# This program is basically "sed", but much more dumb.
#
# Examples:
#
#   $ jou -o replace replace.jou
#   $ echo hi | ./replace hi ho
#   ho
#   $ replace Hello HALLOOO hello.jou
#   $ jou hello.jou
#   HALLOOO World
#
# Installation in case you really like this program:
#
#   $ jou -o ~/bin/replace replace.jou
#
# where instead of ~/bin/ you can use any directory on your PATH.

import "stdlib/assert.jou"
import "stdlib/mem.jou"
import "stdlib/str.jou"
import "stdlib/io.jou"
import "stdlib/errno.jou"
import "stdlib/process.jou"


# TODO: add to stdlib/io.jou
declare tmpfile() -> FILE*


# This function is probably not very fast, but it works well even with infinite
# "files" like a long-running program piped into this program.
def replace_from_file_to_file(in: FILE*, out: FILE*, old: byte*, new: byte*) -> None:
    assert old[0] != '\0'

    rolling_buffer: byte* = malloc(strlen(old))
    assert rolling_buffer != NULL
    rolling_buffer_len = 0

    while True:
        c = fgetc(in)
        if c == EOF:
            if ferror(in) != 0:
                fprintf(get_stderr(), "replace: read error: %s\n", strerror(get_errno()))
                exit(1)
            break

        if old[rolling_buffer_len] == '\0':
            # buffer is full
            if fputc(rolling_buffer[0], out) == EOF:
                fprintf(get_stderr(), "replace: write error: %s\n", strerror(get_errno()))
                exit(1)
            memmove(rolling_buffer, &rolling_buffer[1], --rolling_buffer_len)

        # Add byte to buffer
        rolling_buffer[rolling_buffer_len++] = c as byte

        if old[rolling_buffer_len] == '\0' and memcmp(rolling_buffer, old, rolling_buffer_len) == 0:
            # The entire old string matched
            if fputs(new, out) == EOF:
                fprintf(get_stderr(), "replace: write error: %s\n", strerror(get_errno()))
                exit(1)
            rolling_buffer_len = 0

    # Output remaining content in buffer
    if fwrite(rolling_buffer, 1, rolling_buffer_len, out) != rolling_buffer_len:
        fprintf(get_stderr(), "replace: write error: %s\n", strerror(get_errno()))
        exit(1)

    free(rolling_buffer)


def copy_file(in: FILE*, out: FILE*) -> None:
    buf: byte[4096]
    while True:
        nbytes = fread(buf, 1, sizeof(buf), in)
        if nbytes == 0:
            if ferror(in) != 0:
                fprintf(get_stderr(), "replace: read error: %s\n", strerror(get_errno()))
                exit(1)
            break
        if fwrite(buf, 1, nbytes, out) != nbytes:
            fprintf(get_stderr(), "replace: write error: %s\n", strerror(get_errno()))
            exit(1)


def replace_in_place(path: byte*, old: byte*, new: byte*) -> None:
    temp = tmpfile()
    if temp == NULL:
        fprintf(get_stderr(), "replace: failed to create temporary file: %s\n", strerror(get_errno()))
        exit(1)

    f = fopen(path, "rb")
    if f == NULL:
        fprintf(get_stderr(), "replace: cannot open '%s': %s\n", path, strerror(get_errno()))
        exit(1)
    replace_from_file_to_file(f, temp, old, new)
    fclose(f)

    # TODO: do this in a way that allows checking for errors
    rewind(temp)

    # Needs to be opened again to make it shorter as needed. There is apparently
    # no way to truncate an already opened file in C standard library.
    f = fopen(path, "wb")
    if f == NULL:
        fprintf(get_stderr(), "replace: cannot open '%s': %s\n", path, strerror(get_errno()))
        exit(1)
    copy_file(temp, f)
    fclose(f)
    fclose(temp)


def main(argc: int, argv: byte**) -> int:
    if argc < 3:
        # Test runner runs this with no arguments, hence the output comments here.
        # Output: Usage:
        # Output:   replace old new                   # Read from stdin, write to stdout
        # Output:   replace old new file1 file2 ...   # Edit files in-place
        printf("Usage:\n")
        printf("  replace old new                   # Read from stdin, write to stdout\n")
        printf("  replace old new file1 file2 ...   # Edit files in-place\n")
        return 2

    old = argv[1]
    new = argv[2]
    if old[0] == '\0':
        fprintf(get_stderr(), "replace: old string cannot be empty\n")
        return 1

    if argc == 3:
        replace_from_file_to_file(get_stdin(), get_stdout(), old, new)
    else:
        for i = 3; i < argc; i++:
            replace_in_place(argv[i], old, new)

    return 0
