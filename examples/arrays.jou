import "stdlib/io.jou"

def main() -> int:
    point1 = [1, 2]
    point2 = [3, 4]
    added = point1 + point2

    # Output: 4
    # Output: 6
    for i = 0; i < array_count(added); i++:
        printf("%d\n", added[i])

    # Output: 4
    # Output: 6
    #
    # See also: doc/loops.md
    for ptr = &added[0]; ptr < array_end(added); ptr++:
        printf("%d\n", *ptr)

    return 0
