    # a == b
    @public
    def eq(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = bool_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_eq(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_eq(self, a.hvalue, b.hvalue)
        if self.ubuilder != NULL:
