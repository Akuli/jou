        if self.llvm_builder != NULL:
            result.lvalue = llvm_bit_xor(self, a.lvalue, b.lvalue)
            result.hvalue = hash_bit_xor(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.bit_xor(a.uvalue, b.uvalue)
        return result

    # a << b
    @public
    def bit_shift_left(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_bit_shift_left(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_bit_shift_left(self, a.hvalue, b.hvalue, a.type)
