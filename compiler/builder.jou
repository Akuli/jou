# LLVM doesn't have a built-in union type, and you're supposed to abuse other types for that:
# https://mapping-high-level-constructs-to-llvm-ir.readthedocs.io/en/latest/basic-constructs/unions.html
#
# My first idea was to use an array of bytes that is big enough to fit anything.
# However, that might not be aligned properly.
#
# Then I tried choosing the member type that has the biggest align, and making a large enough array of it.
# Because the align is always a power of two, the memory will be suitably aligned for all member types.
# But it didn't work for some reason I still don't understand.
#
# Then I figured out how clang does it and did it the same way.
# We make a struct that contains:
# - the most aligned type as chosen before
# - array of i8 as padding to make it the right size.
# But for some reason that didn't work either.
#
# As a "last resort" I just use an array of i64 large enough and hope it's aligned as needed.
def union_type_to_llvm(types: LLVMType**, ntypes: int) -> LLVMType*:
    if ntypes == 1:
        return types[0]

    sizeneeded = 0 as int64
    for i = 0; i < ntypes; i++:
        size1 = LLVMABISizeOfType(global_compiler_state.target.main_thread_only.data, types[i])
        size2 = LLVMStoreSizeOfType(global_compiler_state.target.main_thread_only.data, types[i])

        # If this assert fails, you need to figure out which of the size functions should be used.
        # I don't know what their difference is.
        # And if you need the alignment, there's 3 different functions for that...
        assert size1 == size2
        sizeneeded = llmax(sizeneeded, size1)

    return LLVMArrayType(type_to_llvm(int_type(64)), ((sizeneeded+7)/8) as int)


def class_type_to_llvm(type: Type*) -> LLVMType*:
    assert type.kind == TypeKind.Class

    n = type.classdata.fields.len

    flat_elems: LLVMType** = malloc(sizeof(flat_elems[0]) * n)
    for i = 0; i < n; i++:
        flat_elems[i] = type_to_llvm(type.classdata.fields.ptr[i].type)

    # Combine together fields of the same union.
    combined: LLVMType** = malloc(sizeof(combined[0]) * n)
    combinedlen = 0
    for start = 0; start < n; start = end:
        end = start + 1
        while end < n and type.classdata.fields.ptr[start].union_id == type.classdata.fields.ptr[end].union_id:
            end++
        combined[combinedlen++] = union_type_to_llvm(&flat_elems[start], end-start)

    result = LLVMStructType(combined, combinedlen, False as int)
    free(flat_elems)
    free(combined)
    return result


def type_to_llvm(type: Type*) -> LLVMType*:
    if type == NULL:
        # This is only for noreturn and None return types of functions.
        # TODO: tell llvm, if we know a function is noreturn ?
        return LLVMVoidType()

    match type.kind:
        case TypeKind.Array:
            return LLVMArrayType(type_to_llvm(type.array.item_type), type.array.count)
        case TypeKind.Pointer | TypeKind.VoidPointer | TypeKind.FuncPtr:
            return LLVMPointerTypeInContext(LLVMGetGlobalContext(), 0)
        case TypeKind.FloatingPoint:
            if type.size_in_bits == 32:
                return LLVMFloatType()
            if type.size_in_bits == 64:
                return LLVMDoubleType()
            assert False
        case TypeKind.SignedInteger | TypeKind.UnsignedInteger:
            return LLVMIntType(type.size_in_bits)
        case TypeKind.Bool:
            return LLVMInt1Type()
        case TypeKind.TypeVar:
            # This is compiler internal/temporary thing and should never end up here.
            assert False  # please create an issue on GitHub if this errors
        case TypeKind.Class:
            return class_type_to_llvm(type)
        case TypeKind.Enum:
            return type_to_llvm(int_type(32))


# This is not handled by type_to_llvm() because funcptr maps to a pointer in LLVM.
# This function returns an LLVM type representing the underlying function.
def funcptr_type_to_llvm(t: Type*) -> LLVMType*:
    assert t.kind == TypeKind.FuncPtr

    assert t.func_ptr.argtypes.len <= MAX_ARGS
    argtypes: LLVMType*[MAX_ARGS]
    for i = 0; i < t.func_ptr.argtypes.len; i++:
        argtypes[i] = type_to_llvm(t.func_ptr.argtypes.ptr[i])

    return LLVMFunctionType(
        type_to_llvm(t.func_ptr.return_type),
        argtypes,
        t.func_ptr.argtypes.len as int,
        t.func_ptr.takes_varargs as int,
    )


def signature_to_llvm(sig: Signature*) -> LLVMType*:
    # We cannot simply convert the signature into a funcptr type because of
    # thread safety. The new funcptr type might not exist yet, and creating it
    # would cause race conditions.
    assert sig.args.len <= MAX_ARGS
    argtypes: LLVMType*[MAX_ARGS]
    for i = 0; i < sig.args.len; i++:
        argtypes[i] = type_to_llvm(sig.args.ptr[i].type)

    return LLVMFunctionType(
        type_to_llvm(sig.return_type),
        argtypes,
        sig.args.len as int,
        sig.takes_varargs as int,
    )


def declare_in_llvm(sig: Signature*, mod: LLVMModule*) -> LLVMValue*:
    fullname: byte[500]
    self_class = sig.get_self_class()
    if self_class == NULL:
        # function
        snprintf(fullname, sizeof(fullname), "%s", sig.name)
    else:
        # method bark() in class Dog becomes Dog.bark()
        # method append() in generic class List[int] becomes List.append(), not List[int].append()
        n = strcspn(self_class.name, "[")
        snprintf(fullname, sizeof(fullname), "%.*s.%s", n as int, self_class.name, sig.name)

    # Make it so that this can be called many times without issue
    llvm_func = LLVMGetNamedFunction(mod, fullname)
    if llvm_func == NULL:
        llvm_func = LLVMAddFunction(mod, fullname, signature_to_llvm(sig))

    assert llvm_func != NULL
    return llvm_func


def build_llvm_signed_mod(builder: LLVMBuilder*, lhs: LLVMValue*, rhs: LLVMValue*) -> LLVMValue*:
    # Jou's % operator ensures that a%b has same sign as b:
    # jou_mod(a, b) = llvm_mod(llvm_mod(a, b) + b, b)
    llmod = LLVMBuildSRem(builder, lhs, rhs, "smod_tmp")
    sum = LLVMBuildAdd(builder, llmod, rhs, "smod_tmp")
    return LLVMBuildSRem(builder, sum, rhs, "smod")


def build_llvm_signed_div(builder: LLVMBuilder*, lhs: LLVMValue*, rhs: LLVMValue*) -> LLVMValue*:
    # LLVM's provides two divisions. One truncates, the other is an "exact div"
    # that requires there is no remainder. Jou uses floor division which is
    # neither of the two, but is quite easy to implement:
    #
    #    floordiv(a, b) = exact_div(a - jou_mod(a, b), b)
    #
    top = LLVMBuildSub(builder, lhs, build_llvm_signed_mod(builder, lhs, rhs), "sdiv_tmp")
    return LLVMBuildExactSDiv(builder, top, rhs, "sdiv")


# Clamps out-of-range values to min or max. Returns 0 for NaN.
#
# Doing this in LLVM without invoking UB is surprisingly difficult. The
# following pseudo-code roughly describes what this does:
#
#    if float_value is NaN:
#        result = 0
#    elif float_value > max:
#        result = max
#    elif float_value < min:
#        result = min
#    else:
#        result = normal LLVM conversion
#
def cast_floating_point_to_integer(builder: LLVMBuilder*, obj: LLVMValue*, from: Type*, to: Type*) -> LLVMValue*:
    assert from.kind == TypeKind.FloatingPoint
    assert to.is_integer_type()

    is_signed = (to.kind == TypeKind.SignedInteger)

    if is_signed:
        int_min = LLVMConstInt(type_to_llvm(to), to.min_value(), 1)
        int_max = LLVMConstInt(type_to_llvm(to), to.max_value() as int64, 1)
        floating_min = LLVMBuildSIToFP(builder, int_min, type_to_llvm(from), "floating_min")
        floating_max = LLVMBuildSIToFP(builder, int_max, type_to_llvm(from), "floating_max")
    else:
        int_min = LLVMConstInt(type_to_llvm(to), to.min_value(), 0)
        int_max = LLVMConstInt(type_to_llvm(to), to.max_value() as int64, 0)
        floating_min = LLVMBuildUIToFP(builder, int_min, type_to_llvm(from), "floating_min")
        floating_max = LLVMBuildUIToFP(builder, int_max, type_to_llvm(from), "floating_max")

    return LLVMBuildSelect(
        builder,
        # If NaN:
        LLVMBuildFCmp(builder, LLVMRealPredicate.UNO, obj, obj, "is_nan"),
        # then return 0
        LLVMConstInt(type_to_llvm(to), 0, 0),
        # If not NaN:
        LLVMBuildSelect(
            builder,
            # If value > max:
            LLVMBuildFCmp(builder, LLVMRealPredicate.OGT, obj, floating_max, "greater_than_max"),
            # then return max
            int_max,
            # If value <= max:
            LLVMBuildSelect(
                builder,
                # If value < min:
                LLVMBuildFCmp(builder, LLVMRealPredicate.OLT, obj, floating_min, "less_than_min"),
                # then return min
                int_min,
                # If value is between min and max, use LLVM's normal conversion.
                #
                # If value is not between min and max, LLVM returns a poison
                # value. It is fine to construct a poison value if it is not
                # used. Using a poison value invokes UB.
                (
                    LLVMBuildFPToSI(builder, obj, type_to_llvm(to), "normal_cast_signed")
                    if is_signed else
                    LLVMBuildFPToUI(builder, obj, type_to_llvm(to), "normal_cast_unsigned")
                ),
                "min_check",
            ),
            "max_check",
        ),
        "nan_check",
    )


# Builds the result of "a << b" or "a >> b". Avoids LLVM's undefined behaviors.
def bitshift(
    builder: LLVMBuilder*,
    a: LLVMValue*,
    b: LLVMValue*,
    shift_type: Type*,
    left: bool,
) -> LLVMValue*:
    assert LLVMTypeOf(a) == type_to_llvm(shift_type)

    # Shift amount must be converted to a's type because LLVM wants it that
    # way. This is fine: when the result is used, the shift amount is 0 to 63
    # so it surely fits.
    llvm_shift_amount = LLVMBuildIntCast2(builder, b, LLVMTypeOf(a), False as int, "shift_amount")

    # Compute a normal LLVM bitshift. It is a poison value for shifting beyond
    # the width. This is fine because creating a poison value is not UB if you
    # don't use the poison value.
    if left:
        bitshift_or_poison = LLVMBuildShl(builder, a, llvm_shift_amount, "bitshift_or_poison")
    else:
        bitshift_or_poison = LLVMBuildLShr(builder, a, llvm_shift_amount, "bitshift_or_poison")

    return LLVMBuildSelect(
        builder,
        # If we shift beyond the width of the type
        LLVMBuildICmp(
            builder,
            # Check if shift amount >= width
            LLVMIntPredicate.UGE,
            b,
            # Width of the data type (max 64, so surely fits into b's type)
            LLVMConstInt(LLVMTypeOf(b), shift_type.size_in_bits, False as int),
            "shifts_beyond_width",
        ),
        # Then return zero
        LLVMConstInt(LLVMTypeOf(a), 0, False as int),
        # Otherwise, return the result of a normal LLVM bitshift, which is not
        # a poison value when it is chosen.
        bitshift_or_poison,
        "bitshift",
    )


def build_llvm_cast(
    builder: LLVMBuilder*,
    obj: LLVMValue*,
    from: Type*,
    to: Type*,
) -> LLVMValue*:
    assert from != NULL
    assert to != NULL

    # Always treat enums as ints
    if from.kind == TypeKind.Enum:
        from = int_type(32)
    if to.kind == TypeKind.Enum:
        to = int_type(32)

    if from == to:
        return obj

    if from.is_pointer_type() and to.is_pointer_type():
        # All pointers are the same type in LLVM
        return obj

    if from.is_number_type() and to.is_number_type():
        if from.is_integer_type() and to.is_integer_type():
            # Examples:
            #  signed 8-bit 0xFF (-1) --> 16-bit 0xFFFF (-1 or max value)
            #  unsigned 8-bit 0xFF (255) --> 16-bit 0x00FF (255)
            return LLVMBuildIntCast2(builder, obj, type_to_llvm(to), (from.kind == TypeKind.SignedInteger) as int, "cast")
        if from.is_integer_type() and to.kind == TypeKind.FloatingPoint:
            # integer --> double/float
            if from.kind == TypeKind.SignedInteger:
                return LLVMBuildSIToFP(builder, obj, type_to_llvm(to), "cast")
            else:
                return LLVMBuildUIToFP(builder, obj, type_to_llvm(to), "cast")
        if from.kind == TypeKind.FloatingPoint and to.is_integer_type():
            # double/float --> integer
            return cast_floating_point_to_integer(builder, obj, from, to)
        if from.kind == TypeKind.FloatingPoint and to.kind == TypeKind.FloatingPoint:
            # double/float --> double/float
            return LLVMBuildFPCast(builder, obj, type_to_llvm(to), "cast")
        assert False

    if from.is_integer_type() and to.is_pointer_type():
        return LLVMBuildIntToPtr(builder, obj, type_to_llvm(to), "cast")
    if from.is_pointer_type() and to.is_integer_type():
        return LLVMBuildPtrToInt(builder, obj, type_to_llvm(to), "cast")

    if from == bool_type() and to.is_integer_type():
        return LLVMBuildIntCast2(builder, obj, type_to_llvm(to), False as int, "cast")

    printf("cast failed: %s -> %s\n", from.name, to.name)
    assert False


def llvm_declare_global_var(builder: AnyBuilder*, varname: byte*, type: Type*) -> None:
    LLVMAddGlobal(builder.llvm_module, type_to_llvm(type), varname)

def llvm_define_global_var(builder: AnyBuilder*, varname: byte*, type: Type*, initial_value: LLVMValue*, public: bool) -> None:
    llvm_type = type_to_llvm(type)
    globalptr = LLVMAddGlobal(builder.llvm_module, llvm_type, varname)
    assert globalptr != NULL

    if initial_value == NULL:
        LLVMSetInitializer(globalptr, LLVMConstNull(llvm_type))
    else:
        LLVMSetInitializer(globalptr, initial_value)

    if not public:
        LLVMSetLinkage(globalptr, LLVMLinkage.Private)  # This makes it a static global variable

def llvm_begin_function(builder: AnyBuilder*, sig: Signature*, public: bool) -> None:
    builder.llvm_func = declare_in_llvm(sig, builder.llvm_module)
    builder.llvm_returns_a_value = sig.return_type != NULL

    builder.llvm_alloca_block = LLVMAppendBasicBlock(builder.llvm_func, "alloca")
    builder.llvm_code_start_block = LLVMAppendBasicBlock(builder.llvm_func, "code_start")
    LLVMPositionBuilderAtEnd(builder.llvm_builder, builder.llvm_code_start_block)
    builder.llvm_current_block = builder.llvm_code_start_block

    if not public:
        LLVMSetLinkage(builder.llvm_func, LLVMLinkage.Private)

def llvm_end_function(builder: AnyBuilder*) -> None:
    if builder.llvm_returns_a_value:
        # Implicit "return" at the end of a function that should return a value
        LLVMBuildUnreachable(builder.llvm_builder)
    else:
        LLVMBuildRetVoid(builder.llvm_builder)

    LLVMPositionBuilderAtEnd(builder.llvm_builder, builder.llvm_alloca_block)
    LLVMBuildBr(builder.llvm_builder, builder.llvm_code_start_block)

def llvm_begin_statement_in_a_body(builder: AnyBuilder*) -> None:
    pass

def llvm_stack_alloc(builder: AnyBuilder*, t: Type*, varname: byte*) -> LLVMValue*:
    if varname == NULL:
        debug_name = "stack_alloc"
    else:
        debug_name = varname

    # Place all allocations to the same block at start of function, so that
    # we don't overflow the stack when the part of code that creates local
    # var runs many times.
    LLVMPositionBuilderAtEnd(builder.llvm_builder, builder.llvm_alloca_block)
    llvm_ptr = LLVMBuildAlloca(builder.llvm_builder, type_to_llvm(t), debug_name)
    LLVMPositionBuilderAtEnd(builder.llvm_builder, builder.llvm_current_block)
    return llvm_ptr

# *ptr = value
def llvm_set_ptr(builder: AnyBuilder*, ptr: LLVMValue*, value: LLVMValue*) -> None:
    # TODO: fix how typedef llvm_statement works and re-enable this!
    #if ptr.type != value.type.pointer_type():
    #    printf("Cannot set value of %s to %s\n", ptr.type.name, value.type.name)
    #assert ptr.type == value.type.pointer_type()
    ptr_type = LLVMPointerTypeInContext(LLVMGetGlobalContext(), 0)
    LLVMBuildStore(builder.llvm_builder, value, ptr)

# *ptr
def llvm_dereference(builder: AnyBuilder*, ptr: LLVMValue*, ptr_type: Type*) -> LLVMValue*:
    assert ptr_type.kind == TypeKind.Pointer
    return LLVMBuildLoad2(builder.llvm_builder, type_to_llvm(ptr_type.value_type), ptr, "dereference")

# Returns &ptr[index]
def llvm_indexed_pointer(builder: AnyBuilder*, ptr: LLVMValue*, ptr_type: Type*, index: LLVMValue*) -> LLVMValue*:
    assert ptr_type.kind == TypeKind.Pointer
    return LLVMBuildGEP2(
        builder.llvm_builder,
        type_to_llvm(ptr_type.value_type),
        ptr,
        &index,
        1,
        "indexed_pointer",
    )

# Returns &ptr.field
def llvm_class_field_pointer(builder: AnyBuilder*, ptr: LLVMValue*, ptr_type: Type*, field: ClassField*) -> LLVMValue*:
    assert ptr_type.kind == TypeKind.Pointer
    assert ptr_type.value_type.kind == TypeKind.Class

    return LLVMBuildStructGEP2(
        builder.llvm_builder,
        type_to_llvm(ptr_type.value_type),
        ptr,
        field.union_id,
        field.name,
    )

# &global_variable
def llvm_global_var_ptr(builder: AnyBuilder*, name: byte*) -> LLVMValue*:
    result = LLVMGetNamedGlobal(builder.llvm_module, name)
    assert result != NULL
    return result

# some_function
def llvm_get_funcptr(builder: AnyBuilder*, sig: Signature*) -> LLVMValue*:
    return declare_in_llvm(sig, builder.llvm_module)

# i'th argument given to this function
def llvm_get_argument(builder: AnyBuilder*, i: int) -> LLVMValue*:
    return LLVMGetParam(builder.llvm_func, i)

def llvm_call_function(builder: AnyBuilder*, funcptr_type: Type*, func: LLVMValue*, args: LLVMValue**, nargs: int) -> LLVMValue*:
    assert nargs <= MAX_ARGS
    llvm_args: LLVMValue*[MAX_ARGS]
    for i = 0; i < nargs; i++:
        llvm_args[i] = args[i]

    assert funcptr_type.kind == TypeKind.FuncPtr
    debug_name = ""
    if funcptr_type.func_ptr.return_type != NULL:
        debug_name = "func_return_value"

    llvm_return_value = LLVMBuildCall2(
        builder.llvm_builder,
        funcptr_type_to_llvm(funcptr_type),
        func,
        llvm_args,
        nargs,
        debug_name,
    )

    # TODO(refactor): can this be simplified?
    if funcptr_type.func_ptr.return_type == NULL:
        return NULL
    else:
        assert llvm_return_value != NULL
        return llvm_return_value

# self must be included in args
def llvm_call_method(builder: AnyBuilder*, sig: Signature*, args: LLVMValue**, nargs: int) -> LLVMValue*:
    assert nargs >= sig.args.len
    if nargs > sig.args.len:
        assert sig.takes_varargs

    assert nargs <= MAX_ARGS
    llvm_args: LLVMValue*[MAX_ARGS]
    for i = 0; i < nargs; i++:
        llvm_args[i] = args[i]

    debug_name: byte[100] = ""
    if sig.return_type != NULL:
        snprintf(debug_name, sizeof(debug_name), "%s_return_value", sig.name)

    llvm_func = declare_in_llvm(sig, builder.llvm_module)
    llvm_return_value = LLVMBuildCall2(
        builder.llvm_builder,
        signature_to_llvm(sig),
        llvm_func,
        llvm_args,
        nargs,
        debug_name,
    )

    # TODO(refactor): can this be simplified?
    if sig.return_type == NULL:
        return NULL
    else:
        assert llvm_return_value != NULL
        return llvm_return_value

def llvm_array_of_bytes(builder: AnyBuilder*, bytes: List[byte]) -> LLVMValue*:
    assert bytes.len <= UINT32_MAX
    return LLVMConstString(bytes.ptr, bytes.len as uint32, True as int)

def llvm_array(builder: AnyBuilder*, len: int, items: LLVMValue**, item_type: Type*) -> LLVMValue*:
    llvm_items: LLVMValue** = malloc(sizeof(llvm_items[0]) * len)
    assert llvm_items != NULL

    for i = 0; i < len; i++:
        llvm_items[i] = items[i]

    result = LLVMConstArray(type_to_llvm(item_type), llvm_items, len as uint32)
    free(llvm_items)
    return result

# string as '\0' terminated pointer
def llvm_pointer_string(builder: AnyBuilder*, s: byte*) -> LLVMValue*:
    llvm_array = LLVMConstString(s, strlen(s) as uint32, False as int)
    llvm_string = LLVMAddGlobal(builder.llvm_module, LLVMTypeOf(llvm_array), "string_literal")
    LLVMSetLinkage(llvm_string, LLVMLinkage.Private)  # This makes it a static global variable
    LLVMSetInitializer(llvm_string, llvm_array)
    return llvm_string

def llvm_boolean(builder: AnyBuilder*, b: bool) -> LLVMValue*:
    return LLVMConstInt(LLVMInt1Type(), b as int64, False as int)

def llvm_integer(builder: AnyBuilder*, t: Type*, value: int64) -> LLVMValue*:
    assert t.is_integer_type()
    return LLVMConstInt(type_to_llvm(t), value, (t.kind == TypeKind.SignedInteger) as int)

def llvm_float_or_double(builder: AnyBuilder*, t: Type*, dbl: double) -> LLVMValue*:
    assert t.kind == TypeKind.FloatingPoint
    return LLVMConstReal(type_to_llvm(t), dbl)

def llvm_zero_of_type(builder: AnyBuilder*, t: Type*) -> LLVMValue*:
    return LLVMConstNull(type_to_llvm(t))

def llvm_enum_member(builder: AnyBuilder*, t: Type*, name: byte*) -> LLVMValue*:
    int_value = t.find_enum_member(name)
    assert int_value != -1
    return LLVMConstInt(LLVMInt32Type(), int_value, False as int)

# a + b
def llvm_add(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.FloatingPoint:
            return LLVMBuildFAdd(builder.llvm_builder, a, b, "float_sum")
        case TypeKind.SignedInteger | TypeKind.UnsignedInteger:
            return LLVMBuildAdd(builder.llvm_builder, a, b, "int_sum")
        case _:
            assert False

# a - b
def llvm_sub(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.FloatingPoint:
            return LLVMBuildFSub(builder.llvm_builder, a, b, "float_diff")
        case TypeKind.SignedInteger | TypeKind.UnsignedInteger:
            return LLVMBuildSub(builder.llvm_builder, a, b, "int_diff")
        case _:
            assert False

# a * b
def llvm_mul(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.FloatingPoint:
            return LLVMBuildFMul(builder.llvm_builder, a, b, "float_prod")
        case TypeKind.SignedInteger | TypeKind.UnsignedInteger:
            return LLVMBuildMul(builder.llvm_builder, a, b, "int_prod")
        case _:
            assert False

# a / b
def llvm_div(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.FloatingPoint:
            return LLVMBuildFDiv(builder.llvm_builder, a, b, "float_quot")
        case TypeKind.SignedInteger:
            return build_llvm_signed_div(builder.llvm_builder, a, b)
        case TypeKind.UnsignedInteger:
            return LLVMBuildUDiv(builder.llvm_builder, a, b, "uint_quot")
        case _:
            assert False

# a % b
def llvm_mod(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.FloatingPoint:
            return LLVMBuildFRem(builder.llvm_builder, a, b, "float_mod")
        case TypeKind.SignedInteger:
            return build_llvm_signed_mod(builder.llvm_builder, a, b)
        case TypeKind.UnsignedInteger:
            return LLVMBuildURem(builder.llvm_builder, a, b, "uint_mod")
        case _:
            assert False

# a & b
def llvm_bit_and(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*) -> LLVMValue*:
    return LLVMBuildAnd(builder.llvm_builder, a, b, "bit_and")

# a | b
def llvm_bit_or(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*) -> LLVMValue*:
    return LLVMBuildOr(builder.llvm_builder, a, b, "bit_or")

# a ^ b
def llvm_bit_xor(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*) -> LLVMValue*:
    return LLVMBuildXor(builder.llvm_builder, a, b, "bit_xor")

# a << b
def llvm_bit_shift_left(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, shift_type: Type*) -> LLVMValue*:
    return bitshift(builder.llvm_builder, a, b, shift_type, True)

# a >> b
def llvm_bit_shift_right(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, shift_type: Type*) -> LLVMValue*:
    return bitshift(builder.llvm_builder, a, b, shift_type, False)

# a == b
def llvm_eq(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.SignedInteger | TypeKind.UnsignedInteger | TypeKind.Enum | TypeKind.Bool:
            return LLVMBuildICmp(builder.llvm_builder, LLVMIntPredicate.EQ, a, b, "eq")
        case TypeKind.FloatingPoint:
            return LLVMBuildFCmp(builder.llvm_builder, LLVMRealPredicate.OEQ, a, b, "eq")
        case _:
            assert False

# a < b
def llvm_lt(builder: AnyBuilder*, a: LLVMValue*, b: LLVMValue*, type: Type*) -> LLVMValue*:
    match type.kind:
        case TypeKind.SignedInteger:
            return LLVMBuildICmp(builder.llvm_builder, LLVMIntPredicate.SLT, a, b, "lt")
        case TypeKind.UnsignedInteger:
            return LLVMBuildICmp(builder.llvm_builder, LLVMIntPredicate.ULT, a, b, "lt")
        case TypeKind.FloatingPoint:
            return LLVMBuildFCmp(builder.llvm_builder, LLVMRealPredicate.OLT, a, b, "lt")
        case _:
            assert False

# not value
def llvm_not_(builder: AnyBuilder*, value: LLVMValue*) -> LLVMValue*:
    llvm_true = LLVMConstInt(LLVMInt1Type(), 1, False as int)
    return LLVMBuildXor(builder.llvm_builder, value, llvm_true, "not")

# ~value
def llvm_bit_not(builder: AnyBuilder*, value: LLVMValue*, type: Type*) -> LLVMValue*:
    all_bits = uint_type(type.size_in_bits).max_value()
    all_bits_llvm = LLVMConstInt(type_to_llvm(type), all_bits as int64, False as int)
    return LLVMBuildXor(builder.llvm_builder, value, all_bits_llvm, "bit_not")

# sizeof(any value of given type)
def llvm_size_of(builder: AnyBuilder*, t: Type*) -> LLVMValue*:
    # LLVMSizeOf() returns a 64-bit value. Jou's sizeof(x) is 32-bit.
    return LLVMBuildTrunc(builder.llvm_builder, LLVMSizeOf(type_to_llvm(t)), LLVMInt32Type(), "sizeof")

# memset(ptr, 0, sizeof(*ptr))
def llvm_memset_to_zero(builder: AnyBuilder*, ptr: LLVMValue*, ptr_type: Type*) -> None:
    assert ptr_type.kind == TypeKind.Pointer
    size = llvm_size_of(builder, ptr_type.value_type)
    zero_byte = LLVMConstInt(LLVMInt8Type(), 0, False as int)
    LLVMBuildMemSet(builder.llvm_builder, ptr, zero_byte, size, 0)

# value as to
def llvm_cast(builder: AnyBuilder*, value: LLVMValue*, from: Type*, to: Type*) -> LLVMValue*:
    return build_llvm_cast(builder.llvm_builder, value, from, to)

# Blocks are used to implement e.g. if statements and loops.
def llvm_add_block(builder: AnyBuilder*) -> LLVMBasicBlock*:
    return LLVMAppendBasicBlock(builder.llvm_func, "block")

# Decide which block will contain the resulting instructions.
def llvm_set_current_block(builder: AnyBuilder*, block: LLVMBasicBlock*) -> None:
    LLVMPositionBuilderAtEnd(builder.llvm_builder, block)
    builder.llvm_current_block = block

def llvm_branch(builder: AnyBuilder*, cond: LLVMValue*, then: LLVMBasicBlock*, otherwise: LLVMBasicBlock*) -> None:
    LLVMBuildCondBr(builder.llvm_builder, cond, then, otherwise)

def llvm_jump(builder: AnyBuilder*, next_block: LLVMBasicBlock*) -> None:
    LLVMBuildBr(builder.llvm_builder, next_block)

def llvm_unreachable(builder: AnyBuilder*) -> None:
    LLVMBuildUnreachable(builder.llvm_builder)

def llvm_ret(builder: AnyBuilder*, value: LLVMValue*) -> None:
    if value == NULL:
        LLVMBuildRetVoid(builder.llvm_builder)
    else:
        LLVMBuildRet(builder.llvm_builder, value)


def hash_type(hash: Hash*, type: Type*) -> None:
    assert type != NULL

    hash.add_string("type")
    hash.add_int(type.kind as int)
    match type.kind:
        case TypeKind.Array:
            hash.add_int64(type.array.count)
            hash_type(hash, type.array.item_type)
        case (
            # Treat all pointers the same, since they are the same LLVM type.
            TypeKind.Pointer
            | TypeKind.VoidPointer
            | TypeKind.FuncPtr
            # Treat all enums the same, they are int32.
            | TypeKind.Enum
            | TypeKind.Bool
            | TypeKind.TypeVar
        ):
            pass
        case TypeKind.FloatingPoint | TypeKind.SignedInteger | TypeKind.UnsignedInteger:
            hash.add_int(type.size_in_bits)
        case TypeKind.Class:
            # Ignore methods, because only the fields affect the LLVM type.
            for f = type.classdata.fields.ptr; f < type.classdata.fields.end(); f++:
                hash_type(hash, f.type)
                hash.add_int(f.union_id)


def hash_signature(hash: Hash*, sig: Signature*) -> None:
    hash.add_string("signature")
    hash.add_string(sig.name)

    if sig.get_self_class() != NULL:
        # Name of self class is included in function names
        hash.add_string(sig.get_self_class().name)
    else:
        hash.add_string("not a method")

    hash.add_int64(sig.args.len)
    for p = sig.args.ptr; p < sig.args.end(); p++:
        hash_type(hash, p.type)

    if sig.return_type == NULL:
        if sig.is_noreturn:
            hash.add_string("noreturn")
        else:
            hash.add_string("None")
    else:
        hash_type(hash, sig.return_type)


def hash_declare_global_var(builder: AnyBuilder*, varname: byte*, type: Type*) -> None:
    builder.hash.add_string("globaldeclare")
    builder.hash.add_string(varname)
    hash_type(&builder.hash, type)

def hash_define_global_var(builder: AnyBuilder*, varname: byte*, type: Type*, initial_value: int64*, public: bool) -> None:
    builder.hash.add_string("globaldefine")
    builder.hash.add_string(varname)
    builder.hash.add_bool(public)
    hash_type(&builder.hash, type)
    if initial_value != NULL:
        builder.hash.add_int64(*initial_value)

def hash_begin_function(builder: AnyBuilder*, sig: Signature*, public: bool) -> None:
    builder.hash.add_string("begin func")
    hash_signature(&builder.hash, sig)
    builder.hash.add_bool(public)

def hash_end_function(builder: AnyBuilder*) -> None:
    pass

def hash_begin_statement_in_a_body(builder: AnyBuilder*) -> None:
    pass

# Hashes and returns a unique ID number that represents a value in code.
# Also hashes the type, because a changed type may be enough to need a recompile.
def hash_new_value(builder: AnyBuilder*, t: Type*) -> int64:
    id = builder.hash_id_counter++
    builder.hash.add_int64(id)
    if t == NULL:
        builder.hash.add_string("no type")
    else:
        hash_type(&builder.hash, t)
    return id

def hash_stack_alloc(builder: AnyBuilder*, t: Type*, varname: byte*) -> int64:
    # Do nothing with varname, so that renaming a local variable doesn't cause a rebuild
    # TODO: Will need to be different if debug info is enabled
    builder.hash.add_string("stack_alloc")
    hash_type(&builder.hash, t)
    return hash_new_value(builder, t.pointer_type())

# *ptr = value
def hash_set_ptr(builder: AnyBuilder*, ptr: int64, value: int64) -> None:
    builder.hash.add_string("set_ptr")
    builder.hash.add_int64(ptr)
    builder.hash.add_int64(value)

# *ptr
def hash_dereference(builder: AnyBuilder*, ptr: int64, ptr_type: Type*) -> int64:
    builder.hash.add_string("deref")
    builder.hash.add_int64(ptr)
    assert ptr_type.kind == TypeKind.Pointer
    return hash_new_value(builder, ptr_type.value_type)

# Returns &ptr[index]
def hash_indexed_pointer(builder: AnyBuilder*, ptr: int64, ptr_type: Type*, index: int64) -> int64:
    builder.hash.add_string("indexed_pointer")
    builder.hash.add_int64(ptr)
    builder.hash.add_int64(index)
    hash_type(&builder.hash, ptr_type.value_type)  # result depends on size of pointed type
    return hash_new_value(builder, ptr_type)

# Returns &ptr.field
def hash_class_field_pointer(builder: AnyBuilder*, ptr: int64, ptr_type: Type*, field: ClassField*) -> int64:
    # Do not hash field name, renaming fields should not cause recompiling
    assert ptr_type.kind == TypeKind.Pointer
    assert ptr_type.value_type.kind == TypeKind.Class

    # TODO: Result of &ptr.field depends on the offset of the field in the
    #       struct, so ideally we would get it here somehow and compute
    #       that instead of hashing the whole struct.
    hash_type(&builder.hash, ptr_type.value_type)

    builder.hash.add_string("class_field_pointer")
    builder.hash.add_int64(ptr)
    builder.hash.add_int(field.union_id)
    return hash_new_value(builder, field.type.pointer_type())

# &global_variable
def hash_global_var_ptr(builder: AnyBuilder*, name: byte*, var_type: Type*) -> int64:
    builder.hash.add_string("global_var_ptr")
    builder.hash.add_string(name)
    return hash_new_value(builder, var_type.pointer_type())

# some_function
def hash_get_funcptr(builder: AnyBuilder*, signature: Signature*) -> int64:
    builder.hash.add_string("funcptr")
    builder.hash.add_string(signature.name)
    return hash_new_value(builder, signature.to_funcptr_type())

# i'th argument given to this function
def hash_get_argument(builder: AnyBuilder*, i: int, argtype: Type*) -> int64:
    builder.hash.add_string("arg")
    builder.hash.add_int(i)
    return hash_new_value(builder, argtype)

def hash_call_function(builder: AnyBuilder*, funcptr_type: Type*, func: int64, args: int64*, nargs: int) -> int64:
    builder.hash.add_string("call_func")
    builder.hash.add_int64(func)
    for p = args; p < &args[nargs]; p++:
        builder.hash.add_int64(*p)

    assert funcptr_type.kind == TypeKind.FuncPtr
    if funcptr_type.func_ptr.return_type != NULL:
        return hash_new_value(builder, funcptr_type.func_ptr.return_type)
    else:
        return -1

def hash_call_method(builder: AnyBuilder*, sig: Signature*, args: int64*, nargs: int) -> int64:
    hash_signature(&builder.hash, sig)
    for p = args; p < &args[nargs]; p++:
        builder.hash.add_int64(*p)

    if sig.return_type != NULL:
        return hash_new_value(builder, sig.return_type)
    else:
        return -1

# string as array of bytes
def hash_array_of_bytes(builder: AnyBuilder*, bytes: List[byte]) -> int64:
    builder.hash.add_string("array_of_bytes")
    assert bytes.len <= INT32_MAX
    builder.hash.add_int(bytes.len as int)
    builder.hash.add_bytes(bytes.ptr, bytes.len)
    return hash_new_value(builder, uint_type(8).array_type(bytes.len as int))

def hash_array(builder: AnyBuilder*, len: int, items: int64*, item_type: Type*) -> int64:
    builder.hash.add_string("array")
    for i = 0; i < len; i++:
        builder.hash.add_int64(items[i])
    return hash_new_value(builder, item_type.array_type(len))

# string as '\0' terminated pointer
def hash_pointer_string(builder: AnyBuilder*, s: byte*) -> int64:
    builder.hash.add_string("pointer_string")
    builder.hash.add_string(s)
    return hash_new_value(builder, uint_type(8).pointer_type())

def hash_boolean(builder: AnyBuilder*, b: bool) -> int64:
    builder.hash.add_string("bool")
    builder.hash.add_bool(b)
    return hash_new_value(builder, bool_type())

def hash_integer(builder: AnyBuilder*, t: Type*, value: int64) -> int64:
    builder.hash.add_string("integer")
    builder.hash.add_int64(value)
    return hash_new_value(builder, t)

def hash_float_or_double(builder: AnyBuilder*, t: Type*, dbl: double) -> int64:
    builder.hash.add_string("float_or_double")
    builder.hash.add_bytes(&dbl as byte*, sizeof(dbl))
    return hash_new_value(builder, t)

def hash_zero_of_type(builder: AnyBuilder*, t: Type*) -> int64:
    builder.hash.add_string("zero")
    return hash_new_value(builder, t)

def hash_enum_member(builder: AnyBuilder*, t: Type*, name: byte*) -> int64:
    builder.hash.add_string("enum")
    int_value = t.find_enum_member(name)
    assert int_value != -1
    builder.hash.add_int(int_value)
    return hash_new_value(builder, t)

# a + b
def hash_add(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("add")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a - b
def hash_sub(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("sub")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a * b
def hash_mul(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("mul")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a / b
def hash_div(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("div")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a % b
def hash_mod(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("mod")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a & b
def hash_bit_and(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("and")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a | b
def hash_bit_or(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("or")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a ^ b
def hash_bit_xor(builder: AnyBuilder*, a: int64, b: int64, type: Type*) -> int64:
    builder.hash.add_string("xor")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, type)

# a << b
def hash_bit_shift_left(builder: AnyBuilder*, a: int64, b: int64, shift_type: Type*) -> int64:
    builder.hash.add_string("shl")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    # Type of b doesn't matter. Result's type is always the type of a.
    return hash_new_value(builder, shift_type)

# a >> b
def hash_bit_shift_right(builder: AnyBuilder*, a: int64, b: int64, shift_type: Type*) -> int64:
    builder.hash.add_string("shr")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    # Type of b doesn't matter. Result's type is always the type of a.
    return hash_new_value(builder, shift_type)

# a == b
def hash_eq(builder: AnyBuilder*, a: int64, b: int64) -> int64:
    builder.hash.add_string("eq")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, bool_type())

# a < b
def hash_lt(builder: AnyBuilder*, a: int64, b: int64) -> int64:
    builder.hash.add_string("lt")
    builder.hash.add_int64(a)
    builder.hash.add_int64(b)
    return hash_new_value(builder, bool_type())

# not value
def hash_not_(builder: AnyBuilder*, value: int64) -> int64:
    builder.hash.add_string("not")
    builder.hash.add_int64(value)
    return hash_new_value(builder, bool_type())

# ~value
def hash_bit_not(builder: AnyBuilder*, value: int64, type: Type*) -> int64:
    builder.hash.add_string("bitnot")
    builder.hash.add_int64(value)
    return hash_new_value(builder, type)

# sizeof(any value of given type)
def hash_size_of(builder: AnyBuilder*, t: Type*) -> int64:
    builder.hash.add_string("sizeof")
    hash_type(&builder.hash, t)
    return hash_new_value(builder, int_type(32))

# memset(ptr, 0, sizeof(*ptr))
def hash_memset_to_zero(builder: AnyBuilder*, ptr: int64) -> None:
    builder.hash.add_string("memset0")
    builder.hash.add_int64(ptr)

# value as to
def hash_cast(builder: AnyBuilder*, value: int64, to: Type*) -> int64:
    builder.hash.add_string("cast")
    builder.hash.add_int64(value)
    return hash_new_value(builder, to)

def hash_add_block(builder: AnyBuilder*) -> int64:
    builder.hash.add_string("add block")
    block_id = builder.hash_id_counter++
    builder.hash.add_int64(block_id)
    return block_id

# Decide which block will contain the resulting instructions.
def hash_set_current_block(builder: AnyBuilder*, block_id: int64) -> None:
    builder.hash.add_string("set block")
    builder.hash.add_int64(block_id)

def hash_branch(builder: AnyBuilder*, cond: int64, then_block_id: int64, otherwise_block_id: int64) -> None:
    builder.hash.add_string("br")
    builder.hash.add_int64(cond)
    builder.hash.add_int64(then_block_id)
    builder.hash.add_int64(otherwise_block_id)

def hash_jump(builder: AnyBuilder*, next_block_id: int64) -> None:
    builder.hash.add_string("jump")
    builder.hash.add_int64(next_block_id)

def hash_unreachable(builder: AnyBuilder*) -> None:
    builder.hash.add_string("unreachable")

def hash_ret(builder: AnyBuilder*, value: int64*) -> None:
    if value == NULL:
        builder.hash.add_string("ret null")
    else:
        builder.hash.add_string("ret")
        builder.hash.add_int64(*value)


# Special "UVG variable ID". Denotes a value that is not a pointer,
# or is some pointer that we don't keep track of.
const ANONYMOUS_UVG_VALUE_ID: int = -1

# These represent boolean values known at compile time.
const TRUE_UVG_VALUE_ID: int = -2
const FALSE_UVG_VALUE_ID: int = -3


@public
class UBuilder:
    print: bool
    uvg: Uvg
    current_block: UvgBlock*
    location: Location
    inlining_signature: Signature*
    return_value_id: int

    def declare_global_var(self, varname: byte*, type: Type*) -> None:
        pass

    def define_global_var(self, varname: byte*, type: Type*, initial_value: int*, public: bool) -> None:
        pass

    def begin_function(self, sig: Signature*, public: bool) -> None:
        self.uvg.signature = sig
        self.current_block = self.uvg.add_block()
        if sig.return_type != NULL:
            self.return_value_id = self.uvg.stack_alloc("return")
        else:
            self.return_value_id = -1

    def end_function(self) -> None:
        self.ret(NULL)
        self.current_block = NULL
        self.location = Location{}

        if self.print:
            self.uvg.print()
        uvg_analyze(&self.uvg)
        self.uvg.free()
        self.uvg = Uvg{}

    def set_location(self, location: Location, inlining_signature: Signature*) -> None:
        self.inlining_signature = inlining_signature

        # When inlining, do not store the location so that the locations in UVG
        # point at the place where inlined function is being called.
        if inlining_signature == NULL:
            self.location = location

    def add_instruction(self, ins: UvgInstruction) -> None:
        assert ins.var >= 0

        assert self.location.path != NULL
        assert self.location.lineno != 0
        ins.location = self.location
        ins.inlining_signature = self.inlining_signature

        b = self.current_block
        assert b != NULL
        b.instructions.append(ins)

    def begin_statement_in_a_body(self) -> None:
        self.add_instruction(UvgInstruction{kind = UvgInstructionKind.Statement})

    def use(self, var: int) -> None:
        if var >= 0:
            self.add_instruction(UvgInstruction{kind = UvgInstructionKind.Use, var = var})

    def set(self, var: int) -> None:
        if var >= 0:
            self.add_instruction(UvgInstruction{kind = UvgInstructionKind.Set, var = var})

    def dont_analyze(self, var: int) -> None:
        if var >= 0:
            self.add_instruction(UvgInstruction{kind = UvgInstructionKind.DontAnalyze, var = var})

    def stack_alloc(self, t: Type*, varname: byte*) -> int:
        return self.uvg.stack_alloc(varname)

    def set_ptr(self, ptr: int, value: int) -> None:
        self.dont_analyze(value)
        self.set(ptr)

    def dereference(self, ptr: int) -> int:
        self.use(ptr)
        return ANONYMOUS_UVG_VALUE_ID

    def indexed_pointer(self, ptr: int, index: int) -> int:
        self.dont_analyze(ptr)
        return ANONYMOUS_UVG_VALUE_ID

    def class_field_pointer(self, ptr: int, field_name: byte*) -> int:
        self.dont_analyze(ptr)
        return ANONYMOUS_UVG_VALUE_ID

    def global_var_ptr(self, name: byte*, var_type: Type*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def get_funcptr(self, signature: Signature*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def get_argument(self, i: int, argtype: Type*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def call_function(self, funcptr_type: Type*, func: int, args: int*, nargs: int) -> int:
        self.use(func)
        for i = 0; i < nargs; i++:
            self.dont_analyze(args[i])
        return ANONYMOUS_UVG_VALUE_ID

    def call_method(self, sig: Signature*, args: int*, nargs: int) -> int:
        for i = 0; i < nargs; i++:
            self.dont_analyze(args[i])
        return ANONYMOUS_UVG_VALUE_ID

    def array_of_bytes(self, bytes: List[byte]) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def array(self, len: int, items: int*, item_type: Type*) -> int:
        for i = 0; i < len; i++:
            self.use(items[i])
        return ANONYMOUS_UVG_VALUE_ID

    def pointer_string(self, s: byte*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def boolean(self, b: bool) -> int:
        if b:
            return TRUE_UVG_VALUE_ID
        else:
            return FALSE_UVG_VALUE_ID

    def integer(self, t: Type*, value: int64) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def float_or_double(self, t: Type*, dbl: double) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def zero_of_type(self, t: Type*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    def enum_member(self, t: Type*, name: byte*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a + b
    def add(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a - b
    def sub(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a * b
    def mul(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a / b
    def div(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a % b
    def mod(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a & b
    def bit_and(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a | b
    def bit_or(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a ^ b
    def bit_xor(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a << b
    def bit_shift_left(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a >> b
    def bit_shift_right(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a == b
    def eq(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # a < b
    def lt(self, a: int, b: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # not value
    def not_(self, value: int) -> int:
        match value:
            case TRUE_UVG_VALUE_ID:
                return FALSE_UVG_VALUE_ID
            case FALSE_UVG_VALUE_ID:
                return TRUE_UVG_VALUE_ID
            case _:
                return ANONYMOUS_UVG_VALUE_ID

    # ~value
    def bit_not(self, value: int) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # sizeof(any value of given type)
    def size_of(self, t: Type*) -> int:
        return ANONYMOUS_UVG_VALUE_ID

    # memset(ptr, 0, sizeof(*ptr))
    def memset_to_zero(self, ptr: int) -> None:
        self.set(ptr)

    # value as to
    def cast(self, value: int, to: Type*) -> int:
        if to.is_pointer_type():
            # Needed to keep track of pointers to local variables, implicit casts are basically everywhere
            return value
        elif to == bool_type() and (value == TRUE_UVG_VALUE_ID or value == FALSE_UVG_VALUE_ID):
            # Thips helps with e.g. if statements and loops where condition is a literal "True".
            # There is an implicit cast from bool to bool.
            return value
        else:
            # e.g. cast pointer to int64
            self.dont_analyze(value)
            return ANONYMOUS_UVG_VALUE_ID

    # Blocks are used to implement e.g. if statements and loops.
    def add_block(self) -> UvgBlock*:
        return self.uvg.add_block()

    # Decide which block will contain the resulting instructions.
    def set_current_block(self, block: UvgBlock*) -> None:
        self.current_block = block

    def branch(self, cond: int, then: UvgBlock*, otherwise: UvgBlock*) -> None:
        match cond:
            case TRUE_UVG_VALUE_ID:
                self.jump(then)
            case FALSE_UVG_VALUE_ID:
                self.jump(otherwise)
            case _:
                assert self.current_block != NULL
                assert self.current_block.terminator.kind == UvgTerminatorKind.NotSet
                self.current_block.terminator = UvgTerminator{
                    kind = UvgTerminatorKind.Branch,
                    branch = UvgBranch{then = then, otherwise = otherwise},
                }
                self.current_block = NULL

    def jump(self, next_block: UvgBlock*) -> None:
        assert self.current_block != NULL
        assert self.current_block.terminator.kind == UvgTerminatorKind.NotSet
        self.current_block.terminator = UvgTerminator{
            kind = UvgTerminatorKind.Jump,
            jump_block = next_block,
        }
        self.current_block = NULL

    def unreachable(self) -> None:
        assert self.current_block != NULL
        assert self.current_block.terminator.kind == UvgTerminatorKind.NotSet
        self.current_block.terminator = UvgTerminator{kind = UvgTerminatorKind.Unreachable}
        self.current_block = NULL

    def ret(self, value: int*) -> None:
        if value != NULL:
            assert self.return_value_id != -1
            self.set(self.return_value_id)

        if self.return_value_id != -1:
            # The function returns a value
            self.use(self.return_value_id)

        assert self.current_block != NULL
        assert self.current_block.terminator.kind == UvgTerminatorKind.NotSet
        self.current_block.terminator = UvgTerminator{kind = UvgTerminatorKind.Return}


@public
class AnyBuilderValue:
    lvalue: LLVMValue*
    uvalue: int
    hvalue: int64
    type: Type*


@public
class AnyBuilderBlock:
    lblock: LLVMBasicBlock*
    ublock: UvgBlock*  # funny naming :)
    hblock: int64


@public
class AnyBuilder:
    llvm_module: LLVMModule*
    llvm_builder: LLVMBuilder*
    llvm_func: LLVMValue*
    llvm_alloca_block: LLVMBasicBlock*  # local variables created here before code of function runs
    llvm_code_start_block: LLVMBasicBlock*
    llvm_current_block: LLVMBasicBlock*
    llvm_returns_a_value: bool

    hash: Hash
    hash_id_counter: int64

    ubuilder: UBuilder*

    # Also used for imported variables, import vs declare makes no difference in LLVM
    @public
    def declare_global_var(self, varname: byte*, vartype: Type*) -> None:
        if self.llvm_builder != NULL:
            llvm_declare_global_var(self, varname, vartype)
            hash_declare_global_var(self, varname, vartype)
        if self.ubuilder != NULL:
            self.ubuilder.declare_global_var(varname, vartype)

    # If initial value is NULL, zero-initialization will be used.
    @public
    def define_global_var(self, varname: byte*, vartype: Type*, initial_value: AnyBuilderValue*, public: bool) -> None:
        if self.llvm_builder != NULL:
            llvm_define_global_var(self, varname, vartype, NULL if initial_value == NULL else initial_value.lvalue, public)
            hash_define_global_var(self, varname, vartype, NULL if initial_value == NULL else &initial_value.hvalue, public)
        if self.ubuilder != NULL:
            self.ubuilder.define_global_var(varname, vartype, NULL if initial_value == NULL else &initial_value.uvalue, public)

    @public
    def begin_function(self, sig: Signature*, public: bool) -> None:
        if self.llvm_builder != NULL:
            llvm_begin_function(self, sig, public)
            hash_begin_function(self, sig, public)
        if self.ubuilder != NULL:
            self.ubuilder.begin_function(sig, public)

    @public
    def end_function(self) -> None:
        if self.llvm_builder != NULL:
            llvm_end_function(self)
            hash_end_function(self)
        if self.ubuilder != NULL:
            self.ubuilder.end_function()

    @public
    def begin_statement_in_a_body(self) -> None:
        if self.llvm_builder != NULL:
            llvm_begin_statement_in_a_body(self)
            hash_begin_statement_in_a_body(self)
        if self.ubuilder != NULL:
            self.ubuilder.begin_statement_in_a_body()

    # If inlining_signature is not NULL, it means that the given location is
    # inside an @inline function that is being called.
    @public
    def set_location(self, location: Location, inlining_signature: Signature*) -> None:
        if self.ubuilder != NULL:
            self.ubuilder.set_location(location, inlining_signature)

    # Allocates enough stack space in the function to hold a value of given type.
    # Returns a pointer to the stack space.
    # If allocated stack memory is not a local variable, varname must be NULL.
    @public
    def stack_alloc(self, t: Type*, varname: byte*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = t.pointer_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_stack_alloc(self, t, varname)
            result.hvalue = hash_stack_alloc(self, t, varname)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.stack_alloc(t, varname)
        return result

    # *ptr = value
    @public
    def set_ptr(self, ptr: AnyBuilderValue, value: AnyBuilderValue) -> None:
        if self.llvm_builder != NULL:
            llvm_set_ptr(self, ptr.lvalue, value.lvalue)
            hash_set_ptr(self, ptr.hvalue, value.hvalue)
        if self.ubuilder != NULL:
            self.ubuilder.set_ptr(ptr.uvalue, value.uvalue)

    # *ptr
    @public
    def dereference(self, ptr: AnyBuilderValue) -> AnyBuilderValue:
        assert ptr.type.kind == TypeKind.Pointer
        result = AnyBuilderValue{type = ptr.type.value_type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_dereference(self, ptr.lvalue, ptr.type)
            result.hvalue = hash_dereference(self, ptr.hvalue, ptr.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.dereference(ptr.uvalue)
        return result

    # Returns &ptr[index]
    @public
    def indexed_pointer(self, ptr: AnyBuilderValue, index: AnyBuilderValue) -> AnyBuilderValue:
        assert index.type == int_type(64)  # LLVM wants this, easy enough to ensure
        result = AnyBuilderValue{type = ptr.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_indexed_pointer(self, ptr.lvalue, ptr.type, index.lvalue)
            result.hvalue = hash_indexed_pointer(self, ptr.hvalue, ptr.type, index.hvalue)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.indexed_pointer(ptr.uvalue, index.uvalue)
        return result

    # Returns &ptr.field
    @public
    def class_field_pointer(self, ptr: AnyBuilderValue, field_name: byte*) -> AnyBuilderValue:
        assert ptr.type.kind == TypeKind.Pointer
        assert ptr.type.value_type.kind == TypeKind.Class
        field = ptr.type.value_type.find_class_field(field_name)
        assert field != NULL

        result = AnyBuilderValue{type = field.type.pointer_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_class_field_pointer(self, ptr.lvalue, ptr.type, field)
            result.hvalue = hash_class_field_pointer(self, ptr.hvalue, ptr.type, field)
        if self.ubuilder != NULL:
            # TODO(refactor): pass the field, not the name
            result.uvalue = self.ubuilder.class_field_pointer(ptr.uvalue, field_name)
        return result

    @public
    def global_var_ptr(self, name: byte*, var_type: Type*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = var_type.pointer_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_global_var_ptr(self, name)
            result.hvalue = hash_global_var_ptr(self, name, var_type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.global_var_ptr(name, var_type)
        return result

    # Returns a function as funcptr
    @public
    def get_funcptr(self, sig: Signature*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = sig.to_funcptr_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_get_funcptr(self, sig)
            result.hvalue = hash_get_funcptr(self, sig)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.get_funcptr(sig)
        return result

    # Returns the i'th argument given to function
    @public
    def get_argument(self, i: int, argtype: Type*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = argtype}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_get_argument(self, i)
            result.hvalue = hash_get_argument(self, i, argtype)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.get_argument(i, argtype)
        return result

    # Function call through a function pointer
    @public
    def call_function(self, funcptr_type: Type*, func_ptr: AnyBuilderValue, args: AnyBuilderValue*, nargs: int) -> AnyBuilderValue:
        assert funcptr_type.kind == TypeKind.FuncPtr
        assert nargs >= funcptr_type.func_ptr.argtypes.len
        if nargs > funcptr_type.func_ptr.argtypes.len:
            assert funcptr_type.func_ptr.takes_varargs

        assert nargs <= MAX_ARGS
        result = AnyBuilderValue{type = funcptr_type.func_ptr.return_type}

        if self.llvm_builder != NULL:
            largs: LLVMValue*[MAX_ARGS]
            hargs: int64[MAX_ARGS]
            for i = 0; i < nargs; i++:
                largs[i] = args[i].lvalue
                hargs[i] = args[i].hvalue
            result.lvalue = llvm_call_function(self, funcptr_type, func_ptr.lvalue, largs, nargs)
            result.hvalue = hash_call_function(self, funcptr_type, func_ptr.hvalue, hargs, nargs)

        if self.ubuilder != NULL:
            uargs: int[MAX_ARGS]
            for i = 0; i < nargs; i++:
                uargs[i] = args[i].uvalue
            result.uvalue = self.ubuilder.call_function(funcptr_type, func_ptr.uvalue, uargs, nargs)

        return result

    # self with the correct type must be included in args
    @public
    def call_method(self, sig: Signature*, args: AnyBuilderValue*, nargs: int) -> AnyBuilderValue:
        result = AnyBuilderValue{type = sig.return_type}

        assert nargs <= MAX_ARGS

        if self.llvm_builder != NULL:
            largs: LLVMValue*[MAX_ARGS]
            hargs: int64[MAX_ARGS]
            for i = 0; i < nargs; i++:
                largs[i] = args[i].lvalue
                hargs[i] = args[i].hvalue
            result.lvalue = llvm_call_method(self, sig, largs, nargs)
            result.hvalue = hash_call_method(self, sig, hargs, nargs)

        if self.ubuilder != NULL:
            uargs: int[MAX_ARGS]
            for i = 0; i < nargs; i++:
                uargs[i] = args[i].uvalue
            result.uvalue = self.ubuilder.call_method(sig, uargs, nargs)

        return result

    @public
    def array_of_bytes(self, bytes: List[byte]) -> AnyBuilderValue:
        result = AnyBuilderValue{type = uint_type(8).array_type(bytes.len as int)}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_array_of_bytes(self, bytes)
            result.hvalue = hash_array_of_bytes(self, bytes)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.array_of_bytes(bytes)
        return result

    @public
    def array(self, len: int, items: AnyBuilderValue*, item_type: Type*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = item_type.array_type(len)}

        if self.llvm_builder != NULL:
            lvalues: LLVMValue** = malloc(sizeof(lvalues[0]) * len)
            hvalues: int64* = malloc(sizeof(hvalues[0]) * len)
            assert lvalues != NULL
            assert hvalues != NULL
            for i = 0; i < len; i++:
                lvalues[i] = items[i].lvalue
                hvalues[i] = items[i].hvalue
            result.lvalue = llvm_array(self, len, lvalues, item_type)
            result.hvalue = hash_array(self, len, hvalues, item_type)
            free(lvalues)
            free(hvalues)

        if self.ubuilder != NULL:
            uvalues: int* = malloc(sizeof(uvalues[0]) * len)
            assert uvalues != NULL
            for i = 0; i < len; i++:
                uvalues[i] = items[i].uvalue
            result.uvalue = self.ubuilder.array(len, uvalues, item_type)
            free(uvalues)

        return result

    # string as '\0' terminated pointer
    @public
    def pointer_string(self, s: byte*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = uint_type(8).pointer_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_pointer_string(self, s)
            result.hvalue = hash_pointer_string(self, s)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.pointer_string(s)
        return result

    @public
    def boolean(self, b: bool) -> AnyBuilderValue:
        result = AnyBuilderValue{type = bool_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_boolean(self, b)
            result.hvalue = hash_boolean(self, b)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.boolean(b)
        return result

    @public
    def integer(self, t: Type*, value: int64) -> AnyBuilderValue:
        assert t.is_integer_type()
        result = AnyBuilderValue{type = t}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_integer(self, t, value)
            result.hvalue = hash_integer(self, t, value)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.integer(t, value)
        return result

    @public
    def float_or_double(self, t: Type*, dbl: double) -> AnyBuilderValue:
        assert t.kind == TypeKind.FloatingPoint
        result = AnyBuilderValue{type = t}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_float_or_double(self, t, dbl)
            result.hvalue = hash_float_or_double(self, t, dbl)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.float_or_double(t, dbl)
        return result

    @public
    def zero_of_type(self, t: Type*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = t}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_zero_of_type(self, t)
            result.hvalue = hash_zero_of_type(self, t)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.zero_of_type(t)
        return result

    @public
    def enum_member(self, t: Type*, name: byte*) -> AnyBuilderValue:
        result = AnyBuilderValue{type = t}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_enum_member(self, t, name)
            result.hvalue = hash_enum_member(self, t, name)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.enum_member(t, name)
        return result

    # a + b
    @public
    def add(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_add(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_add(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.add(a.uvalue, b.uvalue)
        return result

    # a - b
    @public
    def sub(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_sub(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_sub(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.sub(a.uvalue, b.uvalue)
        return result

    # a * b
    @public
    def mul(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_mul(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_mul(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.mul(a.uvalue, b.uvalue)
        return result

    # a / b
    @public
    def div(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_div(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_div(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.div(a.uvalue, b.uvalue)
        return result

    # a % b
    @public
    def mod(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_mod(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_mod(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.mod(a.uvalue, b.uvalue)
        return result

    # a & b
    @public
    def bit_and(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_bit_and(self, a.lvalue, b.lvalue)
            result.hvalue = hash_bit_and(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.bit_and(a.uvalue, b.uvalue)
        return result

    # a | b
    @public
    def bit_or(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_bit_or(self, a.lvalue, b.lvalue)
            result.hvalue = hash_bit_or(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
            result.uvalue = self.ubuilder.bit_or(a.uvalue, b.uvalue)
        return result

    # a ^ b
    @public
    def bit_xor(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        assert a.type == b.type
