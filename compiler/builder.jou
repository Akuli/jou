    # not value
    @public
    def not_(self, value: AnyBuilderValue) -> AnyBuilderValue:
        assert value.type == bool_type()
        result = AnyBuilderValue{type = bool_type()}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_not_(self, value.lvalue)
