    # a >> b
    @public
    def bit_shift_right(self, a: AnyBuilderValue, b: AnyBuilderValue) -> AnyBuilderValue:
        result = AnyBuilderValue{type = a.type}
        if self.llvm_builder != NULL:
            result.lvalue = llvm_bit_shift_right(self, a.lvalue, b.lvalue, a.type)
            result.hvalue = hash_bit_shift_right(self, a.hvalue, b.hvalue, a.type)
        if self.ubuilder != NULL:
