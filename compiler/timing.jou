# TODO: this belongs to stdlib/time.jou
# https://github.com/Akuli/jou/issues/1210
if LINUX:
    class timespec:
        tv_sec: uint64
        tv_nsec: uint64

    const CLOCK_MONOTONIC: int = 1
    declare clock_gettime(clockid: int, tp: timespec*) -> int

    @public
    def monotonic_ns() -> uint64:
        ts = timespec{}
        clock_gettime(CLOCK_MONOTONIC, &ts)
        return ts.tv_sec * (1_000_000_000 as uint64) + ts.tv_nsec
else:
    # I don't really develop on other platforms so whatever :D
    @public
    def monotonic_ns() -> uint64:
        return 0
