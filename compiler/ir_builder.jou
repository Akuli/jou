#            const Type *classtype = NULL;
#            for (Type **t = file_types->owned_types.ptr; t < End(file_types->owned_types); t++) {
#                if (!strcmp((*t)->name, stmt->data.classdef.name)) {
#                    classtype = *t;
#                    break;
#                }
