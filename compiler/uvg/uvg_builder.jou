import "stdlib/mem.jou"

import "./uvg.jou"
import "../ast.jou"
import "../errors_and_warnings.jou"


class UvgBuilder:
    uvg: Uvg
    current_block: UvgBlock*
    expr_to_id: AstExpression** 
    expr_to_id_len: int
    breakstack: UvgBlock**
    continuestack: UvgBlock**
    nloops: int

    def free(self) -> None:
        free(self->expr_to_id)

    # Return the value ID associated with the expression. Creates a new one if not exist.
    def expr_value_id(self, expr: AstExpression*) -> int:
        match expr->kind:
            # For variables, return a named ID
            case AstExpressionKind.Self:
                return self->uvg.value_id_for_varname("self")
            case AstExpressionKind.GetVariable:
                return self->uvg.value_id_for_varname(expr->varname)
            # For anything else, make it anonymous, but be sure to return same id every time.
            case _:
                for i = 0; i < self->expr_to_id_len; i++:
                    if self->expr_to_id[i] == expr:
                        # return same id as before
                        return i

                # add new
                result = self->uvg.add_value_id(NULL)

                # store to cache so it's same every time
                old_len = self->expr_to_id_len
                new_len = result + 1
                assert new_len > old_len
                self->expr_to_id = realloc(self->expr_to_id, sizeof(self->expr_to_id[0]) * new_len)
                assert self->expr_to_id != NULL
                self->expr_to_id_len = new_len
                memset(&self->expr_to_id[old_len], 0, sizeof(self->expr_to_id[0]) * (new_len - old_len))
                self->expr_to_id[result] = expr

                return result

    # If setting is True, we're setting the value of expr, as in:  expr = ...
    # If setting is False, we're using the value of expr.
    def visit_expression(self, expr: AstExpression*, how: UvgInstructionKind) -> int:
        value_id = self->expr_value_id(expr)

        match expr->kind:
            case (
                AstExpressionKind.String
                | AstExpressionKind.Int
                | AstExpressionKind.Short
                | AstExpressionKind.Long
                | AstExpressionKind.Byte
                | AstExpressionKind.Float
                | AstExpressionKind.Double
                | AstExpressionKind.Bool
                | AstExpressionKind.Null
                | AstExpressionKind.GetEnumMember
                | AstExpressionKind.SizeOf
            ):
                # Simple expression. Result is usable immediately. Does not
                # contain other expressions that could use undefined values.
                assert how == UvgInstructionKind.Use  # not e.g. "hello" = foo

            case AstExpressionKind.GetVariable | AstExpressionKind.Self:
                # Not as simple, but currently requires no special handling.
                pass

            case AstExpressionKind.Array:
                assert how == UvgInstructionKind.Use  # not e.g. [1, 2, 3] = foo
                for i = 0; i < expr->array.length; i++:
                    self->visit_expression(&expr->array.items[i], UvgInstructionKind.Use)

            case AstExpressionKind.Call:
                # Pretend it always has a return value. If it doesn't actually
                # return anything, we end up with one unused anonymous variable.
                # Doesn't matter.
                assert how == UvgInstructionKind.Use
                if expr->call.method_call_self != NULL:
                    self->visit_expression(expr->call.method_call_self, UvgInstructionKind.Use)
                for i = 0; i < expr->call.nargs; i++:
                    self->visit_expression(&expr->call.args[i], UvgInstructionKind.Use)

            case AstExpressionKind.Instantiate:
                assert how == UvgInstructionKind.Use
                for i = 0; i < expr->instantiation.nfields; i++:
                    self->visit_expression(&expr->instantiation.field_values[i], UvgInstructionKind.Use)

            case AstExpressionKind.Dereference:
                # *foo may set value of pointer foo, but not the pointer itself.
                # However, if foo is an array, it accesses the memory of the array directly.
                # TODO: test this
                if expr->operands[0].types.implicit_array_to_pointer_cast:
                    self->visit_expression(&expr->operands[0], how)
                else:
                    self->visit_expression(&expr->operands[0], UvgInstructionKind.Use)

            case AstExpressionKind.Indexing:
                # Treat foo[idx] similarly to *foo, but also evaluate the index.
                # TODO: test this
                if expr->operands[0].types.implicit_array_to_pointer_cast:
                    self->visit_expression(&expr->operands[0], how)
                else:
                    self->visit_expression(&expr->operands[0], UvgInstructionKind.Use)
                self->visit_expression(&expr->operands[1], UvgInstructionKind.Use)

            case AstExpressionKind.GetClassField:
                if expr->class_field.uses_arrow_operator:
                    # Treat foo->blah similarly to *foo.
                    # TODO: test this
                    if expr->operands[0].types.implicit_array_to_pointer_cast:
                        self->visit_expression(expr->class_field.instance, how)
                    else:
                        self->visit_expression(expr->class_field.instance, UvgInstructionKind.Use)
                else:
                    self->visit_expression(expr->class_field.instance, how)

            case AstExpressionKind.Negate | AstExpressionKind.Not | AstExpressionKind.As:
                assert how == UvgInstructionKind.Use
                assert expr->get_arity() == 1
                self->visit_expression(&expr->operands[0], UvgInstructionKind.Use)

            case (
                AstExpressionKind.Add
                | AstExpressionKind.Sub
                | AstExpressionKind.Mul
                | AstExpressionKind.Div
                | AstExpressionKind.Mod
                | AstExpressionKind.Eq
                | AstExpressionKind.Ne
                | AstExpressionKind.Gt
                | AstExpressionKind.Lt
                | AstExpressionKind.Ge
                | AstExpressionKind.Le
                | AstExpressionKind.And  # TODO: lazy evaluation!!!
                | AstExpressionKind.Or  # TODO: lazy evaluation!!!
            ):
                assert how == UvgInstructionKind.Use
                assert expr->get_arity() == 2
                self->visit_expression(&expr->operands[0], UvgInstructionKind.Use)
                self->visit_expression(&expr->operands[1], UvgInstructionKind.Use)

            case (
                AstExpressionKind.PreIncr
                | AstExpressionKind.PreDecr
                | AstExpressionKind.PostIncr
                | AstExpressionKind.PostDecr
            ):
                assert how == UvgInstructionKind.Use
                assert expr->get_arity() == 1
                self->visit_expression(&expr->operands[0], UvgInstructionKind.Use)  # first read current value
                self->visit_expression(&expr->operands[0], UvgInstructionKind.Set)  # then set it

            case AstExpressionKind.AddressOf:
                assert how == UvgInstructionKind.Use
                self->visit_expression(&expr->operands[0], UvgInstructionKind.UseAddress)

        self->current_block->add_instruction(how, value_id, expr->location)
        return value_id

    def visit_if_statement(self, if_stmt: AstIfStatement*) -> None:
        done = self->uvg.add_block()
        for i = 0; i < if_stmt->n_if_and_elifs; i++:
            cond_value_id = self->visit_expression(&if_stmt->if_and_elifs[i].condition, UvgInstructionKind.Use)
            then = self->uvg.add_block()
            otherwise = self->uvg.add_block()

            self->current_block->branch(cond_value_id, then, otherwise)
            self->current_block = then
            self->visit_body(&if_stmt->if_and_elifs[i].body)
            self->current_block->jump(done)
            self->current_block = otherwise

        self->visit_body(&if_stmt->else_body)
        self->current_block->jump(done)
        self->current_block = done

    def visit_match_statement(self, match_stmt: AstMatchStatement*) -> None:
        self->visit_expression(&match_stmt->match_obj, UvgInstructionKind.Use)

        done = self->uvg.add_block()
        for i = 0; i < match_stmt->ncases; i++:
            then = self->uvg.add_block()
            otherwise: UvgBlock* = NULL
            for k = 0; k < match_stmt->cases[i].n_case_objs; k++:
                case_obj_ast = &match_stmt->cases[i].case_objs[k]
                self->visit_expression(case_obj_ast, UvgInstructionKind.Use)

                # Do not try to analyze the condition, create a dummy variable for it
                cond = self->uvg.add_value_id(NULL)
                self->current_block->add_instruction(UvgInstructionKind.Set, cond, case_obj_ast->location)

                otherwise = self->uvg.add_block()
                self->current_block->branch(cond, then, otherwise)
                self->current_block = otherwise

            assert otherwise != NULL

            self->current_block = then
            self->visit_body(&match_stmt->cases[i].body)
            self->current_block->jump(done)
            self->current_block = otherwise

        if match_stmt->case_underscore != NULL:
            self->visit_body(match_stmt->case_underscore)
        self->current_block->jump(done)
        self->current_block = done

    def visit_loop(
        self,
        init: AstStatement*,
        cond: AstExpression*,
        incr: AstStatement*,
        body: AstBody*,
    ) -> None:
        condblock = self->uvg.add_block()  # evaluate condition and go to bodyblock or doneblock
        bodyblock = self->uvg.add_block()  # run loop body and go to incrblock
        incrblock = self->uvg.add_block()  # run incr and go to condblock
        doneblock = self->uvg.add_block()  # rest of the code goes here

        if init != NULL:
            self->visit_statement(init)

        # Evaluate condition. Jump to loop body or skip to after loop.
        self->current_block->jump(condblock)
        self->current_block = condblock
        cond_value_id = self->visit_expression(cond, UvgInstructionKind.Use)
        self->current_block->branch(cond_value_id, bodyblock, doneblock)
        self->current_block = bodyblock

        # 'break' skips to after loop, 'continue' goes to incr.
        self->breakstack = realloc(self->breakstack, sizeof(self->breakstack[0]) * (self->nloops + 1))
        self->continuestack = realloc(self->continuestack, sizeof(self->continuestack[0]) * (self->nloops + 1))
        assert self->breakstack != NULL
        assert self->continuestack != NULL
        self->breakstack[self->nloops] = doneblock
        self->continuestack[self->nloops] = incrblock
        self->nloops++

        # Run loop body
        self->visit_body(body)

        self->nloops--
        assert self->breakstack[self->nloops] == doneblock
        assert self->continuestack[self->nloops] == incrblock

        # Run incr and jump back to condition.
        self->current_block->jump(incrblock)
        self->current_block = incrblock
        if incr != NULL:
            self->visit_statement(incr)
        self->current_block->jump(condblock)
        self->current_block = doneblock

    def visit_statement(self, stmt: AstStatement*) -> None:
        match stmt->kind:
            case AstStatementKind.ExpressionStatement:
                # Currently not possible to visit expression so that you do
                # nothing with the result. Let's pretend we use it for something.
                self->visit_expression(&stmt->expression, UvgInstructionKind.Use)
            case AstStatementKind.Assert:
                cond = self->visit_expression(&stmt->assertion.condition, UvgInstructionKind.Use)
                assert_true = self->uvg.add_block()
                assert_false = self->uvg.add_block()  # will be left empty, actually throws error message
                assert_false->exit_program()
                self->current_block->branch(cond, assert_true, assert_false)
                self->current_block = assert_true
            case AstStatementKind.Pass:
                pass
            case AstStatementKind.Return:
                if stmt->return_value != NULL:
                    self->visit_expression(stmt->return_value, UvgInstructionKind.Use)
                    retval = self->uvg.value_id_for_varname("return")
                    self->current_block->add_instruction(UvgInstructionKind.Set, retval, stmt->location)
            case AstStatementKind.If:
                self->visit_if_statement(&stmt->if_statement)
            case AstStatementKind.Match:
                self->visit_match_statement(&stmt->match_statement)
            case AstStatementKind.WhileLoop:
                self->visit_loop(
                    NULL, &stmt->while_loop.condition, NULL,
                    &stmt->while_loop.body)
            case AstStatementKind.ForLoop:
                self->visit_loop(
                    stmt->for_loop.init, &stmt->for_loop.cond, stmt->for_loop.incr,
                    &stmt->for_loop.body)
            case AstStatementKind.Break:
                assert self->nloops != 0
                self->current_block->jump(self->breakstack[self->nloops - 1])
                self->current_block = self->uvg.add_block()
            case AstStatementKind.Continue:
                assert self->nloops != 0
                self->current_block->jump(self->continuestack[self->nloops - 1])
                self->current_block = self->uvg.add_block()

    def visit_body(self, body: AstBody*) -> None:
        for i = 0; i < body->nstatements; i++:
            self->visit_statement(&body->statements[i])
