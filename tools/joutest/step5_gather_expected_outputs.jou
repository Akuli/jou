import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"
import "stdlib/mem.jou"
import "stdlib/math.jou"
import "stdlib/intnative.jou"

import "./fail.jou"
import "./string_formatter.jou"
import "./state.jou"


# Examples:
#   "# Output: whatever\n", "Output" --> "whatever\n"
#   "# Lolwat: whatever\n", "Output" --> NULL
def skip_start_of_comment(p: byte*, marker: byte*) -> byte*:
    if *p++ != '#':
        return NULL
    if *p++ != ' ':
        return NULL
    while *marker != '\0':
        if *p++ != *marker++:
            return NULL
    if *p++ != ':':
        return NULL

    match *p:
        case ' ':
            # skip space so "# Output: foo\n" becomes "foo\n"
            return &p[1]
        case '\0':
            # treat "# Output:" as blank line
            return p
        case _:
            return NULL


def find_expected_output_from_line(
    test: Test*,
    lineno: int,
    line: byte*,
    out: List[byte]*,
) -> None:
    for p = &line[strlen(line)]; p >= &line[0]; p--:
        for m = test.config.output_comment_rules.ptr; m < test.config.output_comment_rules.end(); m++:
            marker = (*m)[0]
            template = (*m)[1]

            comment = skip_start_of_comment(p, marker)
            if comment != NULL:
                lineno_str: byte[100]
                sprintf(lineno_str, "%d", lineno)

                params: byte*[enum_count(FormatParam)]
                memset(params, 0, sizeof(params))
                params[FormatParam.File as int] = test.get_relative_path()
                params[FormatParam.Line as int] = lineno_str
                params[FormatParam.Comment as int] = comment

                s = format_string(template, params)
                out.extend_from_ptr(s, strlen(s))
                out.append('\n')
                free(s)
                return


global big_buffer: byte[1_000_000]  # surely big enough to fit entire lines!


def find_expected_output(test: Test*) -> None:
    result = List[byte]{}
    lineno = 1

    if test.stdin_input == NULL:
        f = fopen(test.path, "rb")
        if f == NULL:
            e = get_errno()
            message: byte[300]
            snprintf(message, sizeof(message), "reading expected output from '%s' failed", test.path)
            fail_with_errno(message, e)

        while fgets(big_buffer, sizeof(big_buffer), f) != NULL:
            big_buffer[strcspn(big_buffer, "\r\n")] = '\0'
            find_expected_output_from_line(test, lineno++, big_buffer, &result)

        fclose(f)

    else:
        p = test.stdin_input
        while *p != '\0':
            line_len = llmin(strcspn(p, "\r\n"), sizeof(big_buffer) - 1) as intnative
            memcpy(big_buffer, p, line_len)
            big_buffer[line_len] = '\0'
            find_expected_output_from_line(test, lineno++, big_buffer, &result)

            p = &p[line_len]
            if *p == '\r':
                p++
            if *p == '\n':
                p++

    result.append('\0')
    test.expected_output = result.ptr


@public
def step5_gather_expected_outputs(tests: List[Test]) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        find_expected_output(test)
