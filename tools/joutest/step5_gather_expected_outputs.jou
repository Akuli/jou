import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"

import "./fail.jou"
import "./state.jou"


def find_expected_output(path: byte*) -> byte*:
    message: byte[300]

    f = fopen(path, "rb")
    if f == NULL:
        snprintf(message, sizeof(message), "reading expected output from '%s' failed: %s", strerror(get_errno()))
        fail(message)

    result = List[byte]{}
    line: byte[4096]
    while fgets(line, sizeof(line), f) != NULL:
        if ends_with(line, "\r\n"):
            strcpy(&line[strlen(line) - 2], "\n")

        marker = "# Output:"
        for p = &line[strlen(line)]; p >= &line[0]; p--:
            if starts_with(p, marker):
                after_marker = &p[strlen(marker)]
                if *after_marker == ' ' or *after_marker == '\n':
                    if *after_marker == ' ':
                        after_marker++
                    result.extend_from_ptr(after_marker, strlen(after_marker))
                    break

    result.append('\0')
    return result.ptr


@public
def step5_gather_expected_outputs(tests: List[Test]) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        if test.uses_output_capturing:
            test.expected_output = find_expected_output(test.path)
