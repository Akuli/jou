# This actually runs the tests.
#
# Most of the result reporting happens later, but some output is printed as the
# tests run.
#
# Note about error handling
# ~~~~~~~~~~~~~~~~~~~~~~~~~
# If a test crashes in any way (wrong exit code, wrong output, dies with signal),
# we should report the failure and keep going to run other tests. However, if
# something else seems to be wrong, then the test runner process or the OS is
# broken in some way, and you should use fail() to stop the test runner.

import "stdlib/assert.jou"
import "stdlib/intnative.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/process.jou"
import "stdlib/str.jou"

import "./ansi_colors.jou"
import "./fail.jou"
import "./state.jou"

if not WINDOWS:
    import "stdlib/errno.jou"


def add_output_byte(out: List[byte]*, b: byte) -> None:
    match b:
        case '\0':
            # TODO: Escaping similar to this could be good for other weird bytes too.
            out.extend_from_ptr("<\\0>", 4)
        case '\n':
            # Windows line endings handling: \r\n --> \n
            if out.len > 0 and out.end()[-1] == '\r':
                out.pop()
            out.append('\n')
        case _:
            out.append(b)


if WINDOWS:
    class STARTUPINFOA:
        cb: uint32
        lpReserved: byte*
        lpDesktop: byte*
        lpTitle: byte*
        dwX: uint32
        dwY: uint32
        dwXSize: uint32
        dwYSize: uint32
        dwXCountChars: uint32
        dwYCountChars: uint32
        dwFillAttribute: uint32
        dwFlags: uint32
        wShowWindow: uint16
        cbReserved2: uint16
        lpReserved2: byte*
        hStdInput: intnative
        hStdOutput: intnative
        hStdError: intnative

    class PROCESS_INFORMATION:
        hProcess: intnative
        hThread: intnative
        dwProcessId: uint32
        dwThreadId: uint32

    declare FormatMessageA(
        dwFlags: uint32,
        lpSource: void*,
        dwMessageId: uint32,
        dwLanguageId: uint32,
        lpBuffer: byte*,
        nSize: uint32,
        Arguments: void*,  # actually va_list*
    ) -> uint32
    declare CreateProcessA(
        lpApplicationName: byte*,
        lpCommandLine: byte*,  # may be modified! at least in the W version. Windows is weird...
        lpProcessAttributes: void*,  # actually SECURITY_ATTRIBUTES*
        lpThreadAttributes: void*,  # actually SECURITY_ATTRIBUTES*
        bInheritHandles: int,
        dwCreationFlags: uint32,
        lpEnvironment: void*,
        lpCurrentDirectory: byte*,
        lpStartupInfo: STARTUPINFOA*,
        lpProcessInformation: PROCESS_INFORMATION*,
    ) -> int
    declare GetLastError() -> uint32
    declare WaitForSingleObject(handle: intnative, dwMilliseconds: uint32) -> uint32
    declare GetExitCodeProcess(hProcess: intnative, lpExitCode: uint32*) -> int
    declare CloseHandle(hObject: intnative) -> int
    declare CreatePipe(
        hReadPipe: intnative*,
        hWritePipe: intnative*,
        lpPipeAttributes: void*,  # actually SECURITY_ATTRIBUTES*
        nSize: uint32,
    ) -> int
    declare SetHandleInformation(hObject: intnative, dwMask: uint32, dwFlags: uint32) -> int
    declare ReadFile(
        hFile: intnative,
        lpBuffer: void*,
        nNumberOfBytesToRead: uint32,
        lpNumberOfBytesRead: uint32*,
        lpOverlapped: void*,  # actually OVERLAPPED*
    ) -> int

    const FORMAT_MESSAGE_IGNORE_INSERTS: uint32 = 0x00000200
    const FORMAT_MESSAGE_FROM_SYSTEM: uint32 = 0x00001000
    const INFINITE: uint32 = 0xffff_ffff
    const INVALID_HANDLE_VALUE: intnative = -1
    const HANDLE_FLAG_INHERIT: uint32 = 0x00000001
    const STARTF_USESTDHANDLES: uint32 = 0x00000100

    def get_last_error_string() -> byte[300]:
        result: byte[300] = ""
        FormatMessageA(
            FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS,
            NULL, GetLastError(), 0, result, sizeof(result) as uint32, NULL,
        )
        return result

    # This takes a string because that's how windows works. The command line of
    # a Windows process is a string at the lowest level. The process itself
    # (typically libc) splits it into argc and argv or similar, if it wants.
    # The OS does not have a concept of separate arguments.
    #
    # This does not pass the given string to a shell.
    def run_command(test: Test*) -> None:
        error: byte[300]

        pipe_read: intnative = INVALID_HANDLE_VALUE
        pipe_write: intnative = INVALID_HANDLE_VALUE

        if test.uses_output_capturing:
            if CreatePipe(&pipe_read, &pipe_write, NULL, 0) == 0:
                gle = get_last_error_string()
                snprintf(error, sizeof(error), "CreatePipe() failed: %s", gle)
                fail(error)

            # Mark the write end of the pipe as inheritable so the child
            # process can write to it.
            if SetHandleInformation(pipe_write, HANDLE_FLAG_INHERIT, HANDLE_FLAG_INHERIT) == 0:
                gle = get_last_error_string()
                snprintf(error, sizeof(error), "SetHandleInformation() failed: %s", gle)
                fail(error)

        startup_info = STARTUPINFOA{}
        startup_info.cb = sizeof(startup_info) as uint32
        if test.uses_output_capturing:
            startup_info.dwFlags = STARTF_USESTDHANDLES
            if test.stdout_capture_mode != CaptureMode.DoNotCapture:
                startup_info.hStdOutput = pipe_write
            if test.stderr_capture_mode != CaptureMode.DoNotCapture:
                startup_info.hStdError = pipe_write
        process_info = PROCESS_INFORMATION{}

        string = strdup(test.actual_command_string)  # Apparently windows may modify it, don't know why...
        ret = CreateProcessA(
            NULL,  # Program name is a part of our arguments string
            string,
            NULL,
            NULL,
            test.uses_output_capturing as int,
            0,
            NULL,
            NULL,
            &startup_info,
            &process_info,
        )
        free(string)

        # From now on, child is going to write and parent is going to read
        if test.uses_output_capturing:
            CloseHandle(pipe_write)

        if ret == 0:
            test.detail_result.start_error = GetLastError() as int
            if test.uses_output_capturing:
                CloseHandle(pipe_write)
            return

        assert test.actual_output == NULL
        if test.uses_output_capturing:
            output = List[byte]{}
            buf: byte[4096]
            n: uint32 = 0
            while True:
                if ReadFile(pipe_read, buf, sizeof(buf) as uint32, &n, NULL) == 0:
                    gle = get_last_error_string()
                    snprintf(error, sizeof(error), "ReadFile() failed: %s", gle)
                    fail(error)
                if n == 0:
                    break
                for i = 0; i < n; i++:
                    add_output_byte(&output, buf[i])
            CloseHandle(pipe_read)
            output.append('\0')
            test.actual_output = output.ptr

        if WaitForSingleObject(process_info.hProcess, INFINITE) != 0:
            gle = get_last_error_string()
            snprintf(error, sizeof(error), "WaitForSingleObject() failed: %s", gle)
            fail(error)

        exit_code: uint32 = 0
        if GetExitCodeProcess(process_info.hProcess, &exit_code) == 0:
            gle = get_last_error_string()
            snprintf(error, sizeof(error), "GetExitCodeProcess() failed: %s", gle)
            fail(error)

        CloseHandle(process_info.hProcess)
        CloseHandle(process_info.hThread)
        test.detail_result.exit_code = exit_code as int

else:
    # This is 80 bytes on my linux system, doubling that so it's hopefully big
    # enough everywhere.
    typedef posix_spawn_file_actions_t = uint64[20]

    declare posix_spawnp(
        pid: int*,
        file: byte*,
        actions: posix_spawn_file_actions_t*,
        attrp: void*,  # actually posix_spawnattr_t*
        argv: byte**,
        envp: byte**,
    ) -> int
    declare waitpid(pid: int, wstatus: int*, options: int) -> int
    declare pipe(pipefd: int[2]*) -> int
    declare close(fd: int) -> int
    declare read(fd: int, buf: void*, count: intnative) -> intnative
    declare posix_spawn_file_actions_init(actions: posix_spawn_file_actions_t*) -> int
    declare posix_spawn_file_actions_adddup2(actions: posix_spawn_file_actions_t*, fd: int, newfd: int) -> int
    declare posix_spawn_file_actions_addclose(actions: posix_spawn_file_actions_t*, fd: int) -> int
    declare posix_spawn_file_actions_destroy(file_actions: posix_spawn_file_actions_t*) -> int
    declare global environ: byte**

    # Returns True if the process terminated with a signal
    def WIFSIGNALED(s: int) -> bool:
        # 127 means "stopped", see WIFSTOPPED(). We should never get that value.
        return WTERMSIG(s) != 0 and WTERMSIG(s) != 127

    # Returns True if the process exited normally.
    def WIFEXITED(s: int) -> bool:
        return WTERMSIG(s) == 0

    # If the process terminated by exiting normally, returns the exit code.
    def WEXITSTATUS(s: int) -> int:
        return (s >> 8) & 0xff

    # If the process terminated with a signal, returns the signal number.
    def WTERMSIG(s: int) -> int:
        return s & 0x7f

    def run_command(test: Test*) -> None:
        message: byte[300]

        actions: posix_spawn_file_actions_t
        if test.uses_output_capturing:
            pipefd: int[2]
            if pipe(&pipefd) != 0:
                snprintf(message, sizeof(message), "pipe() failed: %s", strerror(get_errno()))
                fail(message)
            pipe_read = pipefd[0]
            pipe_write = pipefd[1]

            err = posix_spawn_file_actions_init(&actions)
            if err != 0:
                snprintf(message, sizeof(message), "posix_spawn_file_actions_init() failed: %s", strerror(err))
                fail(message)

            if test.stdout_capture_mode != CaptureMode.DoNotCapture:
                # Write end of the pipe becomes stdout in the child process
                err = posix_spawn_file_actions_adddup2(&actions, pipe_write, 1)
                if err != 0:
                    snprintf(message, sizeof(message), "posix_spawn_file_actions_adddup2() failed: %s", strerror(err))
                    fail(message)

            if test.stderr_capture_mode != CaptureMode.DoNotCapture:
                # Write end of the pipe becomes stderr in the child process
                err = posix_spawn_file_actions_adddup2(&actions, pipe_write, 2)
                if err != 0:
                    snprintf(message, sizeof(message), "posix_spawn_file_actions_adddup2() failed: %s", strerror(err))
                    fail(message)

            # Child process is not going to read from the pipe, so it closes
            # its read end of the pipe.
            ret = posix_spawn_file_actions_addclose(&actions, pipe_read)
            if err != 0:
                snprintf(message, sizeof(message), "posix_spawn_file_actions_addclose() failed: %s", strerror(err))
                fail(message)

            actions_ptr = &actions
        else:
            pipe_read = -1
            pipe_write = -1
            actions_ptr = NULL

        assert test.actual_command_list.len > 0

        pid = 0
        test.actual_command_list.append(NULL)
        test.detail_result.start_error = posix_spawnp(
            &pid,
            test.actual_command_list.ptr[0],
            actions_ptr,
            NULL,
            test.actual_command_list.ptr,
            environ,
        )
        test.actual_command_list.pop()

        if actions_ptr != NULL:
            posix_spawn_file_actions_destroy(actions_ptr)
        close(pipe_write)  # Parent process is not going to write to the pipe

        if test.detail_result.start_error != 0:
            close(pipe_read)
            return

        assert test.actual_output == NULL
        if test.uses_output_capturing:
            output = List[byte]{}
            buf: byte[4096]
            while True:
                n = read(pipe_read, buf, sizeof(buf))
                if n < 0:
                    snprintf(message, sizeof(message), "reading output failed: %s", strerror(get_errno()))
                    fail(message)
                assert n >= 0  # TODO
                if n == 0:
                    break
                for i = 0; i < n; i++:
                    add_output_byte(&output, buf[i])
            close(pipe_read)
            output.append('\0')
            test.actual_output = output.ptr

        wstatus = 0
        ret = waitpid(pid, &wstatus, 0)
        if ret == -1:
            snprintf(message, sizeof(message), "waitpid() failed: %s", strerror(get_errno()))
            fail(message)

        if WIFEXITED(wstatus):
            test.detail_result.exit_code = WEXITSTATUS(wstatus)
        elif WIFSIGNALED(wstatus):
            assert WTERMSIG(wstatus) != 0
            test.detail_result.terminating_signal = WTERMSIG(wstatus)
        else:
            # I'm not quite sure whether this can ever happen.
            snprintf(message, sizeof(message), "waitpid() gave a status that is neither exit nor signal: %#08x", wstatus)
            fail(message)


def run_test(test: Test*, args: CommandLineArgs*) -> None:
    if args.verbose:
        printf("%srun:%s %s\n", BLUE, RESET, test.actual_command_string)
        fflush(get_stdout())

    run_command(test)

    if (
        test.detail_result.start_error == 0
        and test.detail_result.terminating_signal == 0
        and test.detail_result.exit_code == 0
        and (test.actual_output == NULL or strcmp(test.expected_output, test.actual_output) == 0)
    ):
        test.simple_result = SimpleResult.Success
    else:
        test.simple_result = SimpleResult.Failed

    if args.verbose:
        match test.simple_result:
            case SimpleResult.Success:
                printf("%s ok %s %s\n", GREEN, RESET, test.actual_command_string)
            case SimpleResult.Failed:
                printf("%sFAIL%s %s\n", RED, RESET, test.actual_command_string)
            case SimpleResult.Skipped:
                printf("%sskip%s %s\n", YELLOW, RESET, test.actual_command_string)
    else:
        match test.simple_result:
            case SimpleResult.Success:
                printf("%s.%s", GREEN, RESET)
            case SimpleResult.Failed:
                printf("%sF%s", RED, RESET)
            case SimpleResult.Skipped:
                printf("%ss%s", YELLOW, RESET)
    fflush(get_stdout())


if not WINDOWS:
    declare dirname(path: byte*) -> byte*
    declare setenv(name: byte*, value: byte*, overwrite: int) -> int
    if MACOS:
        declare _NSGetExecutablePath(buf: byte*, bufsize: int*) -> int
    elif NETBSD:
        declare sysctl(
            name: int*,
            namelen: uint32,
            oldp: void*,
            oldlenp: intnative*,
            newp: void*,  # NULL if not setting a new value
            newlen: intnative,  # 0 if not setting a new value
        ) -> int
        const CTL_KERN: int = 1
        const KERN_PROC_ARGS: int = 48
        const KERN_PROC_PATHNAME: int = 5
        const ENOSPC: int = 28  # No space left on this device
    else:
        declare readlink(linkpath: byte*, result: byte*, result_size: intnative) -> intnative

    # TODO: This function is copy/pasted from Jou compiler, move to stdlib?
    #       I removed the Windows branches because we don't need them here.
    def find_current_executable() -> byte*:
        if MACOS:
            n = 1
            result: byte* = malloc(n)
            ret = _NSGetExecutablePath(result, &n)  # sets n to desired size
            assert ret < 0  # didn't fit
            result = realloc(result, n)
            ret = _NSGetExecutablePath(result, &n)
            if ret == 0:
                # success
                return result
        else:
            buf: byte* = NULL
            for size = 2; True; size *= 2:
                buf = realloc(buf, size)
                memset(buf, 0, size)
                if NETBSD:
                    sysctl_name: int[4] = [CTL_KERN, KERN_PROC_ARGS, -1, KERN_PROC_PATHNAME]
                    n: intnative = size
                    ret = sysctl(sysctl_name, array_count(sysctl_name) as uint32, buf, &n, NULL, 0)
                    if ret < 0 and get_errno() != ENOSPC:
                        break  # error
                    if n < size:
                        return buf  # success, it fits
                else:
                    ret = readlink("/proc/self/exe", buf, size)
                    success = 0 <= ret and ret < size
                    if ret < 0:
                        break  # error
                    if ret < size:
                        buf[ret] = '\0'  # Work around valgrind bug: https://bugs.kde.org/show_bug.cgi?id=514094
                        return buf  # success, it fits

        # TODO: show os error message? (GetLastError / errno)
        fail("cannot locate currently running executable, needed for finding the Jou compiler")

    # Adds the directory containing joutest to PATH. It usually contains the
    # Jou compiler.
    #
    # This is not needed on Windows, because Windows looks at the directory
    # containing joutest.exe before even considering PATH. Windows is weird,
    # but in this case the Windows behavior is what we want.
    def add_joutest_dir_to_PATH() -> None:
        joutest_exe = find_current_executable()
        joutest_dir = dirname(joutest_exe)
        if strstr(joutest_exe, ":") != NULL:
            fail("directory containing joutest contains ':' and hence cannot be added to PATH")

        new_path: byte* = NULL
        asprintf(&new_path, "%s:%s", joutest_dir, getenv("PATH"))
        assert new_path != NULL
        free(joutest_exe)

        setenv("PATH", new_path, True as int)
        free(new_path)


@public
def step6_run_tests(tests: List[Test], args: CommandLineArgs*) -> None:
    if not WINDOWS:
        old_path = getenv("PATH")
        if old_path == NULL:
            fail("no PATH environment variable")
        old_path = strdup(old_path)
        add_joutest_dir_to_PATH()

    for t = tests.ptr; t < tests.end(); t++:
        run_test(t, args)

    if not WINDOWS:
        setenv("PATH", old_path, True as int)
        free(old_path)
