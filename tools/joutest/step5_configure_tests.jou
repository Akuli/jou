# TODO: This step is kinda dumb and could probably be deleted.

import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"
import "stdlib/mem.jou"

import "./state.jou"
import "./string_formatter.jou"


# This is public and available on all platforms, because there's a test that
# imports this.
@public
def command_to_string_windows(command: List[byte*]) -> byte*:
    result = List[byte]{}

    for i = 0; i < command.len; i++:
        if i != 0:
            result.append(' ')
        arg = command.ptr[i]

        quoting = arg[0] == '\0' or strstr(arg, " ") != NULL or strstr(arg, "\t") != NULL
        if quoting:
            result.append('"')

        backslash_count = 0
        for p = arg; *p != '\0'; p++:
            match *p:
                case '\\':
                    result.append('\\')
                    backslash_count++
                case '"':
                    # Put double backslashes before quote
                    for ; backslash_count > 0; backslash_count--:
                        result.append('\\')
                    result.append('\\')
                    result.append('"')
                case _:
                    result.append(*p)
                    backslash_count = 0

        if quoting:
            # Put double backslashes before quote
            for ; backslash_count > 0; backslash_count--:
                result.append('\\')
            result.append('"')

    result.append('\0')
    return result.ptr


if not WINDOWS:
    def command_to_string_posix(command: List[byte*]) -> byte*:
        result = List[byte]{}

        for i = 0; i < command.len; i++:
            if i != 0:
                result.append(' ')
            arg = command.ptr[i]

            # The string below is ASCII characters that are safe to include in
            # commands without quoting, in ASCII order (doesn't really matter).
            #
            # I was unsure about '%' and '^' so I left them out.
            if *arg != '\0' and strspn(arg, "+,-./0123456789:=@ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz") == strlen(arg):
                result.extend_from_ptr(arg, strlen(arg))
            else:
                result.append('\'')
                for ; *arg != '\0'; arg++:
                    if *arg == '\'':
                        result.append('\'')  # End single quotes
                        result.append('"')  # Begin double quotes
                        result.append('\'')  # Put the single quote inside the double quotes
                        result.append('"')  # End double quotes
                        result.append('\'')  # Begin single quotes
                    else:
                        result.append(*arg)
                result.append('\'')

        result.append('\0')
        return result.ptr


def configure_skip(test: Test*, filters: List[byte*]) -> None:
    assert test.skip == SkipMode.DontSkip

    if filters.len > 0:
        matches_some_filter = False
        for f = filters.ptr; f < filters.end(); f++:
            if strstr(test.path, *f) != NULL:
                matches_some_filter = True
                break
        if not matches_some_filter:
            test.skip = SkipMode.SkipSilently
            return

    test.skip = test.config.skip_mode
    if (
        *test.expected_output == '\0'
        and (test.config.skip_mode_if_no_expected_output as int) > (test.skip as int)
    ):
        test.skip = test.config.skip_mode_if_no_expected_output


declare dirname(path: byte*) -> byte*

def configure_working_directory(test: Test*) -> None:
    assert test.working_directory == NULL
    if test.config.cd_to_containing_directory:
        temp = strdup(test.path)
        assert temp != NULL
        test.working_directory = strdup(dirname(temp))  # may modify temp string
        free(temp)


def configure_command(test: Test*) -> None:
    params: byte*[enum_count(FormatParam)]
    memset(params, 0, sizeof(params))
    params[FormatParam.File as int] = test.get_relative_path()

    assert test.config.value_present[TestConfigOption.Command as int]
    assert test.actual_command_list.len == 0
    for arg = test.config.command.ptr; arg < test.config.command.end(); arg++:
        test.actual_command_list.append(format_string(*arg, params))

    assert test.actual_command_string == NULL
    if WINDOWS:
        test.actual_command_string = command_to_string_windows(test.actual_command_list)
    else:
        test.actual_command_string = command_to_string_posix(test.actual_command_list)


def configure_uses_output_capturing(test: Test*) -> None:
    test.uses_output_capturing = (
        test.config.stdout != CaptureMode.DoNotCapture
        or test.config.stderr != CaptureMode.DoNotCapture
    )


@public
def step5_configure_tests(tests: List[Test], args: CommandLineArgs*) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        configure_skip(test, args.filter_strings)
        if test.skip == SkipMode.SkipSilently:
            continue
        configure_working_directory(test)
        configure_command(test)
        configure_uses_output_capturing(test)
