def parse_tests_and_defaults(state: State*, tests_toml: TOML*, defaults_toml: TOML*) -> None:
    # This will be copied to make more tests
    template_test = Test{error_comment_output_format = "compiler error in file \"{file}\", line {line}: {message}"}
    template_test.markdown.languages_to_test_as_jou[0] = "jou"
    template_test.markdown.num_languages_to_test_as_jou = 1

    if defaults_toml != NULL:
        if defaults_toml.type != TOMLType.Table:
            fail_in_toml(defaults_toml.lineno, "'defaults_for_all_tests' must be a table")
        files = toml_get(defaults_toml, "files")
        if files != NULL:
            fail_in_toml(files.lineno, "you cannot specify 'files' inside defaults_for_all_tests")
        apply_settings_to_test(defaults_toml, &template_test)

    if tests_toml == NULL:
        fail("joutest.toml must define an array named 'tests'")
    if tests_toml.type != TOMLType.Array:
        fail_in_toml(tests_toml.lineno, "'tests' must be an array")
    if tests_toml.array.len == 0:
        fail_in_toml(tests_toml.lineno, "the 'tests' array cannot be empty")

    # TODO: This should probably loop backwards. When multiple [[tests]]
    #       sections match the same file, we want to use the last settings
    #       specified for it, and mark only those settings as used. Then we can
    #       show error message about settings that do not apply to any file.
    for p = tests_toml.array.ptr; p < tests_toml.array.end(); p++:
        parse_one_item_of_tests(state, &template_test, p)


def parse_the_whole_toml(state: State*, toml: TOML*) -> None:
    assert toml.type == TOMLType.Table

    parse_tests_and_defaults(state, toml_get(toml, "tests"), toml_get(toml, "defaults_for_all_tests"))

    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "tests" | "defaults_for_all_tests":
                pass  # already handled
            case _:
                error: byte[300]
                snprintf(error, sizeof(error), "unknown setting '%s'", kv.key)
                fail_in_toml(kv.value.lineno, error)


enum Condition:
    FlagO0
    FlagO1
    FlagO2
    FlagO3
    FlagValgrind
    NoExpectedOutput
    Windows
    MacOS
    Is32Bit
    Default

global CONDITION_STRINGS: byte*[enum_count(Condition)] = [
    "-O0",
    "-O1",
    "-O2",
    "-O3",
    "--valgrind",
    "no_expected_output",
    "windows",
    "macos",
    "32bit",
    "default",
]

def condition_is_true(c: Condition) -> bool:
    match c:
        # TODO: Don't hard-code -O1
        # TODO: support --valgrind
        # TODO: actually parse the expected output
        case Condition.FlagO0 | Condition.FlagO2 | Condition.FlagO3 | Condition.FlagValgrind | Condition.NoExpectedOutput:
            return False
        case Condition.FlagO1:
            return True
        case Condition.Windows:
            return WINDOWS
        case Condition.MacOS:
            return MACOS
        case Condition.Is32Bit:
            return IS_32BIT
        case Condition.Default:
            return True

def eliminate_condition_tables(toml: TOML*, depth: int) -> None:
    error: byte[300]

    while True:
        assert toml.depth >= depth  # may become more shallow when doing this
        toml.depth = depth

        match toml.type:
            case TOMLType.Error:
                assert False  # should never happen
            case TOMLType.Table:
                # TODO: This is probably not the best way to detect condition tables.
                #       Or is it? It's simple and easy to document.
                default = toml_get(toml, "default")
                if default == NULL:
                    # Normal table
                    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
                        eliminate_condition_tables(&kv.value, depth + 1)
                    return

                # Condition table, pick the correct value
                chosen: TOMLKeyVal* = NULL
                for kv = toml.table.ptr; kv < toml.table.end(); kv++:
                    cond_index = -1
                    for i = 0; i < enum_count(Condition); i++:
                        if strcmp(CONDITION_STRINGS[i], kv.key) == 0:
                            cond_index = i
                            break
                    if cond_index == -1:
                        snprintf(error, sizeof(error), "unknown condition '%s'", kv.key)
                        fail_in_toml(kv.value.lineno, error)
                    cond = cond_index as Condition
                    if cond != Condition.Default and condition_is_true(cond):
                        if chosen != NULL:
                            snprintf(error, sizeof(error), "conditions '%s' and '%s' are both true", chosen.key, kv.key)
                            fail_in_toml(kv.value.lineno, error)
                        chosen = kv

                if chosen == NULL:
                    new_value = default
                else:
                    new_value = &chosen.value
                assert new_value != NULL

                temp = *new_value
                *new_value = TOML{type = TOMLType.Error}  # avoid freeing the value
                toml.free()
                *toml = temp
                continue  # Repeat in case it's a nested condition table

            case TOMLType.Array:
                for p = toml.array.ptr; p < toml.array.end(); p++:
                    eliminate_condition_tables(p, depth + 1)
                return
            case TOMLType.String | TOMLType.Boolean | TOMLType.Integer | TOMLType.Floating:
                return


global big_file_content_buffer: byte[1_000_000]

@public
def step1_discover_tests(state: State*) -> None:
    error: byte[200]

    f = fopen("joutest.toml", "rb")
    if f == NULL:
        snprintf(error, sizeof(error), "cannot open joutest.toml: %s", strerror(get_errno()))
        fail(error)

    n = fread(big_file_content_buffer, 1, sizeof(big_file_content_buffer), f)
    if ferror(f) != 0:
        snprintf(error, sizeof(error), "reading joutest.toml failed: %s", strerror(get_errno()))
        fail(error)
    fclose(f)

    if n == sizeof(big_file_content_buffer):
        fail("joutest.toml is very large, something is probably wrong with it")

    assert n < sizeof(big_file_content_buffer)
    big_file_content_buffer[n] = '\0'
    if strlen(big_file_content_buffer) != n:
        fail("joutest.toml contains a zero byte")

    toml = parse_toml(big_file_content_buffer)
    if toml.type == TOMLType.Error:
        fail_in_toml(toml.lineno, toml.error_message)

    eliminate_condition_tables(&toml, 0)
    parse_the_whole_toml(state, &toml)
    toml.free()
