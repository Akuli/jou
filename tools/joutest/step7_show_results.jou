import "stdlib/str.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/process.jou"

import "./ansi_colors.jou"
import "./diff.jou"
import "./state.jou"

if WINDOWS:
    declare FormatMessageA(
        dwFlags: uint32,
        lpSource: void*,
        dwMessageId: uint32,
        dwLanguageId: uint32,
        lpBuffer: byte*,
        nSize: uint32,
        Arguments: void*,  # actually va_list*
    ) -> uint32
    const FORMAT_MESSAGE_IGNORE_INSERTS: uint32 = 0x00000200
    const FORMAT_MESSAGE_FROM_SYSTEM: uint32 = 0x00001000
else:
    declare strsignal(sig: int) -> byte*


def show_failures(tests: List[Test]) -> None:
    printf("------- FAILURES -------\n\n")

    for t = tests.ptr; t < tests.end(); t++:
        if t.simple_result != SimpleResult.Failed:
            continue

        printf("%s*** Command: %s ***%s\n", YELLOW, t.actual_command_string, RESET)
        if t.detail_result.start_error != 0:
            printf("Process failed to start: ")
            if WINDOWS:
                message: byte[300] = ""
                FormatMessageA(
                    FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS,
                    NULL, t.detail_result.start_error as uint32, 0, message, sizeof(message) as uint32, NULL,
                )
                puts(message)
            else:
                puts(strerror(t.detail_result.start_error))
        elif t.detail_result.terminating_signal != 0:
            if WINDOWS:
                # This shouldn't be possible. Windows doesn't have signals.
                assert False
            else:
                printf(
                    "Process was killed by signal %d: %s\n",
                    t.detail_result.terminating_signal,
                    strsignal(t.detail_result.terminating_signal),
                )
        else:
            # The process completed, perhaps not successfully but it did something.
            # Output can be wrong, exit code can be wrong, both can be wrong.
            if strcmp(t.expected_output, t.actual_output) != 0:
                print_diff(t.expected_output, t.actual_output)

            if t.detail_result.exit_code != 0:
                # TODO: make the correct exit code configurable
                printf(
                    "Process exited with code %d. The correct exit code would be 0.\n",
                    t.detail_result.exit_code,
                )

        printf("\n")
    printf("\n")


@public
def step7_show_results(tests: List[Test]) -> noreturn:
    printf("\n\n")

    succeeded = 0
    failed = 0
    skipped = 0
    for t = tests.ptr; t < tests.end(); t++:
        match t.simple_result:
            case SimpleResult.Success:
                succeeded++
            case SimpleResult.Failed:
                failed++
            case SimpleResult.Skipped:
                skipped++

    if failed != 0:
        show_failures(tests)

    printf("%s%d succeeded", GREEN, succeeded)
    if failed != 0:
        printf(", %s%d failed", RED, failed)
    if skipped != 0:
        printf(", %s%d skipped", YELLOW, skipped)
    printf("%s\n", RESET)

    if succeeded > 0 and failed == 0:
        exit(0)
    else:
        exit(1)
