import "stdlib/assert.jou"
import "stdlib/math.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/str.jou"
import "stdlib/limits.jou"

import "./ansi_colors.jou"


# Finds pointers into the starts of lines. For example:
#
#   "hello\nworld\ntest"
#    ^      ^      ^
#
#   "hello\nworld\ntest\n"
#    ^      ^      ^
#
#   "hello\n"
#    ^
#
#   "hello"
#    ^
#
# The result is an empty list if the given string is empty.
def string_to_lines(s: byte*) -> List[byte*]:
    result = List[byte*]{}
    while *s != '\0':
        result.append(s)
        while *s != '\n' and *s != '\0':
            s++
        if *s == '\n':
            s++
    return result

# Checks if two strings would be equal if both were truncated after their first '\n' (if any).
#
# Examples:
#   "foo\nbar\n", "foo\n" --> True          (same as: strcmp("foo\n", "foo\n") == 0)
#   "foo\nbar\n", "foo" --> False           (same as: strcmp("foo\n", "foo") == 0)
#   "whatever", "whatever\ntest" --> False  (same as: strcmp("whatever", "whatever\n") == 0)
#   "foo", "foobar" --> False               (same as: strcmp("foo", "foobar") == 0)
#
# Used with pointers to starts of lines within multi-line strings.
def lines_equal(line1: byte*, line2: byte*) -> bool:
    while True:
        if (*line1 == '\n' and *line2 == '\n') or (*line1 == '\0' and *line2 == '\0'):
            return True
        if *line1++ != *line2++:
            return False

# Prints a line of diff. Does not access the line beyond \n (if any).
def print_line(color: byte*, prefix: byte, line: byte*) -> None:
    line_len = strcspn(line, "\n")
    assert line_len <= INT32_MAX

    if color == NULL:
        printf("%c%.*s\n", prefix, line_len as int, line)
    else:
        printf("%s%c%.*s%s\n", color, prefix, line_len as int, line, RESET)

    assert line[line_len] == '\0' or line[line_len] == '\n'
    if line[line_len] == '\0':
        printf("\\ No newline at end of file\n")


# This class handles showing context around the diff. You call it when a line
# was added/removed/unchanged, and it prints the added and removed lines with
# a few lines of context around them.
class DiffPrinter:
    context_buf: byte*[3]

    # Values are between 0 and array_count(context_buf) inclusive. For example:
    #   0   Unchanged lines will be buffered. They may be printed later.
    #   1   The next unchanged line will be printed directly. If more, they get buffered.
    #   2   Two unchanged lines will be printed directly. If more, they get buffered.
    context_to_print_before_buffering: int

    # How many lines were not printed because they did not fit in the context buffer?
    skip_count: int

    # This is used to ensure you never get "@@ 1 line not shown @@"
    last_discarded_line: byte*

    def print_skip(self) -> None:
        match self.skip_count:
            case 0:
                pass
            case 1:
                # Do not print "@@ 1 line not shown @@". That looks dumb and
                # makes the user wonder why we aren't just printing the line.
                # So let's just print the line.
                assert self.last_discarded_line != NULL
                print_line(NULL, ' ', self.last_discarded_line)
            case _:
                printf("%s@@ %d lines not shown @@%s\n", CYAN, self.skip_count, RESET)
        self.skip_count = 0

    def print_context_from_buffer(self) -> None:
        for i = 0; i < array_count(self.context_buf); i++:
            line = self.context_buf[i]
            if line != NULL:
                print_line(NULL, ' ', line)

        memset(self.context_buf, 0, sizeof(self.context_buf))
        self.context_to_print_before_buffering = array_count(self.context_buf)

    def unchanged(self, line: byte*) -> None:
        if self.context_to_print_before_buffering > 0:
            # We recently showed an addition or removal. This is part of the
            # context for that and printed immediately.
            print_line(NULL, ' ', line)
            self.context_to_print_before_buffering--
        else:
            # It's been a while since an addition or removal was shown. We may
            # need to show this line for context later, but not right now.
            if self.context_buf[0] != NULL:
                self.last_discarded_line = self.context_buf[0]
                self.skip_count++
            memmove(
                &self.context_buf[0],
                &self.context_buf[1],
                sizeof(self.context_buf[0]) * (array_count(self.context_buf) - 1),
            )
            array_end(self.context_buf)[-1] = line

    def addition(self, line: byte*) -> None:
        self.print_skip()
        self.print_context_from_buffer()
        print_line(GREEN, '+', line)

    def removal(self, line: byte*) -> None:
        self.print_skip()
        self.print_context_from_buffer()
        print_line(RED, '-', line)

    def finish(self) -> None:
        for i = 0; i < array_count(self.context_buf); i++:
            if self.context_buf[i] != NULL:
                self.skip_count++
        self.print_skip()


@public
def print_diff(old_string: byte*, new_string: byte*) -> None:
    # See diff_visualizer.py to understand the diff algorithm used here.

    a = string_to_lines(old_string)
    b = string_to_lines(new_string)

    k_to_x_memory: int* = malloc(sizeof(k_to_x_memory[0]) * (2*(a.len + b.len) + 1))
    assert k_to_x_memory != NULL
    k_to_x = &k_to_x_memory[a.len + b.len]  # Allow negative indexing

    arrows = List[int[4]]{}  # each arrow is [start_x, start_y, end_x, end_y]
    next_k_min = 0
    next_k_max = 0

    for D = 0; ; D++:
        assert D <= a.len + b.len

        # Limit inner loop iterations to make this O(N) instead of O(N^2) when
        # one file has N lines and the other file is short.
        k_min = next_k_min
        k_max = next_k_max
        next_k_min = INT32_MAX
        next_k_max = INT32_MIN

        for k = k_min; k <= k_max; k += 2:
            if D == 0:
                # No arrows yet
                x = 0
                y = 0
            elif k == -D or (k != D and k_to_x[k-1] < k_to_x[k+1]):
                # Arrow down (x doesn't change, y increases, k=x-y decreases)
                # This is an addition because it consumes b without consuming a.
                x = k_to_x[k+1]
                y = x-k
                arrows.append([x, y-1, x, y])
            else:
                # Arrow right (x increases, y doesn't change, k=x-y increases)
                # This is a removal because it consumes a without consuming b.
                x = k_to_x[k-1] + 1
                y = x-k
                arrows.append([x-1, y, x, y])

            if x <= a.len and y <= b.len:
                # This arrow is actually useful, not just running beyond the grid.
                # On the next iteration we will check the diagonals surrounding it.
                next_k_min = min(next_k_min, k-1)
                next_k_max = max(next_k_max, k+1)

            while x < a.len and y < b.len and lines_equal(a.ptr[x], b.ptr[y]):
                # Diagonal arrow (x increases, y increases, k=x-y doesn't change)
                # These are unchanged lines because they consume both strings.
                x++
                y++
                arrows.append([x-1, y-1, x, y])

            k_to_x[k] = x
            if x == a.len and y == b.len:
                # Reached end, backtrack to find the diff
                for i = arrows.len - 1; i >= 0; i--:
                    if arrows.ptr[i][2] == x and arrows.ptr[i][3] == y:
                        # Follow the arrow backwards
                        x = arrows.ptr[i][0]
                        y = arrows.ptr[i][1]
                        assert x >= 0
                        assert y >= 0
                    else:
                        # Mark this arrow as not needed
                        arrows.ptr[i] = [-1, -1, -1, -1]

                assert x == 0
                assert y == 0

                printer = DiffPrinter{}
                for i = 0; i < arrows.len; i++:
                    if arrows.ptr[i][0] != -1:
                        x1 = arrows.ptr[i][0]
                        y1 = arrows.ptr[i][1]
                        x2 = arrows.ptr[i][2]
                        y2 = arrows.ptr[i][3]
                        if x1 == x2:
                            # Arrow down. This is an addition because it consumes b without consuming a.
                            assert 0 <= y1 and y1 < b.len
                            printer.addition(b.ptr[y1])
                        elif y1 == y2:
                            # Arrow right. This is a removal because it consumes a without consuming b.
                            assert 0 <= x1 and x1 < a.len
                            printer.removal(a.ptr[x1])
                        else:
                            assert 0 <= x1 and x1 < a.len
                            assert 0 <= y1 and y1 < b.len
                            assert lines_equal(a.ptr[x1], b.ptr[y1])
                            printer.unchanged(a.ptr[x1])
                printer.finish()

                free(k_to_x_memory)
                free(arrows.ptr)
                free(a.ptr)
                free(b.ptr)
                return
