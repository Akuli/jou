import "./ansi_colors.jou"


def print_line(prefix: byte, line: byte*) -> None:
    match prefix:
        case '+':
            printf("%s+%s%s", GREEN, line, RESET)
        case '-':
            printf("%s-%s%s", RED, line, RESET)
        case ' ':
            printf(" %s", line)
        case _:
            assert False

    if not ends_with(line, "\n"):
        printf("\n\\ No newline at end of file\n")


# This class handles showing context around the diff. You call it when a line
# was added/removed/unchanged, and it prints the added and removed lines with
# a few lines of context around them.
class DiffPrinter:
    context_buf: byte*[3]

    # Values are between 0 and array_count(context_buf) inclusive. For example:
    #   0   Unchanged lines will be buffered. They may be printed later.
    #   1   The next unchanged line will be printed directly. If more, they get buffered.
    #   2   Two unchanged lines will be printed directly. If more, they get buffered.
    context_to_print_before_buffering: int

    # How many lines were not printed because they did not fit in the context buffer?
    skip_count: int

    # This is used to ensure you never get "@@ 1 line not shown @@"
    last_discarded_line: byte*

    def print_skip(self) -> None:
        match self.skip_count:
            case 0:
                pass
            case 1:
                # Do not print "@@ 1 line not shown @@". That looks dumb and
                # makes the user wonder why we aren't just printing the line.
                # So let's just print the line.
                assert self.last_discarded_line != NULL
                print_line(' ', self.last_discarded_line)
            case _:
                printf("%s@@ %d lines not shown @@%s\n", CYAN, self.skip_count, RESET)
        self.skip_count = 0

    def print_context_from_buffer(self) -> None:
        for i = 0; i < array_count(self.context_buf); i++:
            line = self.context_buf[i]
            if line != NULL:
                print_line(' ', line)

        memset(self.context_buf, 0, sizeof(self.context_buf))
        self.context_to_print_before_buffering = array_count(self.context_buf)

    def unchanged(self, line: byte*) -> None:
        if self.context_to_print_before_buffering > 0:
            # We recently showed an addition or removal. This is part of the
            # context for that and printed immediately.
            print_line(' ', line)
            self.context_to_print_before_buffering--
        else:
            # It's been a while since an addition or removal was shown. We may
            # need to show this line for context later, but not right now.
            if self.context_buf[0] != NULL:
                self.last_discarded_line = self.context_buf[0]
                self.skip_count++
            memmove(
                &self.context_buf[0],
                &self.context_buf[1],
                sizeof(self.context_buf[0]) * (array_count(self.context_buf) - 1),
            )
            array_end(self.context_buf)[-1] = line

    def addition(self, line: byte*) -> None:
        self.print_skip()
        self.print_context_from_buffer()
        print_line('+', line)

    def removal(self, line: byte*) -> None:
        self.print_skip()
        self.print_context_from_buffer()
        print_line('-', line)

    def finish(self) -> None:
        for i = 0; i < array_count(self.context_buf); i++:
            if self.context_buf[i] != NULL:
                self.skip_count++
        self.print_skip()


class DiffPair:
    prefix: byte
    line: byte*

def string_to_lines(s: byte*) -> List[byte*]:
    result = List[byte*]{}
    while *s != '\0':
        line_len = strcspn(s, "\n")
        if s[line_len] == '\n':
            line_len++
        line: byte* = NULL
        asprintf(&line, "%*s", line_len as int, s)
        assert line != NULL
        result.append(line)
        s = &s[line_len]
    return result

# Line arrays must be NULL terminated.
# Lines must contain newline characters.
# Lines are C/Jou strings, so they cannot contain zero bytes.
@public
def print_diff(old_string: byte*, new_string: byte*) -> None:
    # See myers_visualizer.py to understand the diff algorithm used here.

    a = string_to_lines(old_string)
    b = string_to_lines(new_string)
    MAX = a.len + b.len

    k_to_x_memory: int* = malloc(sizeof(k_to_x_memory[0]) * (2*MAX + 1))
    assert k_to_x_memory != NULL
    k_to_x = &k_to_x_memory[MAX]  # Allow negative indexing

    arrows = List[int[3]]{}
    next_k_min = 0
    next_k_max = 0

    for D = 0; D <= a.len + b.len; D++:
        # Limit inner loop iterations to make this O(N) instead of O(N^2) when
        # one file has N lines and the other file is short.
        k_min = next_k_min
        k_max = next_k_max
        next_k_min = INT32_MAX
        next_k_max = INT32_MIN
        for k = k_min; k <= k_max; k += 2:
            if D == 0:
                # No arrows yet
                x = 0
                y = 0
            elif k == -D or (k != D and k_to_x[k-1] < k_to_x[k+1]):
                # Arrow down (x doesn't change, y increases, k=x-y decreases)
                # This is an addition because it consumes b without consuming a.
                x = k_to_x[k+1]
                y = x-k
                arrows.append([x, y, '+'])
            else:
                # Arrow right (x increases, y doesn't change, k=x-y increases)
                # This is a removal because it consumes a without consuming b.
                x = k_to_x[k-1] + 1
                y = x-k
                arrows.append([x, y, '-'])

        if x <= a.len and y <= b.len:
            # This k value is actually useful, not just running off the grid.
            next_k_min = min(next_k_min, k-1)
            next_k_max = max(next_k_max, k+1)

        while x < a.len and y < b.len and strcmp(a.ptr[x], b.ptr[y]) == 0:
            # Diagonal arrow (x increases, y increases, k=x-y doesn't change)
            # These are unchanged lines because they consume both strings.
            arrows.append([++x, ++y, ' '])

        k_to_x[k] = x
        if x == a.len and y == b.len:
            # Reached end, backtrack to find the diff
            reversed_diff = List[DiffPair]{}
            while x != 0 or y != 0:
                while True:
                    arrow: int[3] = arrows.pop()
                    if arrow[0] == x and arrow[1] == y:
                        break
                match arrow[2]:
                    case '+':
                        reversed_diff.append(DiffPair{prefix = '+', line = b.ptr[--y]})
                    case '-':
                        reversed_diff.append(DiffPair{prefix = '-', line = a.ptr[--x]})
                    case ' ':
                        x--
                        y--
                        assert strcmp(a.ptr[x], b.ptr[y]) == 0
                        reversed_diff.append(DiffPair{prefix = ' ', line = a.ptr[x]})
                    case _:
                        assert False
            return

    # Should never fall off the loop
    assert False


def join(lines: byte**) -> byte*:
    result = List[byte]{}
    while *lines != NULL:
        result.extend_from_ptr(*lines, strlen(*lines))
        lines++
    result.append('\0')
    return result.ptr


# AI generated function
def test_diffprinter_corner_cases() -> None:
    printer = DiffPrinter{}

    # --- 1. A few unchanged lines (within context) ---
    printer.unchanged("A1\n")
    printer.unchanged("A2\n")

    # --- 2. Overflow unchanged lines (forces buffering + skipping) ---
    printer.unchanged("A3\n")
    printer.unchanged("A4\n")  # should enter buffer
    printer.unchanged("A5\n")  # buffer rotates, skip_count increments

    # --- 3. An addition after buffered context + skip ---
    printer.addition("NEW1\n")

    # --- 4. More unchanged lines
    printer.unchanged("B1\n")
    printer.unchanged("B2\n")
    printer.unchanged("B3\n")
    printer.unchanged("B4\n")
    printer.unchanged("B5\n")
    printer.unchanged("B6\n")
    printer.unchanged("B7\n")   # should overflow buffer again

    # --- 5. A removal after buffered context + skip ---
    printer.removal("OLD1\n")

    # --- 6. Alternating add/remove sequences ---
    printer.addition("NEW2\n")
    printer.removal("OLD2\n")
    printer.addition("NEW3\n")
    printer.removal("OLD3\n")

    # --- 7. Long unchanged tail to test final skip printing ---
    printer.unchanged("C1\n")
    printer.unchanged("C2\n")
    printer.unchanged("C3\n")

    # --- 8. Finish (should flush remaining skip or buffer) ---
    printer.finish()


