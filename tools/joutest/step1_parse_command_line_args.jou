import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/process.jou"
import "stdlib/str.jou"

import "./ansi_colors.jou"
import "./state.jou"


def print_help(argv0: byte*) -> None:
    printf("Usage: %s [--verbose] [--no-colors] [FILTER FILTER2 FILTER3 ...]\n", argv0)
    printf("\n")
    printf("Options:\n")
    printf("  -v / --verbose    show more output than by default\n")
    printf("  --no-colors       do not print with colors\n")
    printf("\n")
    printf("If FILTER arguments are given, only run the tests whose path contains one or\n")
    printf("more FILTERs as a substring.\n")


@public
def step1_parse_command_line_args(argc: int, argv: byte**) -> CommandLineArgs:
    # Set default optimize to O1, user sets optimize will overwrite the default flag
    args = CommandLineArgs{}

    if argc == 2 and strcmp(argv[1], "--help") == 0:
        print_help(argv[0])
        exit(0)

    optlevel_set = False
    i = 1
    while i < argc:
        match argv[i] with strcmp:
            case "--help":
                print_help(argv[0])
                exit(0)

            case "-v" | "--verbose":
                args.verbose = True
                i++

            case "--no-colors":
                disable_colors()
                i++

            case _:
                if argv[i][0] == '-':
                    fprintf(get_stderr(), "%s: unknown argument \"%s\" (try \"%s --help\")\n", argv[0], argv[i], argv[0])
                    exit(2)
                args.filter_strings.append(argv[i++])

    return args
