# This file is currently not used.

import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./glob.jou"
import "./state.jou"
import "./string_formatter.jou"


class Step1State:
    tests: List[Test]
    template_test: Test


def bool_from_toml_keyval(kv: TOMLKeyVal*) -> bool:
    if toml_is_true(&kv.value):
        return True
    if toml_is_false(&kv.value):
        return False
    error: byte[200]
    snprintf(error, sizeof(error), "'%s' must be a boolean", kv.key)
    fail_in_toml(kv.value.lineno, error)


def enum_from_toml_keyval(kv: TOMLKeyVal*, strings: byte**, nstrings: int) -> int:
    s = toml_to_string(&kv.value)
    if s != NULL:
        for i = 0; i < nstrings; i++:
            if strcmp(s, strings[i]) == 0:
                return i

    surely_big_enough = strlen(kv.key) + 10*nstrings + 123
    for i = 0; i < nstrings; i++:
        surely_big_enough += strlen(strings[i])

    error: byte* = malloc(surely_big_enough)
    assert error != NULL

    sprintf(error, "'%s' must be ", kv.key)
    for i = 0; i < nstrings; i++:
        if i == nstrings - 1:
            strcat(error, " or ")
        elif i != 0:
            strcat(error, ", ")
        strcat(error, "\"")
        strcat(error, strings[i])
        strcat(error, "\"")

    fail_in_toml(kv.value.lineno, error)


def is_array_of_strings(toml: TOML*) -> bool:
    if toml == NULL or toml.type != TOMLType.Array:
        return False
    for p = toml.array.ptr; p < toml.array.end(); p++:
        if toml_to_string(p) == NULL:
            return False
    return True


def apply_markdown_settings_to_test(toml: TOML*, test: Test*) -> None:
    return  # TODO: this function is just bad, it should create some temporary structure for parsing the markdown

    if toml.type != TOMLType.Table:
        fail_in_toml(toml.lineno, "'markdown' must be a table")

    md = &test.markdown

    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "languages_to_test_as_jou":
                if not is_array_of_strings(&kv.value):
                    fail_in_toml(kv.value.lineno, "'markdown.languages_to_test_as_jou' must be an array of strings")
                if kv.value.array.len > array_count(md.languages_to_test_as_jou):
                    fail_in_toml(kv.value.lineno, "'markdown.languages_to_test_as_jou' is set to an array that is too long")
                md.num_languages_to_test_as_jou = 0
                for p = kv.value.array.ptr; p < kv.value.array.end(); p++:
                    snprintf(
                        md.languages_to_test_as_jou[md.num_languages_to_test_as_jou++],
                        sizeof(md.languages_to_test_as_jou[0]),
                        "%s",
                        toml_to_string(p),
                    )
            case _:
                error: byte[200]
                snprintf(error, sizeof(error), "unknown setting 'markdown.%s' for a test", kv.key)
                fail_in_toml(kv.value.lineno, error)


def apply_settings_to_test(toml: TOML*, test: Test*) -> None:
    assert toml != NULL
    assert toml.type == TOMLType.Table
    assert test != NULL

    error: byte[200]

    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "files":
                # already handled when creating the tests, we are handling one of them
                pass
            case "skip":
                if toml_is_false(&kv.value):
                    test.skip = Skip.DontSkip
                elif toml_is_true(&kv.value):
                    test.skip = Skip.SkipNormally
                elif toml_to_string(&kv.value) != NULL and strcmp(toml_to_string(&kv.value), "silent") == 0:
                    test.skip = Skip.SkipSilently
                else:
                    fail_in_toml(kv.value.lineno, "'skip' must be false, true or \"silent\"")
            case "cd_to_containing_directory":
                test.cd_to_containing_directory = bool_from_toml_keyval(kv)
            case "run_compiler_under_valgrind":
                # TODO: bake this directly into the command somehow? or not?
                # Easy enough to prepend it whenever really...
                test.run_compiler_under_valgrind = bool_from_toml_keyval(kv)
            case "markdown":
                apply_markdown_settings_to_test(&kv.value, test)
            case "expected_exit_code":
                test.expected_exit_code = toml_to_int(&kv.value, -1)
                # TODO: more validation? exit code 12345 does not get passed through as is on most systems
                if test.expected_exit_code < 0:
                    fail_in_toml(kv.value.lineno, "'expected_exit_code' must be a nonnegative integer")
            case "stdout":
                test.stdout = enum_from_toml_keyval(kv, STD_OUT_ERR_NAMES, enum_count(StdOutErr)) as StdOutErr
            case "stderr":
                test.stderr = enum_from_toml_keyval(kv, STD_OUT_ERR_NAMES, enum_count(StdOutErr)) as StdOutErr
            case "error_comment_output_format":
                s = toml_to_string(&kv.value)
                if s == NULL:
                    fail_in_toml(toml.lineno, "'error_comment_output_format' must be a string")
                if s[0] == '\0':
                    fail_in_toml(toml.lineno, "'error_comment_output_format' cannot be empty string")
                if strlen(s) >= sizeof(test.error_comment_output_format):
                    fail_in_toml(toml.lineno, "'error_comment_output_format' is too long")
                strcpy(test.error_comment_output_format, s)
                # Format with dummy data to fail early if it doesn't work
                free(string_format(s, StringFormatParams{file="",line="",message=""}, toml.lineno))
            case "command":
                if not is_array_of_strings(&kv.value):
                    fail_in_toml(toml.lineno, "'command' must be an array of strings")
                if kv.value.array.len == 0:
                    fail_in_toml(toml.lineno, "'command' cannot be empty")
                test.command.len = 0
                for p = kv.value.array.ptr; p < kv.value.array.end(); p++:
                    s = strdup(toml_to_string(p))
                    assert s != NULL
                    # Format with dummy data to fail early if it doesn't work
                    free(string_format(s, StringFormatParams{file=""}, p.lineno))
                    test.command.append(s)
            case _:
                snprintf(error, sizeof(error), "unknown setting '%s' for a test", kv.key)
                fail_in_toml(kv.value.lineno, error)


def add_or_update_tests_of_file(state: Step1State*, toml: TOML*, path: byte*, path_lineno: int) -> None:
    assert state != NULL
    assert toml != NULL
    assert path != NULL

    num_tests_found = 0
    for test = state.tests.ptr; test < state.tests.end(); test++:
        if strcmp(test.path, path) == 0:
            apply_settings_to_test(toml, test)
            num_tests_found++
            break

    # Currently it is not possible to have multiple tests coming from the same file.
    # This will change in the future when we find tests from markdown.
    assert num_tests_found <= 1

    if num_tests_found == 0:
        # Add new test for the file
        # TODO: .md should actually create many tests!!!!
        t = state.template_test

        assert t.path == NULL
        t.path = strdup(path)
        assert t.path != NULL

        t.toml_lineno = path_lineno

        apply_settings_to_test(toml, &t)
        state.tests.append(t)


def add_or_update_tests_of_glob(state: Step1State*, settings_toml: TOML*, glob_toml: TOML*) -> None:
    glob = toml_to_string(glob_toml)
    if glob == NULL:
        fail_in_toml(glob_toml.lineno, "'files' must be a path, a glob pattern such as \"tests/*.jou\", or an array of paths and/or glob patterns")

    error: byte[200]

    if not glob_is_valid(glob):
        snprintf(error, sizeof(error), "invalid path or glob pattern: %s", glob)
        fail_in_toml(glob_toml.lineno, error)

    paths = List[byte*]{}
    # TODO: don't hard-code the glob depth limit
    do_glob(glob, ".", &paths, 10)
    if paths.len == 0:
        if strstr(glob, "*") == NULL:
            # not really a glob
            snprintf(error, sizeof(error), "file not found: %s", glob)
        else:
            snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
        fail_in_toml(glob_toml.lineno, error)

    # TODO: normalize . and .. components?
    # TODO: normalize case on windows?

    for p = paths.ptr; p < paths.end(); p++:
        add_or_update_tests_of_file(state, settings_toml, *p, glob_toml.lineno)
        free(*p)
    free(paths.ptr)


def parse_one_item_of_tests(state: Step1State*, toml: TOML*) -> None:
    assert toml != NULL
    if toml.type != TOMLType.Table:
        fail_in_toml(toml.lineno, "each item of 'tests' must be a table")

    toml_files = toml_get(toml, "files")
    if toml_files == NULL:
        fail_in_toml(toml.lineno, "each 'tests' table must contain 'files'")

    # files can be a string or an array of strings
    if toml_files.type == TOMLType.Array:
        for item = toml_files.array.ptr; item < toml_files.array.end(); item++:
            add_or_update_tests_of_glob(state, toml, item)
    else:
        add_or_update_tests_of_glob(state, toml, toml_files)


def finish_parsing_command(test: Test*) -> None:
    assert test.command.len == 0
    # Really slow loop, please clean up if this is too slow
    filename = test.path
    while strstr(filename, "/") != NULL or (WINDOWS and strstr(filename, "\\") != NULL):
        filename++

    if test.cd_to_containing_directory:
        fmt_params = StringFormatParams{file = filename}
    else:
        fmt_params = StringFormatParams{file = test.path}

    if test.toml_command != NULL:
        # Get command from TOML
        for p = test.toml_command.array.ptr; p < test.toml_command.array.end(); p++:
            test.command.append(string_format(toml_to_string(p), fmt_params, p.lineno))
    elif ends_with(test.path, ".jou") or ends_with(test.path, ".md"):
        # Use a reasonable default: ["jou", "{file}"]
        test.command.append(strdup("jou"))
        test.command.append(strdup(fmt_params.file))
    else:
        error: byte[300]
        snprintf(error, sizeof(error), "don't know which command to use for testing file '%s', please set 'command' accordingly", filename)
        fail_in_toml(test.toml_lineno, error)


def parse_tests_and_defaults(state: Step1State*, tests_toml: TOML*, defaults_toml: TOML*) -> None:
    # This will be copied to make more tests
    state.template_test = Test{error_comment_output_format = "compiler error in file \"{file}\", line {line}: {message}"}
    state.template_test.markdown.languages_to_test_as_jou[0] = "jou"
    state.template_test.markdown.num_languages_to_test_as_jou = 1

    if defaults_toml != NULL:
        if defaults_toml.type != TOMLType.Table:
            fail_in_toml(defaults_toml.lineno, "'defaults_for_all_tests' must be a table")
        files = toml_get(defaults_toml, "files")
        if files != NULL:
            fail_in_toml(files.lineno, "you cannot specify 'files' inside defaults_for_all_tests")
        apply_settings_to_test(defaults_toml, &state.template_test)

    if tests_toml == NULL:
        fail("joutest.toml must define an array named 'tests'")
    if tests_toml.type != TOMLType.Array:
        fail_in_toml(tests_toml.lineno, "'tests' must be an array")
    if tests_toml.array.len == 0:
        fail_in_toml(tests_toml.lineno, "the 'tests' array cannot be empty")

    # TODO: This should probably loop backwards. When multiple [[tests]]
    #       sections match the same file, we want to use the last settings
    #       specified for it, and mark only those settings as used. Then we can
    #       show error message about settings that do not apply to any file.
    for p = tests_toml.array.ptr; p < tests_toml.array.end(); p++:
        parse_one_item_of_tests(state, p)


def parse_the_whole_toml(toml: TOML*) -> List[Test]:
    assert toml.type == TOMLType.Table
    state = Step1State{}
    parse_tests_and_defaults(&state, toml_get(toml, "tests"), toml_get(toml, "defaults_for_all_tests"))

    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "tests" | "defaults_for_all_tests":
                pass  # already handled
            case _:
                error: byte[300]
                snprintf(error, sizeof(error), "unknown setting '%s'", kv.key)
                fail_in_toml(kv.value.lineno, error)

    return state.tests
