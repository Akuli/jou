import "stdlib/assert.jou"
import "stdlib/io.jou"
import "stdlib/process.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"
import "stdlib/errno.jou"

global big_temp_buffer: byte[1_000_000]


def fail(message: byte*) -> None:
    fprintf(get_stderr(), "joutest error: %s\n", message)
    exit(1)


#enum Mode:
#    Run

#global MODE_STRINGS: byte*[enum_count(Mode)] = ["run"]


def read_joutest_toml() -> None:
    error: byte[200]

    f = fopen("joutest.toml", "rb")
    if f == NULL:
        snprintf(error, sizeof(error), "cannot open joutest.toml: %s", strerror(get_errno()))
        fail(error)

    n = fread(big_temp_buffer, 1, sizeof(big_temp_buffer), f)
    if ferror(f) != 0:
        snprintf(error, sizeof(error), "reading joutest.toml failed: %s", strerror(get_errno()))
        fail(error)
    fclose(f)

    if n == sizeof(big_temp_buffer):
        fail("joutest.toml is very large, something is probably wrong with it")

    assert n < sizeof(big_temp_buffer)
    big_temp_buffer[n] = '\0'
    if strlen(big_temp_buffer) != n:
        fail("joutest.toml contains a zero byte")

    toml = parse_toml(big_temp_buffer)
    if toml.type == TOMLType.Error:
        snprintf(error, sizeof(error), "file \"joutest.toml\", line %d: %s", toml.lineno, toml.error_message)
        fail(error)

    toml.print()
    toml.free()


def main() -> int:
    read_joutest_toml()
    return 0
