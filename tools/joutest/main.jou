    step5_do_something_new(tests)
import "./step5_do_something_new.jou"
import "./step6_gather_expected_outputs.jou"
import "./step7_run_tests.jou"
import "./step8_show_results.jou"


def main(argc: int, argv: byte**) -> int:
    args = step1_parse_command_line_args(argc, argv)
    toml = step2_parse_joutest_toml()
    tests = step3_discover_tests(&toml)
    step4_configure_tests(tests, &args)
    step6_gather_expected_outputs(tests)
    step7_run_tests(tests, &args)
    step8_show_results(tests)
