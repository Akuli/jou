import "./step2_discover_tests.jou"
import "./step5_run_tests.jou"
import "./step6_show_results.jou"


def main() -> int:
    toml = step1_parse_joutest_toml()
    tests = step2_discover_tests(&toml)
    #step3_configure_tests(tests)  # TODO
    #step4_gather_expected_outputs(tests)  # TODO
