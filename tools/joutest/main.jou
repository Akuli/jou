import "./step1_parse_command_line_args.jou"
import "./step2_parse_joutest_toml.jou"
import "./step3_discover_tests.jou"
import "./step4_configure_tests.jou"
import "./step5_filter_tests.jou"
import "./step6_gather_expected_outputs.jou"
import "./step7_run_tests.jou"
import "./step8_show_results.jou"


def main(argc: int, argv: byte**) -> int:
    args = step1_parse_command_line_args(argc, argv)
    test_configs = step2_parse_joutest_toml()
    tests = step3_discover_tests(test_configs)
    step4_configure_tests(tests, &args)
    step5_filter_tests(&tests, &args)  # After configuring, so we check all tests for bad configuration
    step6_gather_expected_outputs(tests)
    step7_run_tests(tests, &args)
    step8_show_results(tests, &args)
