# This file parses joutest.toml

import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/process.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./state.jou"
import "./glob.jou"


def fail_in_toml(toml: TOML*, message: byte*) -> noreturn:
    assert toml != NULL
    full_message: byte[200]
    snprintf(full_message, sizeof(full_message), "file \"joutest.toml\", line %d: %s", toml.lineno, message)
    fail(full_message)


def glob_from_toml(toml: TOML*) -> List[byte*]:
    assert toml != NULL

    if toml.type != TOMLType.String:
        fail_in_toml(toml, "'glob' must be a string")

    glob = toml_to_string(toml)
    if not glob_is_valid(glob):
        fail_in_toml(toml, "invalid or unsupported glob pattern")

    result = List[byte*]{}
    # TODO: don't hard-code the glob depth limit
    do_glob(glob, ".", &result, 10)
    if result.len == 0:
        error: byte[200]
        snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
        fail_in_toml(toml, error)

    # TODO: normalize . and .. components?
    # TODO: normalize case on windows?

    return result


def mode_from_toml(files_toml: TOML*) -> Mode:
    toml = toml_get(files_toml, "mode")
    if toml == NULL:
        return Mode.Unset

    mode_string = toml_to_string(toml)
    message: byte[200] = "mode must be one of the following strings: "

    for m = 0; m < enum_count(Mode); m++:
        if (m as Mode) != Mode.Unset:
            if mode_string != NULL and strcmp(mode_string, MODE_STRINGS[m]) == 0:
                return m as Mode
            message2: byte[200]
            snprintf(
                message2,
                sizeof(message2),
                "%s%s\"%s\"",
                message,
                ", " if ends_with(message, "\"") else "",
                MODE_STRINGS[m],
            )
            message = message2

    fail_in_toml(toml, message)


def parse_one_files_config(state: State*, toml: TOML*) -> None:
    assert toml != NULL
    if toml.type != TOMLType.Table:
        fail_in_toml(toml, "each item of 'files' must be a table")

    toml_glob = toml_get(toml, "glob")
    if toml_glob == NULL:
        fail_in_toml(toml, "each 'files' table must contain 'glob'")
    glob_paths = glob_from_toml(toml_glob)

    for p = glob_paths.ptr; p < glob_paths.end(); p++:
        # This looping could be too slow. Please fix if this causes a problem.
        test_file: TestFile* = NULL
        for tf = state.test_files.ptr; tf < state.test_files.end(); tf++:
            if strcmp(tf.path, *p) == 0:
                test_file = tf
                break

        if test_file == NULL:
            state.test_files.append(TestFile{path = *p, defining_toml_lineno = toml_glob.lineno})
            test_file = &state.test_files.end()[-1]
        else:
            free(*p)

        mode = mode_from_toml(toml)
        if mode != Mode.Unset:
            test_file.mode = mode

    free(glob_paths.ptr)


def parse_all_files_configs(state: State*, toml: TOML*) -> None:
    assert toml != NULL

    toml = toml_get(toml, "files")
    if toml == NULL:
        fail("joutest.toml must define an array named 'files'")
    if toml.type != TOMLType.Array:
        fail_in_toml(toml, "'files' must be an array")
    if toml.array.len == 0:
        fail_in_toml(toml, "the 'files' array cannot be empty")

    # TODO: This should probably loop backwards. When multiple globs match the
    #       same file, we want to use the last settings specified for it, and
    #       mark only those settings as used. Then we can show error message
    #       about settings that do not apply to any file.
    for p = toml.array.ptr; p < toml.array.end(); p++:
        parse_one_files_config(state, p)


global big_file_content_buffer: byte[1_000_000]

@public
def read_joutest_toml(state: State*) -> None:
    error: byte[200]

    f = fopen("joutest.toml", "rb")
    if f == NULL:
        snprintf(error, sizeof(error), "cannot open joutest.toml: %s", strerror(get_errno()))
        fail(error)

    n = fread(big_file_content_buffer, 1, sizeof(big_file_content_buffer), f)
    if ferror(f) != 0:
        snprintf(error, sizeof(error), "reading joutest.toml failed: %s", strerror(get_errno()))
        fail(error)
    fclose(f)

    if n == sizeof(big_file_content_buffer):
        fail("joutest.toml is very large, something is probably wrong with it")

    assert n < sizeof(big_file_content_buffer)
    big_file_content_buffer[n] = '\0'
    if strlen(big_file_content_buffer) != n:
        fail("joutest.toml contains a zero byte")

    toml = parse_toml(big_file_content_buffer)
    if toml.type == TOMLType.Error:
        fail_in_toml(&toml, toml.error_message)

    parse_all_files_configs(state, &toml)
    toml.free()
