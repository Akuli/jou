# This file parses joutest.toml

import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./state.jou"
import "./glob.jou"


def glob_to_paths(glob: byte*, lineno: int) -> List[byte*]:
    error: byte[200]

    if not glob_is_valid(glob):
        snprintf(error, sizeof(error), "invalid path or glob pattern: %s", glob)
        fail_in_toml(lineno, error)

    result = List[byte*]{}
    # TODO: don't hard-code the glob depth limit
    do_glob(glob, ".", &result, 10)
    if result.len == 0:
        if strstr(glob, "*") == NULL:
            # not really a glob
            snprintf(error, sizeof(error), "file not found: %s", glob)
        else:
            snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
        fail_in_toml(lineno, error)

    # TODO: normalize . and .. components?
    # TODO: normalize case on windows?

    return result


def mode_from_toml(files_toml: TOML*) -> Mode:
    toml = toml_get(files_toml, "mode")
    if toml == NULL:
        return Mode.Unset

    mode_string = toml_to_string(toml)
    message: byte[200] = "mode must be one of the following strings: "

    for m = 0; m < enum_count(Mode); m++:
        if (m as Mode) != Mode.Unset:
            if mode_string != NULL and strcmp(mode_string, MODE_STRINGS[m]) == 0:
                return m as Mode
            message2: byte[200]
            snprintf(
                message2,
                sizeof(message2),
                "%s%s\"%s\"",
                message,
                ", " if ends_with(message, "\"") else "",
                MODE_STRINGS[m],
            )
            message = message2

    fail_in_toml(toml.lineno, message)


def parse_test_config(state: State*, toml: TOML*) -> None:
    assert toml != NULL
    if toml.type != TOMLType.Table:
        fail_in_toml(toml.lineno, "each item of 'tests' must be a table")

    toml_files = toml_get(toml, "files")
    if toml_files == NULL:
        fail_in_toml(toml.lineno, "each 'tests' table must contain 'files'")

    mode = mode_from_toml(toml)

    # files can be a string or an array of strings
    if toml_files.type == TOMLType.Array:
        toml_files_ptr = toml_files.array.ptr
        toml_files_end = toml_files.array.end()
    else:
        # Do not look inside it, instead trick the loop below to take it as is just once
        toml_files_ptr = toml_files
        toml_files_end = &toml_files_ptr[1]

    for toml_glob = toml_files_ptr; toml_glob < toml_files_end; toml_glob++:
        glob = toml_to_string(toml_glob)
        if glob == NULL:
            fail_in_toml(toml_glob.lineno, "'files' must be a path, a glob pattern such as \"tests/*.jou\", or an array of paths and/or glob patterns")

        paths = glob_to_paths(glob, toml_glob.lineno)
        for p = paths.ptr; p < paths.end(); p++:
            # This nested looping could be too slow. Please fix if this causes a problem.
            test_file: TestFile* = NULL
            for tf = state.test_files.ptr; tf < state.test_files.end(); tf++:
                if strcmp(tf.path, *p) == 0:
                    test_file = tf
                    free(*p)
                    break
            if test_file == NULL:
                state.test_files.append(TestFile{path = *p, defining_toml_lineno = toml_glob.lineno})
                test_file = &state.test_files.end()[-1]

            # Apply settings to the file
            if mode != Mode.Unset:
                test_file.mode = mode

        free(paths.ptr)


def parse_all_test_configs(state: State*, toml: TOML*) -> None:
    assert toml != NULL

    toml = toml_get(toml, "tests")
    if toml == NULL:
        fail("joutest.toml must define an array named 'tests'")
    if toml.type != TOMLType.Array:
        fail_in_toml(toml.lineno, "'tests' must be an array")
    if toml.array.len == 0:
        fail_in_toml(toml.lineno, "the 'tests' array cannot be empty")

    # TODO: This should probably loop backwards. When multiple globs match the
    #       same file, we want to use the last settings specified for it, and
    #       mark only those settings as used. Then we can show error message
    #       about settings that do not apply to any file.
    for p = toml.array.ptr; p < toml.array.end(); p++:
        parse_test_config(state, p)


global big_file_content_buffer: byte[1_000_000]

@public
def read_joutest_toml(state: State*) -> None:
    error: byte[200]

    f = fopen("joutest.toml", "rb")
    if f == NULL:
        snprintf(error, sizeof(error), "cannot open joutest.toml: %s", strerror(get_errno()))
        fail(error)

    n = fread(big_file_content_buffer, 1, sizeof(big_file_content_buffer), f)
    if ferror(f) != 0:
        snprintf(error, sizeof(error), "reading joutest.toml failed: %s", strerror(get_errno()))
        fail(error)
    fclose(f)

    if n == sizeof(big_file_content_buffer):
        fail("joutest.toml is very large, something is probably wrong with it")

    assert n < sizeof(big_file_content_buffer)
    big_file_content_buffer[n] = '\0'
    if strlen(big_file_content_buffer) != n:
        fail("joutest.toml contains a zero byte")

    toml = parse_toml(big_file_content_buffer)
    if toml.type == TOMLType.Error:
        fail_in_toml(toml.lineno, toml.error_message)

    parse_all_test_configs(state, &toml)
    toml.free()
