import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/sort.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./glob.jou"
import "./state.jou"


class DiscoveryState:
    tests: List[Test]

    # Suppose two different globs apply to the same markdown file.
    #
    # If the markdown file does contains tests, we find them when we glob the
    # markdown file for a second time, so we know that there's no need to look
    # inside the markdown file again.
    #
    # If the markdown file contains nothing we can test, we put it here to
    # ensure we don't search for tests inside it again.
    markdown_files_with_no_tests: List[byte*]

    # The defaults_for_all_tests table
    defaults_toml: TOML*


def add_or_update_tests_of_file(
    state: DiscoveryState*,
    table: TOML*,
    glob_toml: TOML*,
    path_to_be_consumed: byte*,  # will be free()'d either right away or later
) -> None:
    already_exists = False
    for t = state.tests.ptr; t < state.tests.end(); t++:
        if strcmp(t.path, path_to_be_consumed) == 0:
            free(path_to_be_consumed)
            t.relevant_toml_tables.append(table)
            already_exists = True
            break

    if already_exists:
        return

    assert not ends_with(path_to_be_consumed, ".md")  # TODO

    test = Test{path = path_to_be_consumed, glob_toml = glob_toml}
    if state.defaults_toml != NULL:
        test.relevant_toml_tables.append(state.defaults_toml)
    test.relevant_toml_tables.append(table)
    state.tests.append(test)


def add_or_update_tests_of_glob(state: DiscoveryState*, settings_toml: TOML*, glob_toml: TOML*) -> None:
    glob = toml_to_string(glob_toml)
    if glob == NULL:
        fail_in_toml(glob_toml.lineno, "'files' must be a path, a glob pattern such as \"tests/*.jou\", or an array of paths and/or glob patterns")
    if strstr(glob, "\\") != NULL:
        fail_in_toml(glob_toml.lineno, "please use forward slashes instead of backslashes")

    error: byte[200]

    if not glob_is_valid(glob):
        snprintf(error, sizeof(error), "invalid path or glob pattern: %s", glob)
        fail_in_toml(glob_toml.lineno, error)

    paths = List[byte*]{}
    # TODO: don't hard-code the glob depth limit
    do_glob(glob, ".", &paths, 10)
    if paths.len == 0:
        if strstr(glob, "*") == NULL:
            # not really a glob
            snprintf(error, sizeof(error), "file not found: %s", glob)
        else:
            snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
        fail_in_toml(glob_toml.lineno, error)

    # TODO: normalize . and .. components?
    # TODO: normalize case on windows?

    for p = paths.ptr; p < paths.end(); p++:
        add_or_update_tests_of_file(state, settings_toml, glob_toml, *p)
    free(paths.ptr)


def handle_one_item_of_tests(state: DiscoveryState*, toml: TOML*) -> None:
    assert toml != NULL
    if toml.type != TOMLType.Table:
        fail_in_toml(toml.lineno, "each item of 'tests' must be a table")

    toml_files = toml_get(toml, "files")
    if toml_files == NULL:
        fail_in_toml(toml.lineno, "each 'tests' table must contain 'files'")

    # files can be a string or an array of strings
    if toml_files.type == TOMLType.Array:
        for item = toml_files.array.ptr; item < toml_files.array.end(); item++:
            add_or_update_tests_of_glob(state, toml, item)
    else:
        add_or_update_tests_of_glob(state, toml, toml_files)


def compare_tests(t1: Test*, t2: Test*) -> int:
    # TODO: For markdown files, should also compare offsets if paths are equal
    return strcmp(t1.path, t2.path)


@public
def step3_discover_tests(toml: TOML*) -> List[Test]:
    tests_toml: TOML* = NULL
    defaults_toml: TOML* = NULL

    assert toml.type == TOMLType.Table
    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "tests":
                tests_toml = &kv.value
            case "defaults_for_all_tests":
                defaults_toml = &kv.value
            case _:
                error: byte[200]
                snprintf(error, sizeof(error), "unknown setting '%s'", kv.key)
                fail_in_toml(kv.value.lineno, error)

    if tests_toml == NULL:
        fail("joutest.toml must define an array named 'tests'")
    if tests_toml.type != TOMLType.Array:
        fail_in_toml(tests_toml.lineno, "'tests' must be an array")
    if tests_toml.array.len == 0:
        fail_in_toml(tests_toml.lineno, "the 'tests' array cannot be empty")

    if defaults_toml != NULL:
        if defaults_toml.type != TOMLType.Table:
            fail_in_toml(defaults_toml.lineno, "'defaults_for_all_tests' must be a table")
        files = toml_get(defaults_toml, "files")
        if files != NULL:
            fail_in_toml(files.lineno, "you cannot specify 'files' inside defaults_for_all_tests")

    state = DiscoveryState{defaults_toml = defaults_toml}
    for p = tests_toml.array.ptr; p < tests_toml.array.end(); p++:
        handle_one_item_of_tests(&state, p)

    Sorter[Test]{}.sort(state.tests.ptr, state.tests.len, compare_tests)
    return state.tests
