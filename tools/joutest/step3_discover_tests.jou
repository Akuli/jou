def compare_tests(t1: Test*, t2: Test*) -> int:
    result = strcmp(t1.path, t2.path)
    if result == 0:
        # One markdown file can contain multiple tests, sort by line number
        result = t1.first_markdown_lineno - t2.first_markdown_lineno
    return result


class PathAndTestConfig:
    path: byte*
    glob_lineno: int
    config: TestConfig


@public
def step3_discover_tests(configs: List[TestConfig]) -> List[Test]:
    # We can't do this in one pass (that is, loop through just once), because
    # multiple sections of joutest.toml can apply to the same file, and we
    # already need to know the final/merged configuration when extracting tests
    # from markdown files.
    #
    # We first figure out how each file should be configured.
    merged_configs = List[PathAndTestConfig]{}

    for config = configs.ptr; config < configs.end(); config++:
        if not config.value_present[TestConfigOption.Files as int]:
            assert False  # TODO: does this ever run?
            fail_in_toml(config.lineno, "each 'tests' table must contain 'files'")

        for i = 0; i < config.files.len; i++:
            glob = config.files.ptr[i]
            glob_lineno = config.files_linenos.ptr[i]

            glob_result = List[byte*]{}
            do_glob(glob, ".", &glob_result, 10)  # TODO: don't hard-code depth limit?
            if glob_result.len == 0:
                error: byte[500]
                if strstr(glob, "*") == NULL:
                    # not really a glob
                    snprintf(error, sizeof(error), "file not found: %s", glob)
                else:
                    snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
                fail_in_toml(glob_lineno, error)

            for path = glob_result.ptr; path < glob_result.end(); path++:
                merged_config: PathAndTestConfig* = NULL
                for m = merged_configs.ptr; m < merged_configs.end(); m++:
                    if strcmp(m.path, *path) == 0:
                        merged_config = m
                        break
                if merged_config == NULL:
                    merged_configs.append(PathAndTestConfig{path = *path, glob_lineno = glob_lineno})
                    merged_config = &merged_configs.end()[-1]
                config.assign_to(&merged_config.config)

            free(glob_result.ptr)

    # Now create tests from each file
    tests = List[Test]{}
    for merged_config = merged_configs.ptr; merged_config < merged_configs.end(); merged_config++:
        if is_markdown_file(merged_config.path):
            add_tests_from_markdown(&tests, merged_config.path, &merged_config.config, merged_config.glob_lineno)
        else:
            tests.append(Test{path = merged_config.path, config = &merged_config.config})
    Sorter[Test]{}.sort(tests.ptr, tests.len, compare_tests)

    # Can't free merged_configs, tests contain pointers to its configs now
    return tests
