import "stdlib/ascii.jou"
import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/sort.jou"
import "stdlib/str.jou"

import "./fail.jou"
import "./glob.jou"
import "./state.jou"


def list_contains_string(list: List[byte*], string: byte*) -> bool:
    for p = list.ptr; p < list.end(); p++:
        if strcmp(*p, string) == 0:
            return True
    return False


global huge_buffer: byte[1_000_000]  # surely big enough to fit entire lines!

def add_tests_from_markdown(tests: List[Test]*, path: byte*, config: TestConfig*, glob_lineno: int) -> None:
    message: byte[500]

    f = fopen(path, "rb")
    if f == NULL:
        snprintf(message, sizeof(message), "failed to open file '%s': %s", path, strerror(get_errno()))
        fail(message)

    lineno = 0
    code_first_lineno = 0  # 0 if not inside a code block
    code = List[byte]{}

    while fgets(huge_buffer, sizeof(huge_buffer), f) != NULL:
        lineno++

        if starts_with(huge_buffer, "```"):
            lang = &huge_buffer[3]
            trim_ascii_whitespace(lang)

            if *lang != '\0' and list_contains_string(config.markdown_code_block_languages, lang):
                # Start of code block
                code_first_lineno = lineno + 1
                assert code.len == 0
                # If code starts on line 5, add 4 blank lines to beginning so
                # line numbers align correctly.
                for i = 0; i < code_first_lineno - 1; i++:
                    code.append('\n')

            elif *lang == '\0' and code_first_lineno != 0:
                # End of code block
                code.append('\0')
                test = Test{
                    path = strdup(path),
                    config = config,
                    first_markdown_lineno = code_first_lineno,
                    last_markdown_lineno = lineno - 1,
                    stdin_input = strdup(code.ptr),
                }
                assert test.stdin_input != NULL
                tests.append(test)

                code_first_lineno = 0
                code.len = 0

            else:
                # Whatever this is, it cannot occur in the middle of a code block
                code_first_lineno = 0
                code.len = 0

        elif code_first_lineno != 0:
            # Line inside a code block
            code.extend_from_ptr(huge_buffer, strlen(huge_buffer))

    free(code.ptr)

    if ferror(f) != 0:
        snprintf(message, sizeof(message), "failed to read file '%s': %s", path, strerror(get_errno()))
        fail_in_toml(glob_lineno, message)

    fclose(f)


def is_markdown_file(path: byte*) -> bool:
    # This is documented as being case-insensitive
    return (
        ends_with(path, ".md")
        or ends_with(path, ".mD")
        or ends_with(path, ".Md")
        or ends_with(path, ".MD")
    )


class PathAndTestConfig:
    path: byte*
    glob_lineno: int
    config: TestConfig


def get_default_config(defaults_for_all_tests: TestConfig*, markdown: bool) -> TestConfig:
    defaults = TestConfig{}

    defaults.output_comment_rules.append(["Output", "{comment}"])
    defaults.value_present[TestConfigOption.OutputCommentRules as int] = True

    defaults.markdown_code_block_languages.append("jou")
    defaults.value_present[TestConfigOption.MarkdownCodeBlockLanguages as int] = True

    if markdown:
        defaults.command.append("jou")
        defaults.command.append("--stdin-name")
        defaults.command.append("{file}")
        defaults.command.append("-")
    else:
        defaults.command.append("jou")
        defaults.command.append("{file}")
    defaults.value_present[TestConfigOption.Command as int] = True

    defaults_for_all_tests.assign_to(&defaults)
    return defaults


@public
def step3_discover_tests(parsed_joutest_toml: ParsedJoutestToml) -> List[Test]:
    # We can't do this in one pass (that is, loop through just once), because
    # multiple sections of joutest.toml can apply to the same file, and we
    # already need to know the final/merged configuration when extracting tests
    # from markdown files.
    #
    # We first figure out how each file should be configured.
    merged_configs = List[PathAndTestConfig]{}

    for config = parsed_joutest_toml.tests.ptr; config < parsed_joutest_toml.tests.end(); config++:
        if not config.value_present[TestConfigOption.Files as int]:
            fail_in_toml(config.lineno, "each 'tests' table must contain 'files'")

        for i = 0; i < config.files.len; i++:
            glob = config.files.ptr[i]
            glob_lineno = config.files_linenos.ptr[i]

            glob_result = List[byte*]{}
            do_glob(glob, ".", &glob_result, 10)  # TODO: don't hard-code depth limit?
            if glob_result.len == 0:
                error: byte[500]
                if strstr(glob, "*") == NULL:
                    # not really a glob
                    snprintf(error, sizeof(error), "file not found: %s", glob)
                else:
                    snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
                fail_in_toml(glob_lineno, error)

            sort_strings(glob_result.ptr, glob_result.len)
            for path = glob_result.ptr; path < glob_result.end(); path++:
                merged_config: PathAndTestConfig* = NULL
                for m = merged_configs.ptr; m < merged_configs.end(); m++:
                    if strcmp(m.path, *path) == 0:
                        merged_config = m
                        break
                if merged_config == NULL:
                    merged_configs.append(PathAndTestConfig{
                        path = *path,
                        glob_lineno = glob_lineno,
                        config = get_default_config(
                            &parsed_joutest_toml.defaults_for_all_tests,
                            is_markdown_file(*path),
                        ),
                    })
                    merged_config = &merged_configs.end()[-1]
                config.assign_to(&merged_config.config)

            free(glob_result.ptr)

    # Now create tests from each file
    tests = List[Test]{}
    for merged_config = merged_configs.ptr; merged_config < merged_configs.end(); merged_config++:
        if is_markdown_file(merged_config.path):
            add_tests_from_markdown(&tests, merged_config.path, &merged_config.config, merged_config.glob_lineno)
        else:
            tests.append(Test{path = merged_config.path, config = &merged_config.config})

    # Can't free merged_configs, tests contain pointers to its configs now
    return tests
