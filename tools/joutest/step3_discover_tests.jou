import "stdlib/ascii.jou"
import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/sort.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./glob.jou"
import "./state.jou"


class DiscoveryState:
    tests: List[Test]

    # With markdown files, it is possible we find 0 things to test in the file.
    # So to prevent checking those files several times, we need this.
    files_already_checked: List[byte*]


global huge_buffer: byte[1_000_000]  # surely big enough to fit entire lines!

def add_tests_from_markdown(
    state: DiscoveryState*,
    path: byte*,
    config: TestConfig*,
    glob_lineno: int,
) -> int:
    message: byte[500]
    ntests = 0

    f = fopen(path, "rb")
    if f == NULL:
        snprintf(message, sizeof(message), "failed to open file '%s': %s", path, strerror(get_errno()))
        fail(message)

    lineno = 0
    code_first_lineno = 0  # 0 if not inside a code block
    code_language: byte[100] = ""
    code = List[byte]{}

    while fgets(huge_buffer, sizeof(huge_buffer), f) != NULL:
        lineno++

        if starts_with(huge_buffer, "```"):
            lang = &huge_buffer[3]
            trim_ascii_whitespace(lang)

            if *lang != '\0' and strlen(lang) < sizeof(code_language):
                # Start of code block
                strcpy(code_language, lang)
                code_first_lineno = lineno + 1
                assert code.len == 0
                # If code starts on line 5, add 4 blank lines to beginning so
                # line numbers align correctly.
                for i = 0; i < code_first_lineno - 1; i++:
                    code.append('\n')

            elif *lang == '\0' and code_first_lineno != 0:
                # End of code block
                code.append('\0')
                test = Test{
                    path = strdup(path),
                    config = config,
                    first_markdown_lineno = code_first_lineno,
                    last_markdown_lineno = lineno - 1,
                    markdown_code_block_language = code_language,
                    stdin_input = strdup(code.ptr),
                }
                assert test.stdin_input != NULL
                state.tests.append(test)
                ntests++

                code_first_lineno = 0
                code.len = 0

            else:
                # Whatever this is, it cannot occur in the middle of a code block
                code_first_lineno = 0
                code.len = 0

        elif code_first_lineno != 0:
            # Line inside a code block
            code.extend_from_ptr(huge_buffer, strlen(huge_buffer))

    free(code.ptr)

    if ferror(f) != 0:
        snprintf(message, sizeof(message), "failed to read file '%s': %s", path, strerror(get_errno()))
        fail_in_toml(glob_lineno, message)

    fclose(f)
    return ntests


def is_markdown_file(path: byte*) -> bool:
    # This is documented as being case-insensitive
    return (
        ends_with(path, ".md")
        or ends_with(path, ".mD")
        or ends_with(path, ".Md")
        or ends_with(path, ".MD")
    )


def add_or_update_tests_of_file(state: DiscoveryState*, path: byte*, config: TestConfig*, glob_lineno: int) -> int:
    if is_markdown_file(path):
        return add_tests_from_markdown(state, path, config, glob_lineno)
    else:
        state.tests.append(Test{path = path, config = config})
        return 1


def add_or_update_tests_of_glob(state: DiscoveryState*, glob: byte*, glob_lineno: int, config: TestConfig*) -> None:
    printf("hello\n")
    if strstr(glob, "\\") != NULL:
        fail_in_toml(glob_lineno, "please use forward slashes instead of backslashes")

    error: byte[200]

    if not glob_is_valid(glob):
        snprintf(error, sizeof(error), "invalid path or glob pattern: %s", glob)
        fail_in_toml(glob_lineno, error)

    paths = List[byte*]{}
    # TODO: don't hard-code the glob depth limit
    do_glob(glob, ".", &paths, 10)
    if paths.len == 0:
        if strstr(glob, "*") == NULL:
            # not really a glob
            snprintf(error, sizeof(error), "file not found: %s", glob)
        else:
            snprintf(error, sizeof(error), "glob pattern '%s' does not match any files", glob)
        fail_in_toml(glob_lineno, error)

    # TODO: normalize . and .. components?
    # TODO: normalize case on windows?

    ntests = 0
    for p = paths.ptr; p < paths.end(); p++:
        ntests += add_or_update_tests_of_file(state, *p, config, glob_lineno)
    free(paths.ptr)

    if ntests == 0:
        # TODO: test this
        snprintf(error, sizeof(error), "no tests found in '%s'", glob)
        fail_in_toml(glob_lineno, error)


def compare_tests(t1: Test*, t2: Test*) -> int:
    result = strcmp(t1.path, t2.path)
    if result == 0:
        # One markdown file can contain multiple tests, sort by line number
        result = t1.first_markdown_lineno - t2.first_markdown_lineno
    return result


@public
def step3_discover_tests(configs: List[TestConfig]) -> List[Test]:
    state = DiscoveryState{}

    for config = configs.ptr; config < configs.end(); config++:
        if not config.value_present[TestConfigOption.Files as int]:
            fail_in_toml(config.lineno, "each 'tests' table must contain 'files'")
        assert config.files.len == config.files_linenos.len
        for i = 0; i < config.files.len; i++:
            printf("step3: i = %d\n", i)
            add_or_update_tests_of_glob(&state, config.files.ptr[i], config.files_linenos.ptr[i], config)
            printf("step3: i = %d DONE\n", i)

    Sorter[Test]{}.sort(state.tests.ptr, state.tests.len, compare_tests)
    return state.tests
