# This is public and available on all platforms, because there's a test that
# imports this.
@public
def command_to_string_windows(command: List[byte*]) -> byte*:
    result = List[byte]{}

    for i = 0; i < command.len; i++:
        if i != 0:
            result.append(' ')
        arg = command.ptr[i]

        quoting = arg[0] == '\0' or strstr(arg, " ") != NULL or strstr(arg, "\t") != NULL
        if quoting:
            result.append('"')

        backslash_count = 0
        for p = arg; *p != '\0'; p++:
            match *p:
                case '\\':
                    result.append('\\')
                    backslash_count++
                case '"':
                    # Put double backslashes before quote
                    for ; backslash_count > 0; backslash_count--:
                        result.append('\\')
                    result.append('\\')
                    result.append('"')
                case _:
                    result.append(*p)
                    backslash_count = 0

        if quoting:
            # Put double backslashes before quote
            for ; backslash_count > 0; backslash_count--:
                result.append('\\')
            result.append('"')

    result.append('\0')
    return result.ptr


if not WINDOWS:
    def command_to_string_posix(command: List[byte*]) -> byte*:
        result = List[byte]{}

        for i = 0; i < command.len; i++:
            if i != 0:
                result.append(' ')
            arg = command.ptr[i]

            # The string below is ASCII characters that are safe to include in
            # commands without quoting, in ASCII order (doesn't really matter).
            #
            # I was unsure about '%' and '^' so I left them out.
            if *arg != '\0' and strspn(arg, "+,-./0123456789:=@ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz") == strlen(arg):
                result.extend_from_ptr(arg, strlen(arg))
            else:
                result.append('\'')
                for ; *arg != '\0'; arg++:
                    if *arg == '\'':
                        result.append('\'')  # End single quotes
                        result.append('"')  # Begin double quotes
                        result.append('\'')  # Put the single quote inside the double quotes
                        result.append('"')  # End double quotes
                        result.append('\'')  # Begin single quotes
                    else:
                        result.append(*arg)
                result.append('\'')

        result.append('\0')
        return result.ptr


def is_table_with_string_values(toml: TOML*) -> bool:
    if toml.type != TOMLType.Table:
        return False
    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        if toml_to_string(&kv.value) == NULL:
            return False
    return True


def is_array_of_strings(toml: TOML*) -> bool:
    if toml.type != TOMLType.Array:
        return False
    for item = toml.array.ptr; item < toml.array.end(); item++:
        if toml_to_string(item) == NULL:
            return False
    return True


declare dirname(path: byte*) -> byte*

def apply_settings_to_test(toml: TOML*, test: Test*) -> None:
    assert toml != NULL
    assert toml.type == TOMLType.Table
    assert test != NULL
    assert False  # TODO


def is_slash(b: byte) -> bool:
    return b == '/' or (b == '\\' and WINDOWS)


@public
def step4_configure_tests(tests: List[Test], args: CommandLineArgs*) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        if not test.config.value_present[TestConfigOption.OutputCommentRules as int]:
            assert test.config.output_comment_rules.len == 0
            test.config.output_comment_rules.append(["Output", "{comment}"])

        if not test.config.value_present[TestConfigOption.MarkdownCodeBlockLanguages as int]:
            assert test.config.markdown_code_block_languages.len == 0
            test.config.markdown_code_block_languages.append("jou")

        assert test.working_directory == NULL
        if test.config.cd_to_containing_directory:
            temp = strdup(test.path)
            assert temp != NULL
            test.working_directory = strdup(dirname(temp))  # may modify temp string
            free(temp)

            # Take just the file name: "some/workdir/hello.jou" --> "hello.jou"
            p = &test.path[strlen(test.path)]
            while p > test.path and not is_slash(p[-1]):
                p--
            test.path_in_working_directory = p
        else:
            test.path_in_working_directory = test.path

        if not test.config.value_present[TestConfigOption.Command as int]:
            assert test.config.command.len == 0
            if test.stdin_input != NULL:
                test.config.command.append("jou")
                test.config.command.append("--stdin-name")
                test.config.command.append("{file}")
                test.config.command.append("-")
            else:
                test.config.command.append("jou")
                test.config.command.append("{file}")

        params: byte*[enum_count(FormatParam)]
        memset(params, 0, sizeof(params))
        params[FormatParam.File as int] = test.path_in_working_directory

        assert test.actual_command_list.len == 0
        for arg = test.config.command.ptr; arg < test.config.command.end(); arg++:
            test.actual_command_list.append(format_string(*arg, params))

        assert test.actual_command_string == NULL
        if WINDOWS:
            test.actual_command_string = command_to_string_windows(test.actual_command_list)
        else:
            test.actual_command_string = command_to_string_posix(test.actual_command_list)

        test.uses_output_capturing = (
            test.config.stdout != CaptureMode.DoNotCapture
            or test.config.stderr != CaptureMode.DoNotCapture
        )
