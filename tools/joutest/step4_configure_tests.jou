import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"

import "./state.jou"


def command_to_string(command: List[byte*]) -> byte*:
    result = List[byte]{}

    for i = 0; i < command.len; i++:
        if i != 0:
            result.append(' ')
        arg = command.ptr[i]

        if WINDOWS:
            assert False  # TODO
        else:
            # The string below is ASCII characters that are safe to include in
            # commands without quoting, in ASCII order (doesn't really matter).
            #
            # I was unsure about '%' and '^' so I left them out.
            if *arg != '\0' and strspn(arg, "+,-./0123456789:=@ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz") == strlen(arg):
                result.extend_from_ptr(arg, strlen(arg))
            else:
                result.append('\'')
                for ; *arg != '\0'; arg++:
                    if *arg == '\'':
                        result.append('\'')  # End single quotes
                        result.append('"')  # Begin double quotes
                        result.append('\'')  # Put the single quote inside the double quotes
                        result.append('"')  # End double quotes
                        result.append('\'')  # Begin single quotes
                    else:
                        result.append(*arg)
                result.append('\'')

    result.append('\0')
    return result.ptr


@public
def step4_configure_tests(tests: List[Test], args: CommandLineArgs*) -> None:
    # TODO: do this properly
    for test = tests.ptr; test < tests.end(); test++:
        assert test.actual_command_list.len == 0
        test.actual_command_list.append("jou")
        test.actual_command_list.append(test.path)

        assert test.actual_command_string == NULL
        test.actual_command_string = command_to_string(test.actual_command_list)
