import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"
import "stdlib/toml.jou"

import "./fail.jou"
import "./state.jou"
import "./string_formatter.jou"


# This is public and available on all platforms, because there's a test that
# imports this.
@public
def command_to_string_windows(command: List[byte*]) -> byte*:
    result = List[byte]{}

    for i = 0; i < command.len; i++:
        if i != 0:
            result.append(' ')
        arg = command.ptr[i]

        quoting = arg[0] == '\0' or strstr(arg, " ") != NULL or strstr(arg, "\t") != NULL
        if quoting:
            result.append('"')

        backslash_count = 0
        for p = arg; *p != '\0'; p++:
            match *p:
                case '\\':
                    result.append('\\')
                    backslash_count++
                case '"':
                    # Put double backslashes before quote
                    for ; backslash_count > 0; backslash_count--:
                        result.append('\\')
                    result.append('\\')
                    result.append('"')
                case _:
                    result.append(*p)
                    backslash_count = 0

        if quoting:
            # Put double backslashes before quote
            for ; backslash_count > 0; backslash_count--:
                result.append('\\')
            result.append('"')

    result.append('\0')
    return result.ptr


if not WINDOWS:
    def command_to_string_posix(command: List[byte*]) -> byte*:
        result = List[byte]{}

        for i = 0; i < command.len; i++:
            if i != 0:
                result.append(' ')
            arg = command.ptr[i]

            # The string below is ASCII characters that are safe to include in
            # commands without quoting, in ASCII order (doesn't really matter).
            #
            # I was unsure about '%' and '^' so I left them out.
            if *arg != '\0' and strspn(arg, "+,-./0123456789:=@ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz") == strlen(arg):
                result.extend_from_ptr(arg, strlen(arg))
            else:
                result.append('\'')
                for ; *arg != '\0'; arg++:
                    if *arg == '\'':
                        result.append('\'')  # End single quotes
                        result.append('"')  # Begin double quotes
                        result.append('\'')  # Put the single quote inside the double quotes
                        result.append('"')  # End double quotes
                        result.append('\'')  # Begin single quotes
                    else:
                        result.append(*arg)
                result.append('\'')

        result.append('\0')
        return result.ptr


def enum_from_toml_keyval(kv: TOMLKeyVal*, strings: byte**, nstrings: int) -> int:
    # Sanity checks, so that creating the error message below is simpler
    # This ensures that the strings themselves take up less than 1.1kB.
    assert strlen(kv.key) < 100
    assert nstrings > 0
    assert nstrings <= 10
    for i = 0; i < nstrings; i++:
        assert strlen(strings[i]) < 100

    s = toml_to_string(&kv.value)
    if s != NULL:
        for i = 0; i < nstrings; i++:
            if strcmp(s, strings[i]) == 0:
                return i

    error: byte[2000]  # surely big enough, see above
    sprintf(error, "'%s' must be \"%s\"", kv.key, strings[0])
    for i = 1; i < nstrings; i++:
        if i == nstrings - 1:
            sprintf(&error[strlen(error)], " or \"%s\"", strings[i])
        else:
            sprintf(&error[strlen(error)], ", \"%s\"", strings[i])
    fail_in_toml(kv.value.lineno, error)


def apply_settings_to_test(toml: TOML*, test: Test*) -> None:
    assert toml != NULL
    assert toml.type == TOMLType.Table
    assert test != NULL

    error: byte[200]

    for kv = toml.table.ptr; kv < toml.table.end(); kv++:
        match kv.key with strcmp:
            case "files":
                # Already handled in previous step that created the test
                pass
            case "command":
                test.specified_command_list.len = 0
                if kv.value.type != TOMLType.Array:
                    snprintf(error, sizeof(error), "'%s' must be an array of strings", kv.key)
                    fail_in_toml(kv.value.lineno, error)
                for item = kv.value.array.ptr; item < kv.value.array.end(); item++:
                    if toml_to_string(item) == NULL:
                        snprintf(error, sizeof(error), "'%s' must be an array of strings", kv.key)
                        fail_in_toml(item.lineno, error)
                    test.specified_command_list.append(item)
                if test.specified_command_list.len == 0:
                    snprintf(error, sizeof(error), "'%s' cannot be empty", kv.key)
                    fail_in_toml(kv.value.lineno, error)
            case "stdout":
                test.stdout_capture_mode = enum_from_toml_keyval(kv, CAPTURE_MODE_NAMES, enum_count(CaptureMode)) as CaptureMode
            case "stderr":
                test.stderr_capture_mode = enum_from_toml_keyval(kv, CAPTURE_MODE_NAMES, enum_count(CaptureMode)) as CaptureMode
            case _:
                snprintf(error, sizeof(error), "unknown setting '%s' for a test", kv.key)
                fail_in_toml(kv.value.lineno, error)


@public
def step4_configure_tests(tests: List[Test], args: CommandLineArgs*) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        # TODO: It might be better to loop backwards and explicitly ignore
        #       settings that have been already set. This way we can mark the
        #       used parts of TOML and later show warning about stuff that was
        #       ignored entirely.
        for toml = test.relevant_toml_tables.ptr; toml < test.relevant_toml_tables.end(); toml++:
            apply_settings_to_test(*toml, test)

        assert test.actual_command_list.len == 0
        if test.specified_command_list.len == 0:
            test.actual_command_list.append(strdup("jou"))
            test.actual_command_list.append(strdup(test.path))
        else:
            for arg = test.specified_command_list.ptr; arg < test.specified_command_list.end(); arg++:
                test.actual_command_list.append(string_format(*arg, StringFormatParams{file = test.path}))

        assert test.actual_command_string == NULL
        if WINDOWS:
            test.actual_command_string = command_to_string_windows(test.actual_command_list)
        else:
            test.actual_command_string = command_to_string_posix(test.actual_command_list)

        test.uses_output_capturing = (
            test.stdout_capture_mode != CaptureMode.DoNotCapture
            or test.stderr_capture_mode != CaptureMode.DoNotCapture
        )
