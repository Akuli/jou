import "stdlib/list.jou"
import "stdlib/toml.jou"


@public
class CommandLineArgs:
    verbose: bool


@public
enum TestResult:
    Success
    Failed
    Skipped

@public
class Test:
    path: byte*
    glob_toml: TOML*
    relevant_toml_tables: List[TOML*]
    actual_arguments: List[byte*]
    expected_output: byte*
    result: TestResult


@public
enum RunResultKind:
    FailedToStart
    ExitedNormally
    TerminatedBySignal

@public
class RunResult:
    kind: RunResultKind

    # This is one of several different things...
    #   RunResultKind.FailedToStart: errno on posix, GetLastError() on windows
    #   RunResultKind.ExitedNormally: exit code
    #   RunResultKind.TerminatedBySignal: signal number (never happens on Windows)
    number: int

    output: List[byte]
