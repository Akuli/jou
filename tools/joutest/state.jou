import "stdlib/assert.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"


@public
class CommandLineArgs:
    verbose: bool
    filter_strings: List[byte*]  # Only tests with one or more of these as substring are executed


@public
enum CaptureMode:
    CompareToComments   # (default) expected output comes from comments like "# Output: hello"
    DoNotCapture        # do nothing with the output, let it go to console

@public
global CAPTURE_MODE_NAMES: byte*[enum_count(CaptureMode)] = ["compare_to_comments", "do_not_capture"]


@public
enum TestConfigOption:
    Files
    Stdout
    Stderr
    OutputCommentRules
    Command
    CdToContainingDirectory
    ExpectedExitCode
    MarkdownCodeBlockLanguages

@public
global TEST_CONFIG_OPTION_NAMES: byte*[enum_count(TestConfigOption)] = [
    "files",
    "stdout",
    "stderr",
    "output_comment_rules",
    "command",
    "cd_to_containing_directory",
    "expected_exit_code",
    "markdown_code_block_languages",
]

@public
class TestConfig:
    lineno: int

    value_present: bool[enum_count(TestConfigOption)]  # True if the TOML assigns some value for the option
    value_linenos: int[enum_count(TestConfigOption)]

    files: List[byte*]  # may contain globs
    files_linenos: List[int]  # same length as files
    stdout: CaptureMode
    stderr: CaptureMode
    output_comment_rules: List[byte*[2]]
    command: List[byte*]  # may contain things like "{file}"
    cd_to_containing_directory: bool
    expected_exit_code: int
    markdown_code_block_languages: List[byte*]

    @public
    def print(self) -> None:
        printf("TestConfig:\n")
        # Written weirdly as a loop to get compiler error here when adding a new option.
        for opt = 0; opt < enum_count(TestConfigOption); opt++:
            if not self.value_present[opt]:
                continue

            printf("  %s: ", TEST_CONFIG_OPTION_NAMES[opt])
            match opt as TestConfigOption:
                case TestConfigOption.Files:
                    printf("\n")
                    assert self.files.len == self.files_linenos.len
                    for i = 0 ; i < self.files.len; i++:
                        printf("    %s (line %d)\n", self.files.ptr[i], self.files_linenos.ptr[i])
                case TestConfigOption.Stdout:
                    puts(CAPTURE_MODE_NAMES[self.stdout as int])
                case TestConfigOption.Stderr:
                    puts(CAPTURE_MODE_NAMES[self.stderr as int])
                case TestConfigOption.OutputCommentRules:
                    printf("\n")
                    for pair_ptr = self.output_comment_rules.ptr; pair_ptr < self.output_comment_rules.end(); pair_ptr++:
                        printf("    '# %s:' --> %s\n", (*pair_ptr)[0], (*pair_ptr)[1])
                case TestConfigOption.Command:
                    printf("\n")
                    for i = 0; i < self.command.len; i++:
                        printf("    %s\n", self.command.ptr[i])
                case TestConfigOption.CdToContainingDirectory:
                    if self.cd_to_containing_directory:
                        puts("True")
                    else:
                        puts("False")
                case TestConfigOption.ExpectedExitCode:
                    printf("%s\n", self.expected_exit_code)
                case TestConfigOption.MarkdownCodeBlockLanguages:
                    printf("\n")
                    for i = 0; i < self.markdown_code_block_languages.len; i++:
                        printf("    %s\n", self.markdown_code_block_languages.ptr[i])
        printf("\n")

    @public
    def assign_to(self, dest: TestConfig*) -> None:
        assert self != dest  # prevents a bunch of weird corner cases

        # Written weirdly as a loop to get compiler error here when adding a new option.
        for opt = 0; opt < enum_count(TestConfigOption); opt++:
            if not self.value_present[opt]:
                continue

            dest.value_present[opt] = True
            dest.value_linenos[opt] = self.value_linenos[opt]

            match opt as TestConfigOption:
                case TestConfigOption.Files:
                    dest.files.len = 0
                    dest.files.extend(self.files)
                    dest.files_linenos.len = 0
                    dest.files_linenos.extend(self.files_linenos)
                case TestConfigOption.Stdout:
                    dest.stdout = self.stdout
                case TestConfigOption.Stderr:
                    dest.stderr = self.stderr
                case TestConfigOption.OutputCommentRules:
                    dest.output_comment_rules.len = 0
                    dest.output_comment_rules.extend(self.output_comment_rules)
                case TestConfigOption.Command:
                    dest.command.len = 0
                    dest.command.extend(self.command)
                case TestConfigOption.CdToContainingDirectory:
                    dest.cd_to_containing_directory = self.cd_to_containing_directory
                case TestConfigOption.ExpectedExitCode:
                    dest.expected_exit_code = self.expected_exit_code
                case TestConfigOption.MarkdownCodeBlockLanguages:
                    dest.markdown_code_block_languages.len = 0
                    dest.markdown_code_block_languages.extend(self.markdown_code_block_languages)


@public
class ParsedJoutestToml:
    tests: List[TestConfig]

    # These can't be merged into each config immediately, because they would
    # mess up overriding settings from one item of `tests` with another. That
    # happens when multiple items of `tests` specify the same file, typically
    # with a glob.
    defaults_for_all_tests: TestConfig


@public
enum SimpleResult:
    Success
    Failed
    Skipped

@public
class Test:
    # These are set in step 3 (discover tests)
    path: byte*
    config: TestConfig*
    stdin_input: byte*  # For markdown files, code in the code block, NULL if not used
    first_markdown_lineno: int  # Line number if markdown file, 0 if not markdown file
    last_markdown_lineno: int   # Line number if markdown file, 0 if not markdown file

    # These are set in step 4 (configure tests)
    path_in_working_directory: byte*  # usually same as path, just file name if cd_to_containing_directory is used
    actual_command_list: List[byte*]
    actual_command_string: byte*
    uses_output_capturing: bool
    working_directory: byte*  # NULL means use current directory

    # These are set in step 5 (gather expected output)
    expected_output: byte*

    # These are set in step 6 (run tests)
    start_error: int  # If nonzero, the test failed to start: errno on posix, GetLastError() on windows
    terminating_signal: int  # (POSIX only) signal number that killed the test while running
    actual_exit_code: int  # If no start error, and not killed by signal, it exited normally with this status code
    actual_output: byte*
    simple_result: SimpleResult
