import "stdlib/list.jou"
import "stdlib/toml.jou"


@public
class CommandLineArgs:
    verbose: bool


@public
enum SimpleResult:
    Success
    Failed
    Skipped

@public
enum CaptureMode:
    CompareToComments   # (default) expected output comes from comments like "# Output: hello"
    DoNotCapture        # do nothing with the output, let it go to console

@public
global CAPTURE_MODE_NAMES: byte*[enum_count(CaptureMode)] = ["compare_to_comments", "do_not_capture"]

@public
class Test:
    # These are set in step 3 (discover tests)
    path: byte*
    glob_toml: TOML*
    relevant_toml_tables: List[TOML*]

    # These are set in step 4 (configure tests)
    specified_command_list: List[TOML*]  # may contain things like "{file}"
    actual_command_list: List[byte*]
    actual_command_string: byte*
    stdout_capture_mode: CaptureMode
    stderr_capture_mode: CaptureMode
    uses_output_capturing: bool
    working_directory: byte*  # NULL means use current directory
    expected_exit_code: int

    # These are set in step 5 (gather expected output)
    expected_output: byte*

    # These are set in step 6 (run tests)
    start_error: int  # If nonzero, the test failed to start: errno on posix, GetLastError() on windows
    terminating_signal: int  # (POSIX only) signal number that killed the test while running
    actual_exit_code: int  # If no start error, and not killed by signal, it exited normally with this status code
    actual_output: byte*
    simple_result: SimpleResult
