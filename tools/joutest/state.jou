import "stdlib/io.jou"
import "stdlib/list.jou"


@public
enum TestType:
    JouFile
    MarkdownDocTest

@public
global TEST_TYPE_SUFFIXES: byte*[enum_count(TestType)] = [".jou", ".md"]

@public
enum Skip:
    DontSkip        # (default) run the test
    SkipNormally    # show that the test was skipped
    SkipSilently    # ignore the test entirely

@public
enum StdOutErr:
    CompareToComments   # (default) expected output comes from comments like "# Output: hello"
    Discard             # > /dev/null
    DoNotCapture        # do nothing with the output, let it go to console

@public
global STD_OUT_ERR_NAMES: byte*[enum_count(StdOutErr)] = ["compare_to_comments", "discard", "do_not_capture"]

@public
class TestMarkdownSettings:
    languages_to_test_as_jou: byte[100][10]
    num_languages_to_test_as_jou: int

    @public
    def print(self) -> None:
        printf("    markdown:\n")
        printf("      languages_to_test_as_jou: [")
        for i = 0; i < self.num_languages_to_test_as_jou; i++:
            if i > 0:
                printf(",")
            printf("\"%s\"", self.languages_to_test_as_jou[i])
        printf("]\n")

@public
class Test:
    path: byte*
    defining_toml_lineno: int
    type: TestType

    skip: Skip
    cd_to_containing_directory: bool
    run_compiler_under_valgrind: bool
    markdown: TestMarkdownSettings
    expected_exit_code: int
    stdout: StdOutErr
    stderr: StdOutErr

    @public
    def print(self) -> None:
        printf("  Test \"%s\" (joutest.toml:%d)\n", self.path, self.defining_toml_lineno)
        printf("    Type: %s\n", TEST_TYPE_SUFFIXES[self.type as int])
        printf("    Skip: ")
        match self.skip:
            case Skip.DontSkip:
                printf("false (don't skip)\n")
            case Skip.SkipNormally:
                printf("true (skip normally)\n")
            case Skip.SkipSilently:
                printf("\"silent\" (skip silently)\n")
        printf("    cd_to_containing_directory: %s\n", "true" if self.cd_to_containing_directory else "false")
        printf("    run_compiler_under_valgrind: %s\n", "true" if self.run_compiler_under_valgrind else "false")
        if self.type == TestType.MarkdownDocTest:
            self.markdown.print()
        printf("    expected_exit_code: %d\n", self.expected_exit_code)
        printf("    stdout: %s\n", STD_OUT_ERR_NAMES[self.stdout as int])
        printf("    stderr: %s\n", STD_OUT_ERR_NAMES[self.stderr as int])

@public
class State:
    tests: List[Test]

    @public
    def print(self) -> None:
        printf("State:\n")
        for t = self.tests.ptr; t < self.tests.end(); t++:
            t.print()
