import "stdlib/assert.jou"
import "stdlib/fs.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"


@public
def glob_is_valid(glob: byte*) -> bool:
    # Disallow anything that isn't supported properly
    if strcspn(glob, "\\?[]{}") != strlen(glob):
        return False

    got_double_star = False

    while True:
        component_len = strcspn(glob, "/")
        if component_len == 0:
            return False

        for i = 0; i+1 < component_len; i++:
            if glob[i] == '*' and glob[i+1] == '*':
                # It contains **. It should be the whole component, as in
                # foo/**/bar, and it cannot be repeated like foo/**/bar/**/baz.
                if component_len != 2 or got_double_star:
                    return False
                got_double_star = True

        glob = &glob[component_len]
        if *glob == '\0':
            return True
        assert *glob == '/'
        glob++


# Example: "foo_*_bar/whatever", "foo_thing_bar" --> True
# TODO: this is vibe-coded
def first_glob_component_matches(glob: byte*, name: byte*) -> bool:
    star_glob: byte* = NULL
    star_name: byte* = NULL

    while True:
        match *glob:
            case '\0' | '/':
                # End of glob component: if name also ended, success.
                if *name == '\0':
                    return True

                # Otherwise, if we have a previous '*', let it consume one more char
                if star_glob != NULL:
                    # If star_name already points at '\0', we cannot advance it further
                    if *star_name == '\0':
                        return False
                    star_name++
                    name = star_name
                    glob = star_glob
                    continue

                return False

            case '*':
                # Record position after '*' for backtracking and current name pos
                glob++
                star_glob = glob
                star_name = name
                continue

            case _:
                # If name ended, try to backtrack to a previous '*'
                if *name == '\0':
                    if star_glob != NULL:
                        if *star_name == '\0':
                            return False
                        star_name++
                        name = star_name
                        glob = star_glob
                        continue
                    return False

                # Normal character match
                if *glob == *name:
                    glob++
                    name++
                    continue

                # Mismatch: backtrack to last '*' if present
                if star_glob != NULL:
                    if *star_name == '\0':
                        return False
                    star_name++
                    name = star_name
                    glob = star_glob
                    continue

                return False


@public
def do_glob(glob: byte*, relative_to: byte*, out: List[byte*]*, depth_limit: int) -> None:
    if depth_limit < 0:
        return

    if starts_with(relative_to, "./"):
        relative_to++
        relative_to++

    if *glob == '\0':
        # Previous iterations matched all components
        s = strdup(relative_to)
        assert s != NULL
        out.append(s)
        return

    assert glob_is_valid(glob)

    next_glob = &glob[strcspn(glob, "/")]
    if *next_glob == '/':
        next_glob++

    # Double star can be removed at any point
    if starts_with(glob, "**"):
        do_glob(next_glob, relative_to, out, depth_limit)

    # Wildcards can never match "." or "..", that creates confusing bugs.
    # For example, "rm -rf .*" (don't try this as is!!!) removes the current
    # working directory in some shells, but preserves . and .. in others.
    first_component_has_wildcard = (strcspn(glob, "*") < strcspn(glob, "/"))
    iter = DirIter{dir = relative_to, include_dot_and_dotdot = not first_component_has_wildcard}

    while iter.next():
        # Don't recurse into ".", ".." or ".hidden_file" unless requested explicitly
        if iter.name[0] == '.' and glob[0] != '.':
            continue

        # Double star means we can recurse inside basically anything
        if starts_with(glob, "**"):
            do_glob(glob, iter.path, out, depth_limit - 1)
            continue

        # Filter with first glob component, recurse with the rest.
        if first_glob_component_matches(glob, iter.name):
            do_glob(next_glob, iter.path, out, depth_limit - 1)
