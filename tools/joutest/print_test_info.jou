import "stdlib/io.jou"
import "stdlib/assert.jou"

import "./ansi_colors.jou"
import "./state.jou"


def print_test_info_without_newlines(test: Test*) -> None:
    printf("%s%s", RESET, test.actual_command_string)
    if test.working_directory != NULL:
        printf(" %s(in %s)%s", CYAN, test.working_directory, RESET)
    if test.stdin_input != NULL:
        # Please keep this in 'file "foo", line 123' form. Output like that
        # becomes clickable in some editors, at least porcupine.
        printf(
            " %s(input file \"%s\", line %d to line %d)%s",
            CYAN,
            test.path,
            test.first_markdown_lineno,
            test.last_markdown_lineno,
            RESET,
        )


def print_test_info_multiline(test: Test*) -> None:
    printf("%s*** Command: %s\n", YELLOW, test.actual_command_string)
    if test.working_directory != NULL:
        printf("    Working directory: %s\n", test.working_directory)
    if test.stdin_input != NULL:
        # Please keep this in 'file "foo", line 123' form. Output like that
        # becomes clickable in some editors, at least porcupine.
        printf("    Input: file \"%s\", line %d to line %d\n", test.path, test.first_markdown_lineno, test.last_markdown_lineno)
    printf("%s", RESET)


@public
def print_run(test: Test*, verbose: bool) -> None:
    assert verbose  # In non-verbose mode you shouldn't print anything when the test starts
    printf("%srun:%s ", BLUE, RESET)
    print_test_info_without_newlines(test)
    printf("\n")
    fflush(get_stdout())

@public
def print_ok(test: Test*, verbose: bool) -> None:
    if verbose:
        printf("%s ok %s ", GREEN, RESET)
        print_test_info_without_newlines(test)
        printf("\n")
    else:
        printf("%s.%s", GREEN, RESET)
    fflush(get_stdout())

@public
def print_skip(test: Test*, verbose: bool) -> None:
    if verbose:
        printf("%sskip%s ", YELLOW, RESET)
        print_test_info_without_newlines(test)
        printf("\n")
    else:
        printf("%ss%s", YELLOW, RESET)
    fflush(get_stdout())

@public
def print_fail(test: Test*, verbose: bool) -> None:
    if verbose:
        printf("%sFAIL%s ", RED, RESET)
        print_test_info_without_newlines(test)
        printf("\n")
    else:
        printf("%sF%s", RED, RESET)
    fflush(get_stdout())
