import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"

import "./fail.jou"


@public
enum FormatParam:
    File
    Line
    Comment

global PLACEHOLDERS: byte*[enum_count(FormatParam)] = [
    "{file}",
    "{line}",
    "{comment}",
]


def format_string_is_valid(
    format: byte*,  # the format string
    allowed: bool[enum_count(FormatParam)],  # True means the param is allowed
) -> bool:
    assert format != NULL
    while *format != '\0':
        match *format:
            case '{':
                if starts_with(format, "{{"):
                    format = &format[2]
                else:
                    found = -1
                    for i = 0; i < enum_count(FormatParam); i++:
                        if starts_with(format, PLACEHOLDERS[i]):
                            found = i
                            break
                    if found == -1 or not allowed[found]:
                        return False
                    format = &format[strlen(PLACEHOLDERS[found])]
            case '}':
                if not starts_with(format, "}}"):
                    return False
                format = &format[2]
            case _:
                format++
    return True


@public
def validate_format_string_in_toml(
    format: byte*,  # the format string
    error_lineno: int,  # line number of format string in joutest.toml
    allowed: bool[enum_count(FormatParam)],  # True means the param is allowed
) -> None:
    assert format != NULL
    if not format_string_is_valid(format, allowed):
        error: byte[1000] = "braces are allowed only for "
        assert sizeof(error) >= 2*(100 + 15*enum_count(FormatParam))  # easily big enough
        for i = 0; i < enum_count(FormatParam); i++:
            if allowed[i]:
                strcat(error, PLACEHOLDERS[i])
                strcat(error, ", ")
        strcat(error, "{{ and }} (repeating the braces escapes them)")
        fail_in_toml(error_lineno, error)


@public
def format_string(format: byte*, params: byte*[enum_count(FormatParam)]) -> byte*:
    allowed: bool[enum_count(FormatParam)]
    for i = 0; i < enum_count(FormatParam); i++:
        allowed[i] = (params[i] != NULL)
    assert format_string_is_valid(format, allowed)

    out = List[byte]{}
    while *format != '\0':
        match *format:
            case '{':
                if starts_with(format, "{{"):
                    out.append('{')
                    format = &format[2]
                else:
                    found = False
                    for i = 0; i < enum_count(FormatParam); i++:
                        if starts_with(format, PLACEHOLDERS[i]):
                            found = True
                            assert params[i] != NULL
                            out.extend_from_ptr(params[i], strlen(params[i]))
                            format = &format[strlen(PLACEHOLDERS[i])]
                            break
                    assert found
            case '}':
                assert starts_with(format, "}}")
                out.append('}')
                format = &format[2]
            case _:
                out.append(*format++)

    out.append('\0')
    return out.ptr
