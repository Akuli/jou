import "stdlib/assert.jou"
import "stdlib/list.jou"
import "stdlib/str.jou"

import "./fail.jou"


@public
class StringFormatParams:
    # All of these can be NULL
    file: byte*
    line: byte*
    message: byte*


@public
def string_format(string: byte*, params: StringFormatParams, toml_error_lineno: int) -> byte*:
    assert string != NULL

    error: byte[500] = "braces are allowed only for "
    if params.file != NULL:
        strcat(error, "{file}, ")
    if params.line != NULL:
        strcat(error, "{line}, ")
    if params.message != NULL:
        strcat(error, "{message}, ")
    strcat(error, "{{ and }} (repeating the braces escapes them)")

    out = List[byte]{}
    while *string != '\0':
        match *string:
            case '{':
                if starts_with(string, "{file}") and params.file != NULL:
                    out.extend_from_ptr(params.file, strlen(params.file))
                    string = &strstr(string, "}")[1]
                elif starts_with(string, "{line}") and params.line != NULL:
                    out.extend_from_ptr(params.line, strlen(params.line))
                    string = &strstr(string, "}")[1]
                elif starts_with(string, "{message}") and params.message != NULL:
                    out.extend_from_ptr(params.message, strlen(params.message))
                    string = &strstr(string, "}")[1]
                elif starts_with(string, "{{"):
                    out.append('{')
                    string = &string[2]
                else:
                    fail_in_toml(toml_error_lineno, error)
            case '}':
                if starts_with(string, "}}"):
                    out.append('}')
                    string = &string[2]
                else:
                    fail_in_toml(toml_error_lineno, error)
            case _:
                out.append(*string++)

    out.append('\0')
    return out.ptr
