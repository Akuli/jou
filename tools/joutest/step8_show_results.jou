import "stdlib/assert.jou"
import "stdlib/errno.jou"
import "stdlib/io.jou"
import "stdlib/list.jou"
import "stdlib/mem.jou"
import "stdlib/process.jou"
import "stdlib/str.jou"

import "./ansi_colors.jou"
import "./diff.jou"
import "./fail.jou"
import "./state.jou"

if WINDOWS:
    declare FormatMessageA(
        dwFlags: uint32,
        lpSource: void*,
        dwMessageId: uint32,
        dwLanguageId: uint32,
        lpBuffer: byte*,
        nSize: uint32,
        Arguments: void*,  # actually va_list*
    ) -> uint32
    const FORMAT_MESSAGE_IGNORE_INSERTS: uint32 = 0x00000200
    const FORMAT_MESSAGE_FROM_SYSTEM: uint32 = 0x00001000
else:
    declare strsignal(sig: int) -> byte*


def show_failures(tests: List[Test]) -> None:
    for test = tests.ptr; test < tests.end(); test++:
        if test.simple_result != SimpleResult.Failed:
            continue

        printf("%s*** Command: %s\n", YELLOW, test.actual_command_string)
        if test.working_directory != NULL:
            printf("    Working directory: %s\n", test.working_directory)
        if test.stdin_input != NULL:
            # Please keep this in 'file "foo", line 123' form. Output like that
            # becomes clickable in some editors, at least porcupine.
            printf("    Input: file \"%s\", line %d to line %d\n", test.path, test.first_markdown_lineno, test.last_markdown_lineno)
        printf("%s", RESET)

        if test.start_error != 0:
            printf("Process failed to start: ")
            if WINDOWS:
                message: byte[300] = ""
                FormatMessageA(
                    FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS,
                    NULL, test.start_error as uint32, 0, message, sizeof(message) as uint32, NULL,
                )
                while ends_with(message, "\r") or ends_with(message, "\n"):
                    message[strlen(message)-1] = '\0'
                puts(message)
            else:
                puts(strerror(test.start_error))
        elif test.terminating_signal != 0:
            if WINDOWS:
                # This shouldn't be possible. Windows doesn't have signals.
                assert False
            else:
                printf(
                    "Process was killed by signal %d: %s\n",
                    test.terminating_signal,
                    strsignal(test.terminating_signal),
                )
        else:
            # The process completed, perhaps not successfully but it did something.
            # Output can be wrong, exit code can be wrong, both can be wrong.
            if test.uses_output_capturing and strcmp(test.expected_output, test.actual_output) != 0:
                print_diff(test.expected_output, test.actual_output)

            if test.expected_exit_code != test.actual_exit_code:
                printf(
                    "Process exited with code %d. The correct exit code would be %d.\n",
                    test.actual_exit_code,
                    test.expected_exit_code,
                )

        printf("\n")
    printf("\n")


def fail_with_no_tests_found_error_including_filter_strings(filter_strings: List[byte*]) -> noreturn:
    assert filter_strings.len >= 1

    size = 200 + 10*filter_strings.len
    for p = filter_strings.ptr; p < filter_strings.end(); p++:
        size += strlen(*p)

    error_message: byte* = malloc(size)
    assert error_message != NULL

    sprintf(error_message, "found no tests whose path contains \"%s\"", filter_strings.ptr[0])
    for p = &filter_strings.ptr[1]; p < filter_strings.end(); p++:  # skip first
        if p == &filter_strings.end()[-1]:
            # the last one
            strcat(error_message, " or ")
        else:
            strcat(error_message, ", ")
        strcat(error_message, "\"")
        strcat(error_message, *p)
        strcat(error_message, "\"")
    strcat(error_message, " as a substring")

    fail(error_message)


@public
def step8_show_results(tests: List[Test], args: CommandLineArgs*) -> noreturn:
    if tests.len == 0:
        # No tests were ran, likely because user filtered them all out on command line.
        if args.filter_strings.len == 0:
            fail("found no tests")
        else:
            fail_with_no_tests_found_error_including_filter_strings(args.filter_strings)

    printf("\n\n")

    succeeded = 0
    failed = 0
    skipped = 0
    for test = tests.ptr; test < tests.end(); test++:
        match test.simple_result:
            case SimpleResult.Success:
                succeeded++
            case SimpleResult.Failed:
                failed++
            case SimpleResult.Skipped:
                skipped++

    if failed != 0:
        show_failures(tests)

    printf("%s%d succeeded", GREEN, succeeded)
    if failed != 0:
        printf(", %s%d failed", RED, failed)
    if skipped != 0:
        printf(", %s%d skipped", YELLOW, skipped)
    printf("%s\n", RESET)

    if succeeded > 0 and failed == 0:
        exit(0)
    else:
        exit(1)
