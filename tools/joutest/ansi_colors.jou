@public
global RED: byte* = "\x1b[31m"
@public
global GREEN: byte* = "\x1b[32m"
@public
global YELLOW: byte* = "\x1b[33m"
@public
global BLUE: byte* = "\x1b[34m"
@public
global MAGENTA: byte* = "\x1b[35m"
@public
global CYAN: byte* = "\x1b[36m"

@public
global RESET: byte* = "\x1b[0m"


@public
def disable_colors() -> None:
    RED = ""
    GREEN = ""
    YELLOW = ""
    BLUE = ""
    MAGENTA = ""
    CYAN = ""
    RESET = ""
