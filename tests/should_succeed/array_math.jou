import "stdlib/io.jou"

def test_add() -> None:
    array = [1, 2] + [3, 4]
    printf("%d %d\n", array[0], array[1])  # Output: 4 6

    array += [1, 1]
    printf("%d %d\n", array[0], array[1])  # Output: 5 7

    with_offset = array + [0.5, 0.5]
    printf("%f %f\n", with_offset[0], with_offset[1])  # Output: 5.500000 7.500000

    with_float_offset = array + [0.5 as float, 0.5 as float]
    printf("%f %f\n", with_float_offset[0], with_float_offset[1])  # Output: 5.500000 7.500000

    # Output: Sizes: 16 and 8
    printf("Sizes: %d and %d\n", sizeof(with_offset), sizeof(with_float_offset))


def test_sub() -> None:
    array = [1, 2] - [3, 5]
    printf("%d %d\n", array[0], array[1])  # Output: -2 -3

    array -= [1, 1]
    printf("%d %d\n", array[0], array[1])  # Output: -3 -4

    with_offset = array - [0.5, 0.5]
    printf("%f %f\n", with_offset[0], with_offset[1])  # Output: -3.500000 -4.500000

    with_float_offset = array - [0.5 as float, 0.5 as float]
    printf("%f %f\n", with_float_offset[0], with_float_offset[1])  # Output: -3.500000 -4.500000

    # Output: Sizes: 16 and 8
    printf("Sizes: %d and %d\n", sizeof(with_offset), sizeof(with_float_offset))


def test_neg() -> None:
    array1 = -[1, -2]
    array2 = -[3.4, -5.6]
    array3 = -[7.8 as float, -9 as float]
    printf("%d %d\n", array1[0], array1[1])  # Output: -1 2
    printf("%f %f\n", array2[0], array2[1])  # Output: -3.400000 5.600000
    printf("%f %f\n", array3[0], array3[1])  # Output: -7.800000 9.000000


def test_mul() -> None:
    array = [1, 2] * 3
    printf("%d %d\n", array[0], array[1])  # Output: 3 6

    array = 2 * array
    printf("%d %d\n", array[0], array[1])  # Output: 6 12

    array *= 2
    printf("%d %d\n", array[0], array[1])  # Output: 12 24

    half = 0.5 * array
    printf("%f %f\n", half[0], half[1])  # Output: 6.000000 12.000000

    float_half = array * (0.5 as float)
    printf("%f %f\n", float_half[0], float_half[1])  # Output: 6.000000 12.000000

    midpoint = 0.5*([1.2, 3.4] + [1.4, 3.4])
    printf("%f %f\n", midpoint[0], midpoint[1])  # Output: 1.300000 3.400000

    # Output: Sizes: 16 and 8
    printf("Sizes: %d and %d\n", sizeof(half), sizeof(float_half))


def test_div() -> None:
    floor_divided = [-2, 2, 8] // 3
    printf("%d %d %d\n", floor_divided[0], floor_divided[1], floor_divided[2])  # Output: -1 0 2

    array = [-2, 2, 8] / 3.0  # TODO: remove ".0" when possible
    printf("%f %f %f\n", array[0], array[1], array[2])  # Output: -0.666667 0.666667 2.666667

    array /= 2
    printf("%f %f %f\n", array[0], array[1], array[2])  # Output: -0.333333 0.333333 1.333333

    midpoint = ([1.2, 3.4] + [1.4, 3.4]) / 2
    printf("%f %f\n", midpoint[0], midpoint[1])  # Output: 1.300000 3.400000

    float_midpoint = ([1, 2] + [3, 5]) / (2 as float)
    printf("%f %f\n", float_midpoint[0], float_midpoint[1])  # Output: 2.000000 3.500000

    # Output: Sizes: 12 24 16 8
    printf("Sizes: %d %d %d %d\n", sizeof(floor_divided), sizeof(array), sizeof(midpoint), sizeof(float_midpoint))


def main() -> int:
    test_add()
    test_sub()
    test_neg()
    test_mul()
    test_div()
    return 0
