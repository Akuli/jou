#    flag = True
#    while flag:
#        puts("hi")
#    puts("yooooo wat")
#
#def after_infinite_loop_with_variable_set_after_loop() -> None:
#    flag = True
#    while flag:
#        puts("hi")
#    flag = False

@public  # can't run this in main()
def noreturn_function_called() -> None:
    abort()
    x = 1  # Warning: this code will never run
    y = 2

# https://github.com/Akuli/jou/issues/18
def lots_of_unreachable_code() -> None:
    return
    i = 0  # Warning: this code will never run
    while True:
        if i == 3:
            break
            puts("yooooooo")
        puts("blah")
        i = i+1

def duplicate_avoiding_logic_corner_case() -> None:
    while 1 == 2:
        return
        printf("one\n")  # Warning: this code will never run
    return
    printf("two\n")  # Warning: this code will never run

def with_not() -> None:
    if not True:
        puts("Hello")  # Warning: this code will never run

def main() -> int:
    after_return()
    lots_of_unreachable_code()
    duplicate_avoiding_logic_corner_case()
    with_not()
    return 0
